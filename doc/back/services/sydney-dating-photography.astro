---
// src/pages/services/sydney-dating-photography.astro
import '../../styles/global.css'; 

import Layout from "../../layouts/Layout.astro";
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Packages from '../../components/Packages2.astro';

import { Icon } from 'astro-icon/components';

const serviceD = {
  name: "Sydney Dating Profile Photography & Headshots",
  description: "Professional dating profile portraits in Sydney",
  providerName: "ROSE IS ROSE",
  areaServed: ["Sydney", "Bondi", "Manly", "Parramatta"],
  priceRange: "$$-$$$"
};

const breadcrumbs = [
  { name: "Home", item: "/" },
  { name: "Services", item: "/services" },
  { name: "Dating Profile Photography & Headshots", item: "/services/sydney-dating-photography" }
];


// 页面所有文本内容 (保持你原有的所有数据，不做任何删减)
const serviceData = {
  seo: {
    metaTitle: "Sydney Dating Photography | Dating Profile Photographer Sydney | ROSE IS ROSE",
    metaDescription: "Looking for a dating photographer in Sydney? We'll capture you at Bondi, The Rocks & CBD—natural, confident, and ready for Tinder, Hinge & Bumble. Book your session.",
    keywords: "Sydney dating photography, dating profile photographer Sydney, Tinder photos Sydney, Hinge photographer Sydney, dating portraits Sydney, Bondi photographer, Sydney lifestyle photographer",
    imageAlt: "Relaxed guy near Sydney Opera House getting natural dating photos"
  },
  
  hero: {
    badge: "Dating Portraits That Actually Get You Matches",
    locationTag: "Sydney exclusive",
    titleLine1: "SYDNEY",
    titleLine2: "DATING",
    titleLine3: "PORTRAITS",
    desc: "Real photos, real Sydney locations, real you. We'll help you stand out on Tinder, Hinge and Bumble—without feeling like you're trying too hard.",
    ctaPrimary: "Let's do this",
    ctaSecondary: "Tell me more",
    scrollText: "Scroll",
    heroImage: "/assets/images/andrey-zvyagintsev-x0c6vTO5ibA-unsplash.jpg",
  },

  story: {
    bgText: "MATCH • MATCH",
    titleMain: "THE SYDNEY",
    titleItalic: "DIFFERENCE",
    kicker: "WHY YOUR DATING PROFILE NEEDS A LOCAL",
    quoteLetter: "S",
    quoteBody: "ydney's beautiful, sure. But it's also competitive. On dating apps, your photo is fighting for attention with Bondi sunsets, harbour views, and about a thousand other people who also live here.",
    quoteHighlight: "We're not here to make you look like someone else. We're here to make you look like the best version of you—the one your future date will actually want to meet.",
  },

  strategy: [
    {
      title: "PHOTOS WITH A PLAN",
      content: "Anyone can take a photo at the Opera House. We'll help you build a profile that actually tells a story—so when someone's deciding whether to swipe right, they're not just looking at a picture, they're getting a sense of who you are."
    },
    {
      title: "SYDNEY, BUT MAKE IT YOU",
      content: "The Rocks, Bondi, Surry Hills—they're not just backdrops. They're part of your story. We'll pick spots that match your energy, not just the tourist checklist."
    }
  ],

  pitfalls: {
    title: "WHAT'S HOLDING YOUR PROFILE BACK",
    subtitle: "(and how we fix it)",
    techNote: "Quick gear nerd moment: We shoot on Sony Alpha full-frame with prime lenses (35mm/85mm). Translation? That creamy blurry background that makes you pop? That's the lens. The colours that look like Sydney actually looks? That's the skill. You're welcome.",
    items: [
      {
        no: "01",
        title: "The Gym Mirror Shot",
        desc: "We get it, you work out. But this says \"I spend a lot of time looking at myself\" more than it says \"I'm healthy.\" Let's find something better."
      },
      {
        no: "02",
        title: "The Group Shot Puzzle",
        desc: "Three photos in, and they're still guessing which one is you. Don't make them work that hard. We'll give you shots where you're unmistakably the main character."
      },
      {
        no: "03",
        title: "The Dark Bar Blur",
        desc: "Grainy, dark, weirdly orange—it's not doing you any favours. Sydney has some of the best light in the world. Let's use it."
      }
    ]
  },

  experience: [
    {
      id: "01",
      label: "WARDROBE",
      title: "WHAT TO WEAR (AND WHAT TO SKIP)",
      p1: "Sydney weather is a mood—four seasons in one day, sometimes. We'll help you pack for it.",
      italic: "Linen shirt for that Bondi coastal vibe? Yes. Tailored blazer for a CBD rooftop drink? Also yes. Just not at the same time.",
      p2: "We'll also talk colours—what pops against Sydney's blue-gold palette, what fades into the background. (Spoiler: that grey hoodie? Maybe leave it at home.)"
    },
    {
      id: "02",
      label: "STRATEGY",
      title: "THE ALGORITHM IS REAL",
      p1: "Here's something most photographers won't tell you: the order of your photos matters. A lot. We'll give you a \"put this first, this second, save this for later\" guide based on actual data.",
      list: [
        "First photo: Makes them stop scrolling",
        "Middle photos: Shows your personality",
        "Last photo: The full-body confidence shot"
      ]
    }
  ],

  editing: {
    title: "EDITING: LESS IS MORE",
    content: "Australia's sun is gorgeous. It's also intense. We'll colour-grade to keep that warm Sydney glow while softening harsh shadows and making your skin look like skin—not plastic. You'll look like you just got back from a weekend at Palm Beach. Refreshed. Real. Ready."
  },

  experienceModules: [
    {
      title: "Harbour energy, minus the tourist vibe",
      description: "Yes, we shoot at The Rocks and Circular Quay. No, it won't look like every other tourist photo. We find the quiet corners, the good light, the angles that say 'I live here and I know the good spots.'",
      image: "/assets/images/andrey-zvyagintsev-x0c6vTO5ibA-unsplash.jpg",
      imageAlt: "Sydney lifestyle shoot",
      caption: "That Sydney light just hits different."
    },
    {
      title: "Surry Hills if you've got an edge",
      description: "Brick walls, street art, hidden laneways—Surry Hills has texture for days. If your vibe is more 'creative, a little alternative, definitely interesting,' this is your spot.",
      image: "/assets/images/stefan-stefancik-QXevDflbl8A-unsplash.jpg",
      imageAlt: "Depth of field portrait",
      caption: "That blurry background? That's what good glass does."
    },
    {
      title: "Golden hour, every hour (okay just one)",
      description: "That one hour when Sydney looks like a movie set. We'll chase the light, you'll look like the main character. Simple.",
      image: "/assets/images/photo/giovanna-knollseisen-CA4OaE7f500-unsplash.jpg",
      imageAlt: "Sydney golden hour",
      caption: "No filter needed, but we'll add one anyway."
    }
  ],

  faqTitle: "YOU'VE GOT QUESTIONS",
  faq: [
    {
      question: "Where in Sydney do you shoot?",
      answer: "Wherever feels like you. The Rocks if you're into that timeless, sandstone vibe. Surry Hills if you're more artsy. Bondi or Barangaroo if you want that relaxed coastal energy. Or mix it up—we love a good location mash-up."
    },
    {
      question: "How do I not look like I'm trying too hard?",
      answer: "That's literally our whole thing. We call it 'candid but make it flattering.' We'll get you moving, laughing, pretending to look at something interesting—so it looks like a friend caught you being your best self, not a photographer telling you where to put your hand for the 15th time."
    },
    {
      question: "When's the best time for photos in Sydney?",
      answer: "Golden hour, no contest. That magic 60-90 minutes before sunset when the light makes everyone look like they just came back from a week at Palm Springs. Especially if we're near the water—which, let's be honest, in Sydney we usually are."
    },
    {
      question: "I'm awkward in photos. Help?",
      answer: "Same, honestly. But here's the thing—most people are. We've gotten really good at making awkward people look effortless. Think of it as hanging out with a friend who happens to have a camera, not a 'photoshoot.' We'll figure it out together."
    }
  ],

  footerCta: {
    bgText: "SWIPE • SWIPE",
    titleLine1: "YOUR STORY",
    titleLine2: "STARTS HERE",
    desc: "Sydney's full of stories. Let's make yours one that gets told. (And swiped right on.)",
    button: "Book your session"
  }
};
---

<Layout 
  title={serviceData.seo.metaTitle}
  description={serviceData.seo.metaDescription}
  ogImage="/images/dating-photography.jpg"
  pageType="service"
  service={serviceD}
  breadcrumbs={breadcrumbs}
>
  <Header />
  
  <section class="relative h-screen min-h-[800px] flex items-center justify-center overflow-hidden bg-brand-dark">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-b from-brand-dark/90 via-brand-dark/60 to-brand-dark/90 z-10"></div>
      <img src={serviceData.hero.heroImage} alt={serviceData.seo.imageAlt} class="w-full h-full object-cover opacity-60" />
    </div>

    <div class="container relative z-30 mx-auto px-6 text-center reveal-on-scroll">
      <div class="inline-flex items-center gap-3 px-6 py-3 bg-brand-on-dark/5 backdrop-blur-xl rounded-full border border-brand-on-dark/10 mb-8 animate-float">
        <span class="w-2 h-2 rounded-full bg-brand-accent animate-pulse"></span>
        <span class="text-xs tracking-[0.3em] text-brand-on-dark/80 font-light uppercase">{serviceData.hero.badge}</span>
        <span class="text-brand-on-dark/40 mx-2">•</span>
        <span class="text-xs font-mono text-brand-on-dark/60">{serviceData.hero.locationTag}</span>
      </div>

      <h1 class="text-5xl md:text-8xl font-serif text-brand-on-dark mb-6 leading-[0.9] tracking-tight uppercase">
        {serviceData.hero.titleLine1} 
        {serviceData.hero.titleLine2}<br/>
        {serviceData.hero.titleLine3}
      </h1>

      <div class="w-24 h-px mx-auto mb-8 bg-gradient-to-r from-transparent via-brand-accent to-transparent"></div>

      <p class="text-lg md:text-xl text-brand-on-dark/70 max-w-2xl mx-auto font-light leading-relaxed mb-12">
        {serviceData.hero.desc}
      </p>

      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
        <a href="/contact" class="btn-brand px-12 py-6 min-w-[200px] justify-center">
          <span class="inline-flex items-center gap-2">
            {serviceData.hero.ctaPrimary}
            <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </span>
        </a>
        <a href="#story" class="group flex items-center gap-3 text-brand-on-dark/70 hover:text-brand-on-dark transition-colors">
          <span class="w-12 h-px bg-brand-on-dark/30 group-hover:w-16 group-hover:bg-brand-accent transition-all"></span>
          <span class="text-xs tracking-[0.3em] uppercase font-light">{serviceData.hero.ctaSecondary}</span>
        </a>
      </div>
    </div>
  </section>

  <main class="bg-brand-bg">
    <section id="story" class="max-w-7xl mx-auto px-8 py-32 md:py-40 bg-brand-bg text-brand-primary relative">
      <div class="mb-32 relative reveal-on-scroll">
        <div class="absolute -top-20 left-0 text-[9vw] font-serif text-brand-accent/5 leading-none select-none pointer-events-none whitespace-nowrap">
          {serviceData.story.bgText}
        </div>
        <h2 class="text-6xl md:text-8xl font-serif text-brand-accent leading-[0.9] tracking-[-0.03em] uppercase relative">
          {serviceData.story.titleMain}<br />
          <span class="italic font-light text-brand-muted">{serviceData.story.titleItalic}</span>
        </h2>
        <p class="text-xs md:text-sm text-brand-muted/70 tracking-[0.3em] uppercase mt-12 pl-8 border-l border-brand-muted/30">
          {serviceData.story.kicker}
        </p>
      </div>

      <div class="mb-32 relative reveal-on-scroll">
        <div class="absolute -left-8 top-0 text-[12rem] font-serif text-brand-accent/5 leading-none">"</div>
        <div class="relative pl-16">
          <p class="text-lg md:text-2xl font-light leading-relaxed text-brand-primary/80 mb-8">
            <span class="text-8xl float-left font-serif text-brand-accent mr-6 mt-2 leading-[0.8]">{serviceData.story.quoteLetter}</span>
            {serviceData.story.quoteBody}
          </p>
          <p class="text-lg md:text-xl font-light leading-relaxed text-brand-primary/70 pl-8 border-l-2 border-brand-accent/30 italic">
            {serviceData.story.quoteHighlight}
          </p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-20 mb-32 reveal-on-scroll">
        {serviceData.strategy.map((item) => (
          <div class="relative group">
            <h2 class="text-3xl font-serif text-brand-accent mb-8 uppercase tracking-wide flex items-center">
              <span class="w-12 h-px bg-brand-muted mr-6 group-hover:w-20 transition-all duration-700"></span>
              {item.title}
            </h2>
            <p class="text-base font-light leading-relaxed text-brand-primary/70">{item.content}</p>
          </div>
        ))}
      </div>

      <div class="mb-40 relative reveal-on-scroll">
        <h2 class="text-4xl md:text-5xl font-serif text-brand-accent mb-16 uppercase tracking-wide text-center">
          {serviceData.pitfalls.title}<br />
          <span class="text-xl font-light text-brand-muted block mt-4 tracking-normal">{serviceData.pitfalls.subtitle}</span>
        </h2>
        <div class="grid md:grid-cols-3 gap-8">
          {serviceData.pitfalls.items.map((item) => (
            <div class="group relative p-10 bg-white/50 border border-brand-dark/5 hover:border-brand-accent/30 transition-all duration-700">
              <span class="absolute -top-6 left-8 text-8xl font-serif text-brand-accent/10 group-hover:text-brand-accent/20 transition-colors">{item.no}</span>
              <h3 class="text-2xl font-serif text-brand-accent mb-4 relative z-10">{item.title}</h3>
              <p class="text-sm font-light text-brand-primary/60 leading-relaxed relative z-10">{item.desc}</p>
              <div class="absolute bottom-0 left-0 w-0 h-[2px] bg-brand-accent group-hover:w-full transition-all duration-700"></div>
            </div>
          ))}
        </div>
        <div class="mt-16 p-8 bg-brand-accent/5 border-l-4 border-brand-accent">
          <p class="text-sm font-mono text-brand-primary/80 leading-relaxed">{serviceData.pitfalls.techNote}</p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-20 mb-40 reveal-on-scroll">
        {serviceData.experience.map((exp) => (
          <div class="relative group">
            <h2 class="text-3xl font-serif text-brand-accent mb-10 uppercase tracking-wide">
              <span class="block text-sm font-light text-brand-muted mb-3 tracking-[0.3em]">{exp.id} — {exp.label}</span>
              {exp.title}
            </h2>
            <div class="space-y-6">
              <p class="text-base font-light leading-relaxed text-brand-primary/70">{exp.p1}</p>
              {exp.italic && <p class="text-base font-light leading-relaxed text-brand-primary/70 italic pl-6 border-l-2 border-brand-accent/30">{exp.italic}</p>}
              {exp.p2 && <p class="text-base font-light leading-relaxed text-brand-primary/70">{exp.p2}</p>}
              {exp.list && (
                <ul class="space-y-4 text-base font-light">
                  {exp.list.map((li) => (
                    <li class="flex items-start">
                      <span class="w-1.5 h-1.5 rounded-full bg-brand-accent mt-2 mr-4"></span>
                      <span class="text-brand-primary/70">{li}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        ))}
      </div>

      <div class="mb-40 relative py-24 px-8 bg-brand-dark -mx-8 text-brand-on-dark reveal-on-scroll text-center">
        <h2 class="text-4xl md:text-5xl font-serif mb-8 uppercase tracking-wide">{serviceData.editing.title}</h2>
        <div class="w-24 h-px bg-brand-muted/30 mx-auto mb-8"></div>
        <p class="text-lg md:text-xl font-light leading-relaxed max-w-2xl mx-auto opacity-80">{serviceData.editing.content}</p>
      </div>

      <div class="mb-40 reveal-on-scroll">
        <div class="grid md:grid-cols-3 gap-8">
          {serviceData.experienceModules.map((module) => (
            <div class="group relative bg-white/50 border border-brand-dark/5 hover:border-brand-accent/30 transition-all duration-700">
              <div class="aspect-[4/5] overflow-hidden">
                <img src={module.image} alt={module.imageAlt} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000" />
              </div>
              <div class="p-8">
                <h3 class="text-xl font-serif text-brand-accent mb-4">{module.title}</h3>
                <p class="text-sm font-light text-brand-primary/70 leading-relaxed mb-4">{module.description}</p>
                <p class="text-xs font-mono text-brand-muted/60 italic">{module.caption}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <Packages />

      <div class="mb-40 mt-40 reveal-on-scroll">
        <h2 class="text-3xl md:text-4xl font-serif text-brand-accent mb-16 text-center uppercase tracking-wide">{serviceData.faqTitle}</h2>
        <div class="max-w-3xl mx-auto space-y-6">
          {serviceData.faq.map((item, index) => (
            <div class="border-b border-brand-muted/10 pb-6">
              <details class="group">
                <summary class="flex justify-between items-center cursor-pointer list-none">
                  <h3 class="text-lg font-serif text-brand-accent">
                    <span class="inline-block w-8 text-sm font-mono text-brand-muted">{index + 1}.</span>
                    {item.question}
                  </h3>
                  <Icon name="lucide:chevron-down" class="w-5 h-5 text-brand-muted group-open:rotate-180 transition-transform" />
                </summary>
                <p class="mt-4 text-sm font-light text-brand-primary/70 leading-relaxed pl-8">{item.answer}</p>
              </details>
            </div>
          ))}
        </div>
      </div>

      <div class="text-center relative py-20 reveal-on-scroll">
        <div class="absolute inset-0 flex items-center justify-center opacity-5 select-none pointer-events-none">
          <span class="text-[12vw] font-serif text-brand-accent whitespace-nowrap">{serviceData.footerCta.bgText}</span>
        </div>
        <h2 class="text-5xl md:text-7xl font-serif text-brand-accent mb-8 uppercase tracking-tight relative">
          {serviceData.footerCta.titleLine1}<br />
          <span class="italic font-light text-brand-muted">{serviceData.footerCta.titleLine2}</span>
        </h2>
        <p class="text-base font-light text-brand-primary/60 max-w-xl mx-auto mb-16 relative">{serviceData.footerCta.desc}</p>
        <a href="/booking" class="btn-brand">
          {serviceData.footerCta.button}
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  function initDatingPageReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
  }

  document.addEventListener('astro:page-load', initDatingPageReveal);
  initDatingPageReveal();
</script>