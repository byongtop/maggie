---
// src/pages/portfolio.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const portfolioData = {
  seo: {
    title: "Portfolio | ROSE IS ROSE - Dating & Narrative Portraiture",
    description: "Explore our curated collection of narrative portraits and personal branding sessions in Sydney."
  },
  hero: {
    badge: "CURATED COLLECTION",
    title: "PORTFOLIO",
    bgText: "Narrative"
  },
  categories: [
    { id: 'all', name: 'ALL WORK' },
    { id: 'dating', name: 'DATING PORTRAITS' },
    { id: 'lifestyle', name: 'LIFESTYLE' },
    { id: 'personal-brand', name: 'PERSONAL BRAND' }
  ],
  projects: [
    {
      title: 'Magnetic Identity',
      category: 'dating',
      location: 'Sydney Harbour',
      image: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=1200&auto=format&fit=crop',
      slug: '/services/magnetic-identity'
    },
    {
      title: 'Executive Presence',
      category: 'personal-brand',
      location: 'CBD Rooftop',
      image: 'https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?q=80&w=1200&auto=format&fit=crop',
      slug: '#'
    },
    {
      title: 'Golden Hour Glow',
      category: 'dating',
      location: 'Bondi Beach',
      image: 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=1200&auto=format&fit=crop',
      slug: '#'
    },
    {
      title: 'Urban Sophisticate',
      category: 'lifestyle',
      location: 'Surry Hills',
      image: 'https://images.unsplash.com/photo-1539571696357-5a69c17a67c6?q=80&w=1200&auto=format&fit=crop',
      slug: '#'
    },
    {
      title: 'The Modern Gentleman',
      category: 'dating',
      location: 'The Rocks',
      image: 'https://images.unsplash.com/photo-1488161628813-244a2dcba2aa?q=80&w=1200&auto=format&fit=crop',
      slug: '#'
    }
  ],
  cta: {
    badge: "CLIENT STORIES",
    quote: "The portraits didn't just change my dating profile—they changed how I see myself.",
    author: "James, Sydney",
    buttonText: "Create Your Story",
    buttonLink: "/contact"
  }
};
---

<Layout title={portfolioData.seo.title}>
  <Header />

  <section class="relative h-[65vh] flex items-end pb-24 bg-brand-dark overflow-hidden">
    <div class="absolute inset-0 opacity-[0.05] pointer-events-none select-none">
      <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-[28vw] font-serif italic text-brand-on-dark whitespace-nowrap">
        {portfolioData.hero.bgText}
      </span>
    </div>
    <div class="container-wide relative z-10 reveal-on-scroll">
      <span class="h-badge !text-brand-muted">{portfolioData.hero.badge}</span>
      <h1 class="h-hero !text-brand-on-dark">{portfolioData.hero.title}</h1>
      <div class="w-24 h-px bg-brand-muted/30 mt-8"></div>
    </div>
  </section>

  <section class="sticky top-0 z-40 bg-brand-bg/80 backdrop-blur-xl border-b border-brand-dark/5">
    <div class="container-wide py-6">
      <div class="flex flex-wrap justify-center gap-x-10 gap-y-4">
        {portfolioData.categories.map(cat => (
          <button 
            class="text-[10px] tracking-[0.3em] uppercase text-brand-primary/60 hover:text-brand-accent transition-colors py-2 relative group"
            data-category={cat.id}
          >
            {cat.name}
            <span class="absolute bottom-1 left-0 w-full h-px bg-brand-accent scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-500"></span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-brand-bg">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {portfolioData.projects.map((project, index) => (
          <a 
            href={project.slug}
            class={`group relative block overflow-hidden bg-brand-dark reveal-on-scroll ${
              index % 4 === 0 ? 'md:col-span-2 md:row-span-2' : ''
            }`}
          >
            <div class={`relative w-full h-full overflow-hidden ${index % 4 === 0 ? 'aspect-square md:aspect-auto' : 'aspect-[3/4]'}`}>
              <img 
                src={project.image}
                alt={project.title}
                class="w-full h-full object-cover transition-all duration-[2s] ease-[--expo-out]"
              />
              <div class="absolute inset-0 bg-brand-dark/80 opacity-0 group-hover:opacity-100 transition-opacity duration-700 flex flex-col justify-end p-10">
                <span class="text-[9px] tracking-[0.3em] text-brand-muted uppercase mb-2">{project.location}</span>
                <h3 class="text-2xl font-serif text-brand-on-dark mb-4">{project.title}</h3>
                <div class="flex items-center gap-3">
                  <span class="text-[9px] tracking-[0.4em] uppercase text-brand-on-dark/60">View Story</span>
                  <div class="w-12 h-px bg-brand-muted group-hover:w-20 transition-all duration-700"></div>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-32 reveal-on-scroll">
        <button class="btn-brand !bg-transparent !text-brand-accent border border-brand-accent/20 hover:!bg-brand-accent hover:!text-brand-on-dark">
          Load More Work
        </button>
      </div>
    </div>
  </section>

  <section class="section-padding bg-brand-dark text-brand-on-dark relative overflow-hidden">
    <div class="container-tight text-center relative z-10 reveal-on-scroll">
      <span class="h-badge !text-brand-muted">{portfolioData.cta.badge}</span>
      <p class="text-3xl md:text-5xl font-serif italic mb-16 leading-tight">
        "{portfolioData.cta.quote}"
      </p>
      <div class="w-px h-20 bg-brand-muted/30 mx-auto mb-12"></div>
      <p class="h-badge !mb-16 opacity-60">— {portfolioData.cta.author}</p>
      
      <a href={portfolioData.cta.buttonLink} class="group inline-flex flex-col items-center gap-6">
        <span class="text-[11px] tracking-[0.5em] uppercase text-brand-on-dark group-hover:text-brand-muted transition-colors">
          {portfolioData.cta.buttonText}
        </span>
        <div class="w-24 h-px bg-brand-muted group-hover:w-40 transition-all duration-700"></div>
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  function initPortfolio() {
    // 揭幕动画
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));

    // 简单的过滤逻辑占位 (后续可根据需求实现)
    const filterBtns = document.querySelectorAll('[data-category]');
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        console.log('Filtering by:', btn.getAttribute('data-category'));
      });
    });
  }

  document.addEventListener('astro:page-load', initPortfolio);
  initPortfolio();
</script>