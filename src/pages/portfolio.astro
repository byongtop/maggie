---
// src/pages/portfolio.astro 或 src/pages/portfolio/index.astro
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const portfolioCategories = [
  { id: 'all', name: 'ALL WORK' },
  { id: 'dating', name: 'DATING PORTRAITS' },
  { id: 'lifestyle', name: 'LIFESTYLE' },
  { id: 'personal-brand', name: 'PERSONAL BRAND' },
  { id: 'events', name: 'EVENTS' }
];

const featuredProjects = [
  {
    title: 'Magnetic Identity',
    category: 'dating',
    location: 'Sydney Harbour',
    image: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=1200&auto=format&fit=crop',
    slug: '/services/magnetic-identity'
  },
  {
    title: 'Executive Presence',
    category: 'personal-brand',
    location: 'CBD Rooftop',
    image: 'https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?q=80&w=1200&auto=format&fit=crop',
    slug: '/portfolio/executive-presence'
  },
  {
    title: 'Golden Hour Glow',
    category: 'dating',
    location: 'Bondi Beach',
    image: 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=1200&auto=format&fit=crop',
    slug: '/portfolio/golden-hour-glow'
  },
  {
    title: 'Urban Sophisticate',
    category: 'lifestyle',
    location: 'Surry Hills',
    image: 'https://images.unsplash.com/photo-1539571696357-5a69c17a67c6?q=80&w=1200&auto=format&fit=crop',
    slug: '/portfolio/urban-sophisticate'
  },
  {
    title: 'Minimalist Portrait',
    category: 'personal-brand',
    location: 'Paddington Studio',
    image: 'https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?q=80&w=1200&auto=format&fit=crop',
    slug: '/portfolio/minimalist-portrait'
  },
  {
    title: 'The Modern Gentleman',
    category: 'dating',
    location: 'The Rocks',
    image: 'https://images.unsplash.com/photo-1488161628813-244a2dcba2aa?q=80&w=1200&auto=format&fit=crop',
    slug: '/portfolio/modern-gentleman'
  },
  {
    title: 'Authentic Connection',
    category: 'dating',
    location: 'Manly Cove',
    image: 'https://images.unsplash.com/photo-1501196354995-cbb51c65aaea?q=80&w=1200&auto=format&fit=crop',
    slug: '/portfolio/authentic-connection'
  },
  {
    title: 'Creative Visionary',
    category: 'lifestyle',
    location: 'Darlinghurst',
    image: 'https://images.unsplash.com/photo-1521119989659-a83eee488004?q=80&w=1200&auto=format&fit=crop',
    slug: '/portfolio/creative-visionary'
  },
  {
    title: 'Corporate Storyteller',
    category: 'personal-brand',
    location: 'Barangaroo',
    image: 'https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?q=80&w=1200&auto=format&fit=crop',
    slug: '/portfolio/corporate-storyteller'
  },
  {
    title: 'Nightfall Magnetism',
    category: 'dating',
    location: 'Circular Quay',
    image: 'https://images.unsplash.com/photo-1503443207922-dff7d543fd0e?q=80&w=1200&auto=format&fit=crop',
    slug: '/portfolio/nightfall-magnetism'
  }
];
---

<Layout title="Portfolio | ROSE IS ROSE">
  <Header />

  <!-- Hero Section -->
<section class="relative h-[60vh] min-h-[500px] flex items-end pb-20 bg-brand-dark">
  <div class="absolute inset-0 opacity-5">
    <img src="/assets/images/rose-background.png" alt="Portfolio background" class="w-full h-full object-cover" />
  </div>
  <div class="container relative z-10 mx-auto px-6">
    <span class="text-xs tracking-[0.3em] text-brand-muted block mb-4">CURATED COLLECTION</span>
    <h1 class="text-6xl md:text-8xl font-serif text-white mb-6">PORTFOLIO</h1>
    <div class="w-24 h-px bg-brand-muted/30"></div>
  </div>
</section>

  <!-- Filter Categories -->
  <section class="sticky top-20 z-40 bg-brand-bg/80 backdrop-blur-md border-y border-brand-muted/10">
    <div class="container mx-auto px-6 py-6">
      <div class="flex flex-wrap justify-center gap-6">
        {portfolioCategories.map(cat => (
          <button 
            class="text-xs tracking-[0.3em] uppercase text-brand-primary/60 hover:text-brand-accent transition px-4 py-2"
            data-category={cat.id}
          >
            {cat.name}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Masonry Grid -->
  <section class="py-20 bg-brand-bg">
    <div class="container mx-auto px-6">
      <!-- Featured Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {featuredProjects.map((project, index) => (
          <a 
            href={project.slug}
            class={`group relative overflow-hidden bg-brand-dark ${
              index === 0 ? 'md:col-span-2 md:row-span-2' : ''
            }`}
          >
            <div class="aspect-[4/5] md:aspect-auto md:h-full">
              <img 
                src={project.image}
                alt={project.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            </div>
            
            <!-- Overlay Content -->
            <div class="absolute bottom-0 left-0 right-0 p-8 translate-y-full group-hover:translate-y-0 transition-transform duration-500">
              <span class="text-xs text-brand-muted block mb-2">{project.location}</span>
              <h3 class="text-2xl font-serif text-white mb-2">{project.title}</h3>
              <span class="text-[10px] tracking-[0.3em] uppercase text-white/60">View Project →</span>
            </div>
          </a>
        ))}
      </div>

      <!-- Load More Button -->
      <div class="text-center mt-20">
        <button class="px-12 py-4 border border-brand-accent/30 text-brand-accent text-xs tracking-[0.3em] uppercase hover:bg-brand-accent hover:text-white transition">
          Load More Work
        </button>
      </div>
    </div>
  </section>

  <!-- Testimonial / CTA -->
  <section class="py-32 bg-brand-dark text-white">
    <div class="container mx-auto px-6 text-center max-w-3xl">
      <span class="text-xs tracking-[0.3em] text-brand-muted block mb-6">CLIENT STORIES</span>
      <p class="text-2xl md:text-3xl font-serif italic mb-12">
        "The portraits didn't just change my dating profile—they changed how I see myself."
      </p>
      <div class="w-px h-12 bg-brand-muted/30 mx-auto mb-8"></div>
      <p class="text-sm text-white/60 mb-8">— James, Sydney</p>
      <a href="/booking" class="inline-flex items-center gap-4 text-xs tracking-[0.3em] uppercase">
        <span>Create Your Story</span>
        <span class="w-12 h-px bg-brand-muted"></span>
      </a>
    </div>
  </section>
</Layout>