---
// src/pages/services/dating-wardrobe-sydney.astro
// Dating Wardrobe Consulting Sydney - ROSE IS ROSE Service Page

import '../../styles/global.css';
import Layout from "../../layouts/Layout.astro";
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Packages from '../../components/Packages2.astro';
import { Icon } from 'astro-icon/components';

// 服务数据（用于SEO Schema）
const serviceSEODetails = {
  name: "Sydney Dating Wardrobe Consulting",
  description: "Professional wardrobe consulting for dating profile photos in Sydney",
  providerName: "ROSE IS ROSE",
  areaServed: ["Sydney", "Bondi", "Manly", "Parramatta"],
  priceRange: "$$-$$$"
};

// 面包屑导航
const breadcrumbs = [
  { name: "Home", item: "/" },
  { name: "Services", item: "/services" },
  { name: "Dating Wardrobe Consulting", item: "/services/dating-wardrobe-sydney" }
];

/**
 * 页面常量配置 - 集中管理所有文案与元数据
 */
const serviceData = {
  // 基础信息
  info: {
    level: "1",
    no: "03",
    title: "DATING WARDROBE CONSULTING",
    subtitle: "Wear What Works",
    h1Title: "WARDROBE",
    h1TitleSub: "CONSULTING",
    desc: "Stop staring at your closet wondering what works. We'll help you figure out exactly what to wear—so you look confident, comfortable, and totally you.",
    heroImage: "/assets/images/andrey-zvyagintsev-x0c6vTO5ibA-unsplash.jpg",
  },

  // SEO 优化
  seo: {
    metaTitle: "Dating Wardrobe Consultant Sydney | What to Wear for Dating Photos | ROSE IS ROSE",
    metaDescription: "Need a dating wardrobe consultant in Sydney? We'll help you choose outfits for your dating profile photos that look confident, natural, and totally you. Book your session.",
    metaKeywords: "dating wardrobe consultant, dating photo outfits, what to wear for dating photos, Sydney wardrobe styling, dating profile styling"
  },

  // 叙事区块
  narrative: {
    bgText: "OUTFIT • OUTFIT • OUTFIT",
    mainTitleLine1: "WEAR",
    mainTitleLine2: "WHAT WORKS",
    caption: "WHY YOUR OUTFITS MATTER FOR DATING PHOTOS",
    quote: "You know the feeling: photo day's coming, you stare at your closet, try on five things, hate all of them, and end up in the same old outfit you always wear.",
    quoteSupport: "We're here to make sure that never happens. We'll help you find clothes that photograph well, feel like you, and actually work for where we're shooting. No stress. No last-minute panic. Just outfits you feel good in.",
  },

  // 策略区块
  strategies: [
    {
      title: "CLOTHES THAT PHOTOGRAPH WELL",
      text: "Some outfits look great in real life but fall flat on camera. Others? They pop. We know the difference—fabrics that catch light right, colours that work with Sydney's palette, fits that flatter without trying too hard."
    },
    {
      title: "SYDNEY-SPECIFIC STYLING",
      text: "Bondi wants something different from The Rocks. Surry Hills has its own vibe. We'll match your outfits to your locations—so you look like you belong, not like you're visiting."
    }
  ],

  // 错误修复区块
  mistakesTitle: "WARDROBE MISTAKES WE SEE",
  mistakesSub: "(and how we fix them)",
  mistakes: [
    {
      no: "01",
      title: "The Wrong Fit",
      desc: "Too baggy? You disappear. Too tight? Looks uncomfortable. We'll help you find that sweet spot—clothes that fit right and feel good."
    },
    {
      no: "02",
      title: "Colours That Disappear",
      desc: "That grey shirt against the harbour? Gone. Navy against the night sky? Invisible. We'll show you which colours make you pop in Sydney's light."
    },
    {
      no: "03",
      title: "The \"I Tried Too Hard\" Look",
      desc: "Over-styled outfits scream \"I'm trying.\" We go for effortless—clothes that look like you just threw them on, but actually took thought."
    }
  ],
  quickTip: "Quick tip: Textures photograph better than flat fabrics. Linen, knits, subtle patterns—they add depth. We'll show you what works in your wardrobe.",

  // 体验模式
  modes: [
    {
      step: "01 — VIRTUAL",
      title: "WE CAN DO THIS FROM YOUR COUCH",
      p1: "Jump on Zoom. Show us your closet. We'll talk you through what works, what doesn't, and what combinations you haven't thought of.",
      p2: "No judgement. No \"you should buy this.\" Just honest advice from someone who knows what works on camera.",
      p3: "By the end, you'll have a list of outfits for each location. Easy."
    },
    {
      step: "02 — SHOPPING",
      title: "IF YOU NEED SOMETHING NEW",
      p1: "Sometimes your closet needs a little help. We get it.",
      list: [
        "Shopping list with links",
        "In-person shopping trip if you want",
        "No commission, no upselling—just honest recs"
      ]
    }
  ],

  // 黑色视觉区块 (深红背景)
  stressFree: {
    title: "ONE LESS THING TO STRESS ABOUT",
    desc: "Show up on shoot day with your outfits ready to go. No morning panic. No \"does this work?\" texts to friends. Just clothes you feel good in, planned out, waiting for you. That's the goal."
  },

  // 体验模块循环
  experienceModules: [
    {
      title: "The Closet Edit",
      description: "We'll go through your wardrobe with you—yes, really. Pulling out what works, setting aside what doesn't, and discovering combos you never thought of.",
      image: "/assets/images/andrey-zvyagintsev-x0c6vTO5ibA-unsplash.jpg",
      imageAlt: "Wardrobe editing session",
      caption: "Your closet has more than you think."
    },
    {
      title: "Location, Location, Location",
      description: "That linen shirt? Perfect for Bondi. That tailored blazer? That's your CBD rooftop energy. We'll match each outfit to where we're shooting.",
      image: "/assets/images/stefan-stefancik-QXevDflbl8A-unsplash.jpg",
      imageAlt: "Outfit planning for Sydney locations",
      caption: "Bondi vs The Rocks vs CBD—dress the part."
    },
    {
      title: "The Colour Guide",
      description: "Some colours pop against Sydney's blue sky and harbour. Some disappear. We'll show you which is which—so you stand out, not blend in.",
      image: "/assets/images/photo/giovanna-knollseisen-CA4OaE7f500-unsplash.jpg",
      imageAlt: "Colour palette for dating photos",
      caption: "Blue works. Grey? Maybe not."
    }
  ],

  // FAQ
  faqTitle: "YOU'VE GOT QUESTIONS",
  faq: [
    {
      question: "Why do I need a wardrobe consultant for dating photos?",
      answer: "We prevent the 'nothing to wear' stress. We'll help you find clothes that photograph well, suit your body, and actually feel like you—so you can show up with total confidence."
    },
    {
      question: "What if I don't have 'the right' clothes?",
      answer: "We work with what you've got—you'd be surprised what's already in your closet. If needed, we provide a shopping list with zero pressure to buy."
    },
    {
      question: "Does location really affect what I should wear?",
      answer: "100%. A beach shoot requires a different vibe than a city laneway. We'll match your outfits to your locations so you look like you belong there."
    },
    {
      question: "I'm a guy who knows nothing about fashion. Help?",
      answer: "That's exactly who we're here for. We keep it simple: 'wear this, not that.' No fashion lectures, just practical advice that works."
    }
  ],

  // 结尾
  footerCTA: {
    bgText: "STYLE • STYLE • STYLE",
    titleLine1: "DRESS ONCE",
    titleLine2: "STRESS NEVER",
    desc: "Let's figure out your outfits now, so on shoot day you can focus on the fun part: being you.",
    button: "Book your consult"
  }
};
---

<Layout
  title={serviceData.seo.metaTitle}
  description={serviceData.seo.metaDescription}
  ogImage="/images/dating-wardrobe-og.jpg"
  pageType="service"
  service={serviceSEODetails}
  breadcrumbs={breadcrumbs}
>
  <Header />

  {/* Hero Section */}
  <section class="relative h-screen min-h-[800px] flex items-center justify-center overflow-hidden bg-[#34041A]">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-b from-[#34041A]/90 via-[#34041A]/70 to-[#34041A]/90 z-10"></div>
      <img
        src={serviceData.info.heroImage}
        alt="Sydney Wardrobe Consulting"
        class="w-full h-full object-cover animate-ken-burns opacity-60"
      />
    </div>

    <div class="container relative z-30 mx-auto px-6 text-center reveal-on-scroll">
      <div class="inline-flex items-center gap-3 px-6 py-3 bg-white/5 backdrop-blur-xl rounded-full border border-white/10 mb-8 animate-float">
        <span class="w-2 h-2 rounded-full bg-[#8C7355] animate-pulse"></span>
        <span class="text-xs tracking-[0.3em] text-[#F9F2E7]/80 font-light uppercase">{serviceData.info.subtitle}</span>
      </div>

      <h1 class="text-5xl md:text-8xl font-serif text-white mb-6 leading-[1.2] tracking-tight uppercase">
        <span class="block overflow-hidden">
          <span class="block animate-title-slide-up">{serviceData.info.h1Title}</span>
        </span>
        <span class="block overflow-hidden">
          <span class="block animate-title-slide-up animation-delay-200 text-[#8C7355]">{serviceData.info.h1TitleSub}</span>
        </span>
      </h1>

      <div class="w-24 h-px mx-auto mb-8 bg-[#8C7355] animate-width-grow"></div>

      <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto font-light leading-relaxed mb-12 animate-fade-in animation-delay-500">
        {serviceData.info.desc}
      </p>

      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center animate-fade-in animation-delay-700">
        <a href="/booking" class="group relative px-10 py-5 bg-[#8C7355] text-[#F9F2E7] overflow-hidden rounded-2xl transition-all hover:scale-105 active:scale-95">
          <span class="absolute inset-0 w-0 bg-white/20 group-hover:w-full transition-all duration-500"></span>
          <span class="relative flex items-center gap-3 text-sm tracking-[0.3em] uppercase font-light">
            Fix my wardrobe
            <Icon name="lucide:arrow-right" class="w-4 h-4 group-hover:translate-x-2 transition-transform" />
          </span>
        </a>
      </div>
    </div>
  </section>

  <main class="bg-[#F9F2E7]">
    <section id="story" class="max-w-7xl mx-auto px-8 py-32 md:py-40 relative">
      {/* Narrative Section */}
      <div class="mb-32 relative reveal-on-scroll">
        <div class="absolute -top-20 left-0 text-[15vw] font-serif text-[#34041A]/5 leading-none select-none pointer-events-none whitespace-nowrap uppercase">
          {serviceData.narrative.bgText}
        </div>
        <h2 class="text-6xl md:text-8xl font-serif text-[#34041A] leading-[0.9] tracking-[-0.03em] uppercase relative">
          {serviceData.narrative.mainTitleLine1}<br />
          <span class="italic font-light text-[#8C7355] relative inline-block group">
            {serviceData.narrative.mainTitleLine2}
            <span class="absolute -bottom-4 left-0 w-0 h-px bg-[#34041A] group-hover:w-full transition-all duration-1000"></span>
          </span>
        </h2>
        <p class="text-xs md:text-sm text-[#8C7355] tracking-[0.3em] uppercase mt-12 font-sans relative pl-8 before:absolute before:left-0 before:top-1/2 before:w-6 before:h-px before:bg-[#8C7355]/30">
          {serviceData.narrative.caption}
        </p>
      </div>

      {/* Quote Section */}
      <div class="mb-32 relative group pl-16 reveal-on-scroll">
        <div class="absolute -left-8 top-0 text-[12rem] font-serif text-[#34041A]/10 leading-none select-none pointer-events-none">"</div>
        <p class="text-lg md:text-2xl font-light leading-relaxed text-[#3C3835] mb-8">
          {serviceData.narrative.quote}
        </p>
        <p class="text-lg md:text-xl font-light leading-relaxed text-[#3C3835]/70 pl-8 border-l-2 border-[#34041A]/30 italic">
          {serviceData.narrative.quoteSupport}
        </p>
      </div>

      {/* Strategies Grid */}
      <div class="grid md:grid-cols-2 gap-20 mb-32 reveal-on-scroll">
        {serviceData.strategies.map((item) => (
          <div class="relative group">
            <h2 class="text-3xl font-serif text-[#34041A] mb-8 uppercase tracking-wide flex items-center">
              <span class="w-12 h-px bg-[#8C7355]/40 mr-6 group-hover:w-20 transition-all duration-700"></span>
              {item.title}
            </h2>
            <p class="text-base font-light leading-relaxed text-[#3C3835]/70">
              {item.text}
            </p>
          </div>
        ))}
      </div>

      {/* Mistakes Section */}
      <div class="mb-40 relative reveal-on-scroll">
        <h2 class="text-4xl md:text-5xl font-serif text-[#34041A] mb-16 uppercase tracking-wide text-center">
          {serviceData.mistakesTitle}<br />
          <span class="text-xl font-light text-[#8C7355] block mt-4 tracking-normal">{serviceData.mistakesSub}</span>
        </h2>
        <div class="grid md:grid-cols-3 gap-8">
          {serviceData.mistakes.map((item) => (
            <div class="group relative p-10 bg-white/50 backdrop-blur-sm border border-[#8C7355]/10 hover:border-[#34041A]/30 transition-all duration-700 hover:translate-y-[-8px]">
              <span class="absolute -top-6 left-8 text-8xl font-serif text-[#34041A]/10 group-hover:text-[#34041A]/20 transition-colors">{item.no}</span>
              <h3 class="text-2xl font-serif text-[#34041A] mb-4 relative z-10 uppercase">{item.title}</h3>
              <p class="text-sm font-light text-[#3C3835]/60 leading-relaxed relative z-10">{item.desc}</p>
              <div class="absolute bottom-0 left-0 w-0 h-[2px] bg-[#34041A] group-hover:w-full transition-all duration-700"></div>
            </div>
          ))}
        </div>
        <div class="mt-16 p-8 bg-white/40 border-l-4 border-[#34041A] rounded-r-2xl">
          <p class="text-sm font-mono text-[#3C3835]/80 leading-relaxed italic">{serviceData.quickTip}</p>
        </div>
      </div>

      {/* Modes Section */}
      <div class="grid md:grid-cols-2 gap-20 mb-40 reveal-on-scroll">
        {serviceData.modes.map((mode) => (
          <div class="relative group">
            <h2 class="text-3xl font-serif text-[#34041A] mb-10 uppercase tracking-wide">
              <span class="block text-sm font-light text-[#8C7355] mb-3 tracking-[0.3em]">{mode.step}</span>
              {mode.title}
            </h2>
            <div class="space-y-6">
              <p class="text-base font-light text-[#3C3835]/70">{mode.p1}</p>
              {mode.p2 && <p class="text-base font-light italic pl-6 border-l-2 border-[#34041A]/30 text-[#3C3835]/70">{mode.p2}</p>}
              {mode.p3 && <p class="text-base font-light text-[#3C3835]/70">{mode.p3}</p>}
              {mode.list && (
                <ul class="space-y-4 text-base font-light">
                  {mode.list.map((li) => (
                    <li class="flex items-start group/item">
                      <span class="w-1.5 h-1.5 rounded-full bg-[#34041A] mt-2 mr-4 group-hover/item:scale-150 transition-transform"></span>
                      <span class="text-[#3C3835]/70">{li}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        ))}
      </div>

      {/* Stress Free Section */}
      <div class="mb-40 relative py-24 px-8 bg-[#34041A] -mx-8 text-[#F9F2E7] reveal-on-scroll">
        <div class="max-w-4xl mx-auto text-center relative">
          <h2 class="text-4xl md:text-5xl font-serif text-white mb-8 uppercase tracking-wide">{serviceData.stressFree.title}</h2>
          <div class="w-24 h-px bg-gradient-to-r from-transparent via-[#8C7355] to-transparent mx-auto mb-8"></div>
          <p class="text-lg md:text-xl font-light leading-relaxed max-w-2xl mx-auto text-white/80">{serviceData.stressFree.desc}</p>
        </div>
      </div>

      {/* Experience Modules */}
      <div class="mb-40 reveal-on-scroll">
        <h2 class="text-3xl md:text-4xl font-serif text-[#34041A] mb-16 text-center uppercase tracking-wide">HOW IT WORKS</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {serviceData.experienceModules.map((module, index) => (
            <div class="group relative bg-white/50 border border-[#8C7355]/10 hover:border-[#34041A]/30 transition-all duration-700">
              <div class="aspect-[4/5] overflow-hidden">
                <img src={module.image} alt={module.imageAlt} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000" />
              </div>
              <div class="p-8 relative">
                <span class="absolute top-4 right-8 text-4xl font-serif text-[#34041A]/10">{(index+1).toString().padStart(2, '0')}</span>
                <h3 class="text-xl font-serif text-[#34041A] mb-4 uppercase">{module.title}</h3>
                <p class="text-sm font-light text-[#3C3835]/70 leading-relaxed mb-4">{module.description}</p>
                <p class="text-xs font-mono text-[#8C7355]/60 italic">{module.caption}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* Packages Component */}
      <Packages />

      {/* FAQ Section */}
      <div class="mb-40 mt-40 reveal-on-scroll">
        <h2 class="text-3xl md:text-4xl font-serif text-[#34041A] mb-16 text-center uppercase tracking-wide">{serviceData.faqTitle}</h2>
        <div class="max-w-3xl mx-auto space-y-6">
          {serviceData.faq.map((item, index) => (
            <div class="border-b border-[#8C7355]/10 pb-6">
              <details class="group">
                <summary class="flex justify-between items-center cursor-pointer list-none">
                  <h3 class="text-lg font-serif text-[#34041A] group-hover:opacity-70 transition-opacity">
                    <span class="inline-block w-8 text-sm font-mono text-[#8C7355]">{(index + 1).toString().padStart(2, '0')}</span>
                    {item.question}
                  </h3>
                  <Icon name="lucide:chevron-down" class="w-5 h-5 text-[#8C7355] group-open:rotate-180 transition-transform" />
                </summary>
                <p class="mt-4 text-sm font-light text-[#3C3835]/70 leading-relaxed pl-8">{item.answer}</p>
              </details>
            </div>
          ))}
        </div>
      </div>

      {/* Footer CTA */}
      <div class="text-center py-20 relative reveal-on-scroll">
        <h2 class="text-5xl md:text-7xl font-serif text-[#34041A] mb-8 uppercase tracking-tight">
          {serviceData.footerCTA.titleLine1}<br />
          <span class="italic font-light text-[#8C7355]">{serviceData.footerCTA.titleLine2}</span>
        </h2>
        <p class="text-base font-light text-[#3C3835]/60 max-w-xl mx-auto mb-16">{serviceData.footerCTA.desc}</p>
        <a href="/booking" class="btn-brand inline-flex items-center gap-3">
          {serviceData.footerCTA.button}
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* 滚动揭幕动画 */
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .reveal-on-scroll.active {
    opacity: 1;
    transform: translateY(0);
  }

  /* 标题滑动动画 */
  @keyframes titleSlideUp {
    from {
      transform: translateY(100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .animate-title-slide-up {
    animation: titleSlideUp 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .animation-delay-200 {
    animation-delay: 0.2s;
  }

  .animation-delay-500 {
    animation-delay: 0.5s;
  }

  .animation-delay-700 {
    animation-delay: 0.7s;
  }

  /* 宽度增长动画 */
  @keyframes widthGrow {
    from { width: 0; }
    to { width: 6rem; }
  }

  .animate-width-grow {
    animation: widthGrow 1.2s ease-out forwards;
  }

  /* 淡入动画 */
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }

  /* 浮动动画 */
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  /* 脉冲动画 */
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .animate-pulse {
    animation: pulse 2s ease-in-out infinite;
  }

  /* Ken Burns 效果 */
  @keyframes kenBurns {
    from { transform: scale(1); }
    to { transform: scale(1.1); }
  }

  .animate-ken-burns {
    animation: kenBurns 20s ease-out forwards;
  }

  /* 自定义滚动条 */
  ::-webkit-scrollbar {
    width: 8px;
  }

  ::-webkit-scrollbar-track {
    background: #F9F2E7;
  }

  ::-webkit-scrollbar-thumb {
    background: #8C7355;
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: #34041A;
  }

  ::selection {
    background: rgba(52, 4, 26, 0.15);
    color: #34041A;
  }

  html {
    scroll-behavior: smooth;
  }
</style>

<script>
  function initReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

    document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
  }

  // 兼容 Astro 的 View Transitions
  document.addEventListener('astro:page-load', initReveal);

  // 页面加载时执行
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initReveal);
  } else {
    initReveal();
  }
</script>