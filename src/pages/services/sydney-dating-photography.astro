---
// src/pages/services/sydney-dating-photography.astro
import '../../styles/global.css'; 

import Layout from "../../layouts/Layout.astro";
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Packages from '../../components/Packages2.astro';

import { Icon } from 'astro-icon/components';

const serviceD = {
  name: "Sydney Dating Profile Photography",
  description: "Dating profile photography and dating portraits in Sydney",
  providerName: "ROSE IS ROSE",
  areaServed: ["Sydney", "Bondi", "Manly", "Parramatta"],
  priceRange: "$$-$$$",
  // For Review schema — add when you have real reviews:
  // aggregateRating: { ratingValue: "5", reviewCount: "24" }
};

const breadcrumbs = [
  { name: "Home", item: "/" },
  { name: "Services", item: "/services" },
  { name: "Dating Profile Photography Sydney", item: "/services/sydney-dating-photography" }
];

const serviceData = {
  seo: {
    // PRIMARY keyword: "dating profile photography Sydney" in title, near the front
    metaTitle: "Dating Profile Photography Sydney | Dating Portraits | ROSE IS ROSE",
    // Natural sentence, primary keyword in first half, secondary (dating portraits) woven in
    metaDescription: "Sydney dating profile photography for Tinder, Hinge and Bumble. Real locations, honest portraits, no awkward posing. Book with Rose.",
    keywords: "dating profile photography Sydney, dating profile photographer Sydney, dating portraits Sydney, Tinder photos Sydney, Hinge photographer Sydney, Bumble photos Sydney, Bondi photographer",
    // ✅ SEO-rich alt: brand + primary keyword + location
    imageAlt: "Sydney dating profile photography session by ROSE IS ROSE — natural outdoor portrait near the harbour"
  },
  
  hero: {
    // Badge: no fluff, speaks directly to the problem
    badge: "Dating Profile Photography · Sydney",
    locationTag: "Sydney only",
    // H1 rendered as three visual lines — but the actual text reads as one indexable phrase
    // Wrap in a single <h1> with CSS line breaks, not separate elements, for SEO
    h1Full: "Sydney Dating Profile Photography",
    titleLine1: "SYDNEY",
    titleLine2: "DATING PROFILE",
    titleLine3: "PHOTOGRAPHY",
    // Direct, no "journey" language — speaks to the person who is privately frustrated
    desc: "You're not unlovable. You're just using photos that don't look like you on a good day. Let's fix that.",
    ctaPrimary: "Book a session",
    ctaSecondary: "See how it works",
    scrollText: "Scroll",
    heroImage: "/assets/images/s1.jpg",
  },

  story: {
    bgText: "MATCH • MATCH",
    titleMain: "THE REAL",
    titleItalic: "REASON",
    // Kicker names the problem head-on — no softening
    kicker: "WHY YOUR DATING PROFILE ISN'T WORKING",
    quoteLetter: "N",
    // Starts mid-thought, like a real person talking — no "Sydney is beautiful, sure"
    quoteBody: "obody swipes on a photo and thinks 'I wonder what their personality is like.' They swipe on a feeling. And right now, your photos are giving off the wrong one — or worse, no feeling at all.",
    // The pivot: empathy without being patronising
    quoteHighlight: "It's not your face. It's the photo. There's a difference, and I've spent years learning exactly how to close that gap.",
  },

  // Renamed from "strategy" to something more pointed
  whyItMatters: [
    {
      title: "THREE SECONDS.",
      content: "That's how long someone spends on your first photo before deciding. Not your bio. Not your job. Your photo. If it's not pulling them in within three seconds, they're already gone — and you'll never know why."
    },
    {
      title: "SYDNEY IS COMPETITIVE.",
      content: "This city is full of attractive, interesting people — and most of them have mediocre dating profile photos. That's actually good news for you. One session and you're already ahead of half the app."
    }
  ],

  pitfalls: {
    title: "WHAT YOUR PHOTOS ARE SAYING ABOUT YOU",
    subtitle: "(without you realising)",
    // Tech note rewritten — confident, not nerdy-explaining
    techNote: "Shot on Sony Alpha full-frame with 35mm and 85mm prime lenses. That soft background that makes you look like the subject of the photo, not a person standing in front of a background? That's not a filter. That's the glass. Colour grading done to match how Sydney actually looks in real life — warm, bright, a little golden.",
    items: [
      {
        no: "01",
        title: "The Caught-Off-Guard Shot",
        // Pain point: no confidence in how they look — reframe as a solvable problem
        desc: "Squinting into the sun, mid-laugh at something no one else can see, slightly blurry. It reads as 'I don't have a single photo I actually like of myself.' We're going to change that."
      },
      {
        no: "02",
        title: "The Group Photo Stand-In",
        desc: "Four people, zero context. Are you the one on the left? The right? The one who got cropped? Don't make someone do detective work. Every photo should be clearly, confidently you."
      },
      {
        no: "03",
        title: "The Mirror, The Car, The Ceiling",
        // Specific and a bit wry — not preachy
        desc: "Bathroom mirror, car selfie, photo taken from below while you're lying on the couch. These aren't bad because of a 'rule' — they're bad because they tell someone you didn't think you were worth the effort."
      }
    ]
  },

  // Rewritten to feel like genuine prep advice, not a listicle
  experience: [
    {
      id: "01",
      label: "BEFORE WE SHOOT",
      title: "WE TALK FIRST.",
      p1: "Not a form. An actual conversation. What are you looking for? What do you hate about photos of yourself? What's the one thing you wish people noticed about you before they judged your height or your hairline?",
      italic: "I've heard it all. The woman who thinks she photographs badly from every angle. The guy who hasn't liked a photo of himself in ten years. We start there.",
      p2: "Then we figure out what to wear, where to shoot, and how to make the whole thing feel less like a photoshoot and more like a good afternoon in Sydney."
    },
    {
      id: "02",
      label: "PROFILE STRATEGY",
      title: "THE ORDER MATTERS MORE THAN YOU THINK.",
      p1: "I'll tell you exactly which photo to lead with and why. The apps reward profiles that get early right-swipes — your first image sets that in motion. Whether you're on Tinder, Hinge or Bumble, the dating profile photos that perform best aren't the ones where you look the most attractive — they're the ones where you look the most like yourself.",
      list: [
        "Photo one: stops the scroll — eye contact, good light, clearly you",
        "Photos two and three: build the picture of who you are",
        "Final photo: relaxed, full-length, the version of you someone would actually meet"
      ]
    }
  ],

  editing: {
    title: "EDITED TO LOOK LIKE YOU. ON A REALLY GOOD DAY.",
    // Rewritten — removes "Palm Beach" cliché opener, leads with the real reassurance
    content: "No smoothed-out skin, no whitened teeth, no 'fixed' features. People edit their dating photos into someone slightly better-looking than themselves — and then wonder why their dates seem underwhelmed when they show up. I colour-grade for Sydney's light: warm, natural, sharp where it counts. You'll look like yourself. Just well-rested, well-lit, and happy."
  },

  experienceModules: [
    {
      title: "The Rocks & Circular Quay",
      // Location copy: feels like insider knowledge, not tourism brochure
      description: "Sandstone, harbour light, spots that look expensive without trying. We find the angles that say 'I've actually lived here' rather than 'I'm standing in front of the famous thing.'",
      image: "/assets/images/dating/d03.jpeg",
      imageAlt: "Dating portrait session at The Rocks Sydney — warm harbour light, natural expression",
      caption: "The light near the water at 5pm. Nothing else needed."
    },
    {
      title: "Surry Hills & Redfern",
      description: "Textured walls, good coffee, the kind of neighbourhood that makes you look interesting by proximity. If your dating profile currently has zero personality, this is where we start.",
      image: "/assets/images/dating/d07.jpeg",
      imageAlt: "Dating profile portrait in Surry Hills Sydney — urban backdrop, natural light",
      caption: "Depth of field that actually flatters."
    },
    {
      title: "Golden Hour, Wherever You Are",
      // Removed the "okay just one" joke — felt forced
      description: "An hour before sunset, Sydney turns into a different city. Softer light, longer shadows, that warmth that makes everyone look like they're exactly where they should be. We plan around it.",
      image: "/assets/images/dating/d05.jpeg",
      imageAlt: "Golden hour dating portrait session Sydney — warm natural light outdoor photography",
      caption: "Golden hour in Sydney. Worth planning your whole afternoon around."
    }
  ],

  faqTitle: "QUESTIONS PEOPLE ACTUALLY ASK",
  faq: [
    {
      question: "I genuinely don't like how I look in photos. Can you still help?",
      // Pain point 3 addressed head-on — no toxic positivity
      answer: "Yes — and honestly, this is the most common thing I hear. Most people who think they photograph badly have just never been photographed well. There's a difference between your face and a bad photo of your face. Give me an hour and I'll show you."
    },
    {
      question: "Where do you shoot in Sydney?",
      answer: "Wherever suits you. The Rocks and Circular Quay if you want that effortlessly Sydney feel. Surry Hills or Redfern for more texture and edge. Bondi or Barangaroo for something relaxed and coastal. We decide together based on what you're going for — not just what photographs well in general."
    },
    {
      question: "What should I wear?",
      answer: "Bring two or three options and we'll decide on the day. Generally: colours that aren't grey or black, nothing with a large logo, something you'd actually wear on a first date. I'll tell you what works against Sydney's light and what doesn't. The grey hoodie stays home."
    },
    {
      question: "Will I look like myself, or will I look like a 'dating profile photo'?",
      // Addresses the fear of looking try-hard — speaks to both men and women
      answer: "You'll look like yourself. The whole point is that whoever matches with you recognises you when you walk through the door. We're not building a fantasy — we're capturing the version of you that already exists, just on a day when the light was good and you weren't staring at your own camera."
    },
    {
      question: "How many photos do I get?",
      answer: "Depends on the package — full details in the packages section below. But every final image is individually edited. You won't be sorting through 200 half-decent shots trying to figure out which ones to use. I do that work for you."
    },
    {
      question: "Do you shoot Tinder, Hinge and Bumble profile photos?",
      answer: "All three — and each app has a slightly different vibe. Hinge tends to reward photos that show personality and context, not just a headshot. Tinder's first photo needs to stop the scroll fast. Bumble, especially if you're a woman, gives you control — so your lead photo needs to do real work. I'll help you think through which photos work where, not just hand you a folder and wish you luck."
    }
  ],

  footerCta: {
    bgText: "SWIPE • SWIPE",
    titleLine1: "ENOUGH",
    titleLine2: "WAITING",
    // Removed the "swiped right on" pun — a bit too on-the-nose
    desc: "You know what you want. You know the photos aren't helping. One session, done properly — let's go.",
    button: "Book your session"
  }
};
---

<Layout 
  title={serviceData.seo.metaTitle}
  description={serviceData.seo.metaDescription}
  ogImage="/images/dating-profile-photography-sydney.jpg"
  pageType="service"
  service={serviceD}
  breadcrumbs={breadcrumbs}
>
  <Header />
  
  <section class="relative h-screen min-h-[800px] flex items-center justify-center overflow-hidden bg-brand-dark">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-b from-brand-dark/90 via-brand-dark/60 to-brand-dark/90 z-10"></div>
      <img src={serviceData.hero.heroImage} alt={serviceData.seo.imageAlt} class="w-full h-full object-cover opacity-60" />
    </div>

    <div class="container relative z-30 mx-auto px-6 text-center reveal-on-scroll">
      <div class="inline-flex items-center gap-3 px-6 py-3 bg-brand-on-dark/5 backdrop-blur-xl rounded-full border border-brand-on-dark/10 mb-8 animate-float">
        <span class="w-2 h-2 rounded-full bg-brand-accent animate-pulse"></span>
        <span class="text-xs tracking-[0.3em] text-brand-on-dark/80 font-light uppercase">{serviceData.hero.badge}</span>
        <span class="text-brand-on-dark/40 mx-2">•</span>
        <span class="text-xs font-mono text-brand-on-dark/60">{serviceData.hero.locationTag}</span>
      </div>

      {/* 
        ✅ SEO FIX: Single <h1> tag wrapping all three lines.
        The full phrase "Sydney Dating Profile Photography" is readable by crawlers.
        Visual line breaks achieved with <br/> inside one element, not separate elements.
        The hidden span ensures the full keyword phrase exists as continuous text.
      */}
      <h1 class="text-5xl md:text-8xl font-serif text-brand-on-dark mb-6 leading-[0.9] tracking-tight uppercase">
        <span class="sr-only">{serviceData.hero.h1Full}</span>
        <span aria-hidden="true">
          {serviceData.hero.titleLine1}<br />
          {serviceData.hero.titleLine2}<br />
          {serviceData.hero.titleLine3}
        </span>
      </h1>

      <div class="w-24 h-px mx-auto mb-8 bg-gradient-to-r from-transparent via-brand-accent to-transparent"></div>

      <p class="text-lg md:text-xl text-brand-on-dark/70 max-w-2xl mx-auto font-light leading-relaxed mb-12">
        {serviceData.hero.desc}
      </p>

      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
        <a href="/contact" class="btn-brand px-12 py-6 min-w-[200px] justify-center">
          <span class="inline-flex items-center gap-2">
            {serviceData.hero.ctaPrimary}
            <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </span>
        </a>
        <a href="#story" class="group flex items-center gap-3 text-brand-on-dark/70 hover:text-brand-on-dark transition-colors">
          <span class="w-12 h-px bg-brand-on-dark/30 group-hover:w-16 group-hover:bg-brand-accent transition-all"></span>
          <span class="text-xs tracking-[0.3em] uppercase font-light">{serviceData.hero.ctaSecondary}</span>
        </a>
      </div>
    </div>
  </section>

  <main class="bg-brand-bg">
    <section id="story" class="max-w-7xl mx-auto px-8 py-32 md:py-40 bg-brand-bg text-brand-primary relative">
      <div class="mb-32 relative reveal-on-scroll">
        <div class="absolute -top-20 left-0 text-[9vw] font-serif text-brand-accent/5 leading-none select-none pointer-events-none whitespace-nowrap">
          {serviceData.story.bgText}
        </div>
        <h2 class="text-6xl md:text-8xl font-serif text-brand-accent leading-[0.9] tracking-[-0.03em] uppercase relative">
          {serviceData.story.titleMain}<br />
          <span class="italic font-light text-brand-muted">{serviceData.story.titleItalic}</span>
        </h2>
        <p class="text-xs md:text-sm text-brand-muted/70 tracking-[0.3em] uppercase mt-12 pl-8 border-l border-brand-muted/30">
          {serviceData.story.kicker}
        </p>
      </div>

      <div class="mb-32 relative reveal-on-scroll">
        <div class="absolute -left-8 top-0 text-[12rem] font-serif text-brand-accent/5 leading-none">"</div>
        <div class="relative pl-16">
          <p class="text-lg md:text-2xl font-light leading-relaxed text-brand-primary/80 mb-8">
            <span class="text-8xl float-left font-serif text-brand-accent mr-6 mt-2 leading-[0.8]">{serviceData.story.quoteLetter}</span>
            {serviceData.story.quoteBody}
          </p>
          <p class="text-lg md:text-xl font-light leading-relaxed text-brand-primary/70 pl-8 border-l-2 border-brand-accent/30 italic">
            {serviceData.story.quoteHighlight}
          </p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-20 mb-32 reveal-on-scroll">
        {serviceData.whyItMatters.map((item) => (
          <div class="relative group">
            <h2 class="text-3xl font-serif text-brand-accent mb-8 uppercase tracking-wide flex items-center">
              <span class="w-12 h-px bg-brand-muted mr-6 group-hover:w-20 transition-all duration-700"></span>
              {item.title}
            </h2>
            <p class="text-base font-light leading-relaxed text-brand-primary/70">{item.content}</p>
          </div>
        ))}
      </div>

      <div class="mb-40 relative reveal-on-scroll">
        <h2 class="text-4xl md:text-5xl font-serif text-brand-accent mb-16 uppercase tracking-wide text-center">
          {serviceData.pitfalls.title}<br />
          <span class="text-xl font-light text-brand-muted block mt-4 tracking-normal">{serviceData.pitfalls.subtitle}</span>
        </h2>
        <div class="grid md:grid-cols-3 gap-8">
          {serviceData.pitfalls.items.map((item) => (
            <div class="group relative p-10 bg-white/50 border border-brand-dark/5 hover:border-brand-accent/30 transition-all duration-700">
              <span class="absolute -top-6 left-8 text-8xl font-serif text-brand-accent/10 group-hover:text-brand-accent/20 transition-colors">{item.no}</span>
              <h3 class="text-2xl font-serif text-brand-accent mb-4 relative z-10">{item.title}</h3>
              <p class="text-sm font-light text-brand-primary/60 leading-relaxed relative z-10">{item.desc}</p>
              <div class="absolute bottom-0 left-0 w-0 h-[2px] bg-brand-accent group-hover:w-full transition-all duration-700"></div>
            </div>
          ))}
        </div>
        <div class="mt-16 p-8 bg-brand-accent/5 border-l-4 border-brand-accent">
          <p class="text-sm font-mono text-brand-primary/80 leading-relaxed">{serviceData.pitfalls.techNote}</p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-20 mb-40 reveal-on-scroll">
        {serviceData.experience.map((exp) => (
          <div class="relative group">
            <h2 class="text-3xl font-serif text-brand-accent mb-10 uppercase tracking-wide">
              <span class="block text-sm font-light text-brand-muted mb-3 tracking-[0.3em]">{exp.id} — {exp.label}</span>
              {exp.title}
            </h2>
            <div class="space-y-6">
              <p class="text-base font-light leading-relaxed text-brand-primary/70">{exp.p1}</p>
              {exp.italic && <p class="text-base font-light leading-relaxed text-brand-primary/70 italic pl-6 border-l-2 border-brand-accent/30">{exp.italic}</p>}
              {exp.p2 && <p class="text-base font-light leading-relaxed text-brand-primary/70">{exp.p2}</p>}
              {exp.list && (
                <ul class="space-y-4 text-base font-light">
                  {exp.list.map((li) => (
                    <li class="flex items-start">
                      <span class="w-1.5 h-1.5 rounded-full bg-brand-accent mt-2 mr-4"></span>
                      <span class="text-brand-primary/70">{li}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        ))}
      </div>

      <div class="mb-40 relative py-24 px-8 bg-brand-dark -mx-8 text-brand-on-dark reveal-on-scroll text-center">
        <h2 class="text-4xl md:text-5xl font-serif mb-8 uppercase tracking-wide">{serviceData.editing.title}</h2>
        <div class="w-24 h-px bg-brand-muted/30 mx-auto mb-8"></div>
        <p class="text-lg md:text-xl font-light leading-relaxed max-w-2xl mx-auto opacity-80">{serviceData.editing.content}</p>
      </div>

      <div class="mb-40 reveal-on-scroll">
        <div class="grid md:grid-cols-3 gap-8">
          {serviceData.experienceModules.map((module) => (
            <div class="group relative bg-white/50 border border-brand-dark/5 hover:border-brand-accent/30 transition-all duration-700">
              <div class="aspect-[4/5] overflow-hidden">
                <img src={module.image} alt={module.imageAlt} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000" />
              </div>
              <div class="p-8">
                <h3 class="text-xl font-serif text-brand-accent mb-4">{module.title}</h3>
                <p class="text-sm font-light text-brand-primary/70 leading-relaxed mb-4">{module.description}</p>
                <p class="text-xs font-mono text-brand-muted/60 italic">{module.caption}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <Packages />

      <div class="mb-40 mt-40 reveal-on-scroll">
        <h2 class="text-3xl md:text-4xl font-serif text-brand-accent mb-16 text-center uppercase tracking-wide">{serviceData.faqTitle}</h2>
        <div class="max-w-3xl mx-auto space-y-6">
          {serviceData.faq.map((item, index) => (
            <div class="border-b border-brand-muted/10 pb-6">
              <details class="group">
                <summary class="flex justify-between items-center cursor-pointer list-none">
                  <h3 class="text-lg font-serif text-brand-accent">
                    <span class="inline-block w-8 text-sm font-mono text-brand-muted">{index + 1}.</span>
                    {item.question}
                  </h3>
                  <Icon name="lucide:chevron-down" class="w-5 h-5 text-brand-muted group-open:rotate-180 transition-transform" />
                </summary>
                <p class="mt-4 text-sm font-light text-brand-primary/70 leading-relaxed pl-8">{item.answer}</p>
              </details>
            </div>
          ))}
        </div>
      </div>

      <div class="text-center relative py-20 reveal-on-scroll">
        <div class="absolute inset-0 flex items-center justify-center opacity-5 select-none pointer-events-none">
          <span class="text-[12vw] font-serif text-brand-accent whitespace-nowrap">{serviceData.footerCta.bgText}</span>
        </div>
        <h2 class="text-5xl md:text-7xl font-serif text-brand-accent mb-8 uppercase tracking-tight relative">
          {serviceData.footerCta.titleLine1}<br />
          <span class="italic font-light text-brand-muted">{serviceData.footerCta.titleLine2}</span>
        </h2>
        <p class="text-base font-light text-brand-primary/60 max-w-xl mx-auto mb-16 relative">{serviceData.footerCta.desc}</p>
        <a href="/booking" class="btn-brand">
          {serviceData.footerCta.button}
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  function initDatingPageReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
  }

  document.addEventListener('astro:page-load', initDatingPageReveal);
  initDatingPageReveal();
</script>