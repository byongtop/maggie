---
// src/pages/services/sydney-dating-photography.astro
// Sydney Dating Portraits - roseisrose Service Page

import '../../styles/global.css'; 

import Layout from "../../layouts/Layout.astro";
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Packages from '../../components/Packages2.astro';

import { Icon } from 'astro-icon/components';

// 页面元数据
const serviceData = {
  level: "1",
  no: "01",
  title: "Sydney Dating Photography",
  subtitle: "Dating Portraits That Actually Get You Matches",
  h1Title: "Your Sydney Dating Story: Photos That Feel Like You, Matches That Feel Right",
  desc: "Real photos, real Sydney locations, real you. We'll help you stand out on Tinder, Hinge and Bumble—without feeling like you're trying too hard.",
  image: "/assets/images/stefan-stefancik-QXevDflbl8A-unsplash.jpg",
  heroImage: "/assets/images/andrey-zvyagintsev-x0c6vTO5ibA-unsplash.jpg",
  features: [
    "2-3 hour golden hour shoot at Sydney's best spots",
    "15 edited photos that actually look like you",
    "Pre-shoot coffee chat to figure out your vibe",
    "Wardrobe tips that work in Sydney light",
    "Which photo goes where—yes, there's a strategy"
  ],
  order: 1,
  seo: {
    metaTitle: "Sydney Dating Photography | Dating Profile Photographer Sydney | ROSE IS ROSE",
    metaDescription: "Looking for a dating photographer in Sydney? We'll capture you at Bondi, The Rocks & CBD—natural, confident, and ready for Tinder, Hinge & Bumble. Book your session.",
    keywords: "Sydney dating photography, dating profile photographer Sydney, Tinder photos Sydney, Hinge photographer Sydney, dating portraits Sydney, Bondi photographer, Sydney lifestyle photographer",
    imageAlt: "Relaxed guy near Sydney Opera House getting natural dating photos"
  },
  isPublished: true,
  faq: [
    {
      question: "Where in Sydney do you shoot?",
      answer: "Wherever feels like you. The Rocks if you're into that timeless,砂岩 vibe. Surry Hills if you're more artsy. Bondi or Barangaroo if you want that relaxed coastal energy. Or mix it up—we love a good location mash-up."
    },
    {
      question: "How do I not look like I'm trying too hard?",
      answer: "That's literally our whole thing. We call it 'candid but make it flattering.' We'll get you moving, laughing, pretending to look at something interesting—so it looks like a friend caught you being your best self, not a photographer telling you where to put your hand for the 15th time."
    },
    {
      question: "When's the best time for photos in Sydney?",
      answer: "Golden hour, no contest. That magic 60-90 minutes before sunset when the light makes everyone look like they just came back from a week at Palm Springs. Especially if we're near the water—which, let's be honest, in Sydney we usually are."
    },
    {
      question: "I'm awkward in photos. Help?",
      answer: "Same, honestly. But here's the thing—most people are. We've gotten really good at making awkward people look effortless. Think of it as hanging out with a friend who happens to have a camera, not a 'photoshoot.' We'll figure it out together."
    }
  ],
  experienceModules: [
    {
      title: "Harbour energy, minus the tourist vibe",
      description: "Yes, we shoot at The Rocks and Circular Quay. No, it won't look like every other tourist photo. We find the quiet corners, the good light, the angles that say 'I live here and I know the good spots.'",
      image: "/assets/images/andrey-zvyagintsev-x0c6vTO5ibA-unsplash.jpg",
      imageAlt: "Sydney lifestyle shoot",
      caption: "That Sydney light just hits different."
    },
    {
      title: "Surry Hills if you've got an edge",
      description: "Brick walls, street art, hidden laneways—Surry Hills has texture for days. If your vibe is more 'creative, a little alternative, definitely interesting,' this is your spot.",
      image: "/assets/images/stefan-stefancik-QXevDflbl8A-unsplash.jpg",
      imageAlt: "Depth of field portrait",
      caption: "That blurry background? That's what good glass does."
    },
    {
      title: "Golden hour, every hour (okay just one)",
      description: "That one hour when Sydney looks like a movie set. We'll chase the light, you'll look like the main character. Simple.",
      image: "/assets/images/florian-marette-LEDfhIf_c7E-unsplash.jpg",
      imageAlt: "Sydney golden hour",
      caption: "No filter needed, but we'll add one anyway."
    }
  ]
};
---

<Layout 
  title={serviceData.seo.metaTitle}
  description={serviceData.seo.metaDescription}
>
  <Header />
  <!-- Hero Section with Parallax Effect -->
  <section class="relative h-screen min-h-[800px] flex items-center justify-center overflow-hidden">
    <!-- Dynamic Background with Overlay -->
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-b from-brand-dark/90 via-brand-dark/70 to-brand-dark/90 z-10"></div>
      <div class="absolute inset-0 bg-[url('/assets/images/grid-pattern.svg')] opacity-5 z-20"></div>
      <img 
        src={serviceData.heroImage} 
        alt="Sydney Harbour Background" 
        class="w-full h-full object-cover animate-ken-burns"
      />
    </div>

    <!-- Hero Content -->
    <div class="container relative z-30 mx-auto px-6 text-center">
      <!-- Floating Badge -->
      <div class="inline-flex items-center gap-3 px-6 py-3 bg-white/5 backdrop-blur-xl rounded-full border border-white/10 mb-8 animate-float">
        <span class="w-2 h-2 rounded-full bg-brand-accent animate-pulse"></span>
        <span class="text-xs tracking-[0.3em] text-white/80 font-light uppercase">{serviceData.subtitle}</span>
        <span class="text-white/40 mx-2">•</span>
        <span class="text-xs font-mono text-white/60">Sydney exclusive</span>
      </div>

      <!-- Main Title with Split Animation -->
      <h1 class="text-7xl md:text-9xl font-serif text-white mb-6 leading-[0.9] tracking-tight">
        <span class="block overflow-hidden">
          <span class="block animate-title-slide-up">SYDNEY</span>
        </span>
        <span class="block overflow-hidden">
          <span class="block animate-title-slide-up animation-delay-200">DATING</span>
        </span>
        <span class="block overflow-hidden">
          <span class="block animate-title-slide-up animation-delay-400">PORTRAITS</span>
        </span>
      </h1>

      <!-- Gradient Line -->
      <div class="w-24 h-px mx-auto mb-8 bg-gradient-to-r from-transparent via-brand-accent to-transparent animate-width-grow"></div>

      <!-- Description -->
      <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto font-light leading-relaxed mb-12 animate-fade-in animation-delay-500">
        {serviceData.desc}
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center animate-fade-in animation-delay-700">
        <a href="/booking" class="group relative px-10 py-5 bg-brand-accent text-white overflow-hidden rounded-2xl">
          <span class="absolute inset-0 w-0 bg-white/20 group-hover:w-full transition-all duration-500"></span>
          <span class="relative flex items-center gap-3 text-sm tracking-[0.3em] uppercase font-light">
            Let's do this
            <Icon name="lucide:arrow-right" class="w-4 h-4 group-hover:translate-x-2 transition-transform" />
          </span>
        </a>
        <a href="#story" class="group flex items-center gap-3 text-white/70 hover:text-white transition-colors">
          <span class="w-12 h-px bg-white/30 group-hover:w-16 group-hover:bg-brand-accent transition-all"></span>
          <span class="text-xs tracking-[0.3em] uppercase font-light">Tell me more</span>
        </a>
      </div>

      <!-- Scroll Indicator -->
      <div class="absolute bottom-12 left-1/2 -translate-x-1/2">
        <a href="#story" class="flex flex-col items-center gap-3 text-white/40 hover:text-white/60 transition-colors">
          <span class="text-xs tracking-[0.2em] uppercase font-light rotate-90 mb-4">Scroll</span>
          <div class="w-px h-16 bg-gradient-to-b from-white/20 to-transparent"></div>
        </a>
      </div>
    </div>
  </section>

  <!-- Main Content Section -->
  <main class="bg-brand-bg">
  <section id="story" class="max-w-7xl mx-auto px-8 py-32 md:py-40 bg-brand-bg text-brand-primary relative">
    <!-- Background Decorative Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-40 -left-20 w-80 h-80 bg-brand-accent/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-40 -right-20 w-96 h-96 bg-brand-accent/5 rounded-full blur-3xl"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-[url('/assets/images/pattern.png')] opacity-[0.02]"></div>
    </div>

    <!-- 主标题 - 大留白，强对比 -->
    <div class="mb-32 relative">
      <div class="absolute -top-20 left-0 text-[15vw] font-serif text-brand-accent/5 leading-none select-none pointer-events-none whitespace-nowrap">
        MATCH • MATCH • MATCH
      </div>
      <h2 class="text-6xl md:text-8xl font-serif text-brand-accent leading-[0.9] tracking-[-0.03em] uppercase relative">
        THE SYDNEY<br />
        <span class="italic font-light text-brand-muted relative inline-block group">
          DIFFERENCE
          <span class="absolute -bottom-4 left-0 w-0 h-px bg-brand-accent group-hover:w-full transition-all duration-1000"></span>
        </span>
      </h2>
      <p class="text-xs md:text-sm text-brand-muted/70 tracking-[0.3em] uppercase mt-12 font-sans relative pl-8 before:absolute before:left-0 before:top-1/2 before:w-6 before:h-px before:bg-brand-muted/30">
        WHY YOUR DATING PROFILE NEEDS A LOCAL
      </p>
    </div>

    <!-- 引言段落 - 优雅的首字下沉和视差效果 -->
    <div class="mb-32 relative group">
      <div class="absolute -left-8 top-0 text-[12rem] font-serif text-brand-accent/10 leading-none select-none pointer-events-none group-hover:text-brand-accent/20 transition-colors duration-700">
        "
      </div>
      <div class="relative pl-16">
        <p class="text-lg md:text-2xl font-light leading-relaxed text-brand-primary/80 mb-8 dropcap">
          <span class="text-8xl float-left font-serif text-brand-accent mr-6 mt-2 leading-[0.8]">S</span>
          ydney's beautiful, sure. But it's also competitive. On dating apps, your photo is fighting for attention with Bondi sunsets, harbour views, and about a thousand other people who also live here. 
        </p>
        <p class="text-lg md:text-xl font-light leading-relaxed text-brand-primary/70 pl-8 border-l-2 border-brand-accent/30 italic">
          We're not here to make you look like someone else. We're here to make you look like the best version of you—the one your future date will actually want to meet.
        </p>
      </div>
    </div>

    <!-- 战略叙事区块 - 网格布局增加层次 -->
    <div class="grid md:grid-cols-2 gap-20 mb-32">
      <div class="relative group">
        <div class="absolute inset-0 bg-gradient-to-br from-brand-accent/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 -m-8 rounded-3xl"></div>
        <h2 class="text-3xl font-serif text-brand-accent mb-8 uppercase tracking-wide flex items-center">
          <span class="w-12 h-px bg-brand-muted mr-6 group-hover:w-20 transition-all duration-700"></span>
          PHOTOS WITH A PLAN
        </h2>
        <p class="text-base font-light leading-relaxed text-brand-primary/70 relative">
          Anyone can take a photo at the Opera House. We'll help you build a profile that actually tells a story—so when someone's deciding whether to swipe right, they're not just looking at a picture, they're getting a sense of who you are.
        </p>
        <div class="absolute bottom-0 left-0 w-0 h-px bg-brand-accent group-hover:w-full transition-all duration-1000"></div>
      </div>
      <div class="relative group">
        <div class="absolute inset-0 bg-gradient-to-bl from-brand-accent/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 -m-8 rounded-3xl"></div>
        <h2 class="text-3xl font-serif text-brand-accent mb-8 uppercase tracking-wide flex items-center">
          <span class="w-12 h-px bg-brand-muted mr-6 group-hover:w-20 transition-all duration-700"></span>
          SYDNEY, BUT MAKE IT YOU
        </h2>
        <p class="text-base font-light leading-relaxed text-brand-primary/70">
          The Rocks, Bondi, Surry Hills—they're not just backdrops. They're part of your story. We'll pick spots that match your energy, not just the tourist checklist.
        </p>
        <div class="absolute bottom-0 left-0 w-0 h-px bg-brand-accent group-hover:w-full transition-all duration-1000"></div>
      </div>
    </div>

    <!-- 三陷阱区块 - 带有编号的高级列表 -->
    <div class="mb-40 relative">
      <h2 class="text-4xl md:text-5xl font-serif text-brand-accent mb-16 uppercase tracking-wide text-center">
        WHAT'S HOLDING YOUR PROFILE BACK<br />
        <span class="text-xl font-light text-brand-muted block mt-4 tracking-normal">(and how we fix it)</span>
      </h2>
      <div class="grid md:grid-cols-3 gap-8">
        <!-- 陷阱1 -->
        <div class="group relative p-10 bg-white/50 backdrop-blur-sm border border-brand-muted/10 hover:border-brand-accent/30 transition-all duration-700 hover:translate-y-[-8px]">
          <span class="absolute -top-6 left-8 text-8xl font-serif text-brand-accent/10 group-hover:text-brand-accent/20 transition-colors">01</span>
          <h3 class="text-2xl font-serif text-brand-accent mb-4 relative z-10">The Gym Mirror Shot</h3>
          <p class="text-sm font-light text-brand-primary/60 leading-relaxed relative z-10">We get it, you work out. But this says "I spend a lot of time looking at myself" more than it says "I'm healthy." Let's find something better.</p>
          <div class="absolute bottom-0 left-0 w-0 h-[2px] bg-gradient-to-r from-brand-accent to-transparent group-hover:w-full transition-all duration-700"></div>
        </div>
        <!-- 陷阱2 -->
        <div class="group relative p-10 bg-white/50 backdrop-blur-sm border border-brand-muted/10 hover:border-brand-accent/30 transition-all duration-700 hover:translate-y-[-8px]">
          <span class="absolute -top-6 left-8 text-8xl font-serif text-brand-accent/10 group-hover:text-brand-accent/20 transition-colors">02</span>
          <h3 class="text-2xl font-serif text-brand-accent mb-4 relative z-10">The Group Shot Puzzle</h3>
          <p class="text-sm font-light text-brand-primary/60 leading-relaxed relative z-10">Three photos in, and they're still guessing which one is you. Don't make them work that hard. We'll give you shots where you're unmistakably the main character.</p>
          <div class="absolute bottom-0 left-0 w-0 h-[2px] bg-gradient-to-r from-brand-accent to-transparent group-hover:w-full transition-all duration-700"></div>
        </div>
        <!-- 陷阱3 -->
        <div class="group relative p-10 bg-white/50 backdrop-blur-sm border border-brand-muted/10 hover:border-brand-accent/30 transition-all duration-700 hover:translate-y-[-8px]">
          <span class="absolute -top-6 left-8 text-8xl font-serif text-brand-accent/10 group-hover:text-brand-accent/20 transition-colors">03</span>
          <h3 class="text-2xl font-serif text-brand-accent mb-4 relative z-10">The Dark Bar Blur</h3>
          <p class="text-sm font-light text-brand-primary/60 leading-relaxed relative z-10">Grainy, dark, weirdly orange—it's not doing you any favours. Sydney has some of the best light in the world. Let's use it.</p>
          <div class="absolute bottom-0 left-0 w-0 h-[2px] bg-gradient-to-r from-brand-accent to-transparent group-hover:w-full transition-all duration-700"></div>
        </div>
      </div>
      <!-- 技术说明 -->
      <div class="mt-16 p-8 bg-gradient-to-r from-brand-accent/10 to-transparent border-l-4 border-brand-accent rounded-r-2xl">
        <p class="text-sm font-mono text-brand-primary/80 leading-relaxed">
          Quick gear nerd moment: We shoot on Sony Alpha full-frame with prime lenses (35mm/85mm). Translation? That creamy blurry background that makes you pop? That's the lens. The colours that look like Sydney actually looks? That's the skill. You're welcome.
        </p>
      </div>
    </div>

    <!-- 体验区块 - 双栏布局 -->
    <div class="grid md:grid-cols-2 gap-20 mb-40">
      <!-- WARDROBE DIAGNOSTICS -->
      <div class="relative group">
        <div class="sticky top-8">
          <h2 class="text-3xl font-serif text-brand-accent mb-10 uppercase tracking-wide">
            <span class="block text-sm font-light text-brand-muted mb-3 tracking-[0.3em]">01 — WARDROBE</span>
            WHAT TO WEAR (AND WHAT TO SKIP)
          </h2>
          <div class="space-y-6">
            <p class="text-base font-light leading-relaxed text-brand-primary/70">
              Sydney weather is a mood—four seasons in one day, sometimes. We'll help you pack for it.
            </p>
            <p class="text-base font-light leading-relaxed text-brand-primary/70 italic pl-6 border-l-2 border-brand-accent/30">
              Linen shirt for that Bondi coastal vibe? Yes. Tailored blazer for a CBD rooftop drink? Also yes. Just not at the same time.
            </p>
            <p class="text-base font-light leading-relaxed text-brand-primary/70">
              We'll also talk colours—what pops against Sydney's blue-gold palette, what fades into the background. (Spoiler: that grey hoodie? Maybe leave it at home.)
            </p>
          </div>
        </div>
      </div>
      <!-- MASTERING THE HIDING & TINDER ALGORITHM -->
      <div class="relative group">
        <div class="sticky top-8">
          <h2 class="text-3xl font-serif text-brand-accent mb-10 uppercase tracking-wide">
            <span class="block text-sm font-light text-brand-muted mb-3 tracking-[0.3em]">02 — STRATEGY</span>
            THE ALGORITHM IS REAL
          </h2>
          <div class="space-y-6">
            <p class="text-base font-light leading-relaxed text-brand-primary/70">
              Here's something most photographers won't tell you: the order of your photos matters. A lot. We'll give you a "put this first, this second, save this for later" guide based on actual data.
            </p>
            <ul class="space-y-4 text-base font-light">
              <li class="flex items-start group/item">
                <span class="w-2 h-2 rounded-full bg-brand-accent mt-2 mr-4 group-hover/item:scale-150 transition-transform"></span>
                <span class="text-brand-primary/70">First photo: Makes them stop scrolling</span>
              </li>
              <li class="flex items-start group/item">
                <span class="w-2 h-2 rounded-full bg-brand-accent mt-2 mr-4 group-hover/item:scale-150 transition-transform"></span>
                <span class="text-brand-primary/70">Middle photos: Shows your personality</span>
              </li>
              <li class="flex items-start group/item">
                <span class="w-2 h-2 rounded-full bg-brand-accent mt-2 mr-4 group-hover/item:scale-150 transition-transform"></span>
                <span class="text-brand-primary/70">Last photo: The full-body confidence shot</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- 自然修图区块 - 宽幅设计 -->
    <div class="mb-40 relative py-24 px-8 bg-gradient-to-br from-brand-dark via-brand-dark/95 to-brand-dark -mx-8 text-white">
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute top-0 right-0 w-96 h-96 bg-brand-accent/5 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-96 h-96 bg-brand-accent/5 rounded-full blur-3xl"></div>
      </div>
      <div class="max-w-4xl mx-auto text-center relative">
        <h2 class="text-4xl md:text-5xl font-serif text-white mb-8 uppercase tracking-wide">
          EDITING: LESS IS MORE
        </h2>
        <div class="w-24 h-px bg-gradient-to-r from-transparent via-brand-accent to-transparent mx-auto mb-8"></div>
        <p class="text-lg md:text-xl font-light leading-relaxed max-w-2xl mx-auto text-white/80">
          Australia's sun is gorgeous. It's also intense. We'll colour-grade to keep that warm Sydney glow while softening harsh shadows and making your skin look like skin—not plastic. You'll look like you just got back from a weekend at Palm Beach. Refreshed. Real. Ready.
        </p>
      </div>
    </div>

    <!-- Experience Modules Grid -->
    <div class="mb-40">
      <h2 class="text-3xl md:text-4xl font-serif text-brand-accent mb-16 text-center uppercase tracking-wide">
        THE SYDNEY EXPERIENCE
      </h2>
      <div class="grid md:grid-cols-3 gap-8">
        {serviceData.experienceModules.map((module, index) => (
          <div class="group relative overflow-hidden rounded-sm bg-white/50 backdrop-blur-sm border border-brand-muted/10 hover:border-brand-accent/30 transition-all duration-700 hover:translate-y-[-8px]">
            <div class="aspect-[4/5] overflow-hidden">
              <img 
                src={module.image} 
                alt={module.imageAlt}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            </div>
            <div class="p-8">
              <h3 class="text-xl font-serif text-brand-accent mb-4">{module.title}</h3>
              <p class="text-sm font-light text-brand-primary/70 leading-relaxed mb-4">{module.description}</p>
              <p class="text-xs font-mono text-brand-muted/60 italic">{module.caption}</p>
            </div>
            <div class="absolute top-4 right-4 text-6xl font-serif text-brand-accent/10 group-hover:text-brand-accent/20 transition-colors">
              {(index + 1).toString().padStart(2, '0')}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Packages Section -->
    <Packages />

    <!-- FAQ Section -->
    <div class="mb-40 mt-40">
      <h2 class="text-3xl md:text-4xl font-serif text-brand-accent mb-16 text-center uppercase tracking-wide">
        YOU'VE GOT QUESTIONS
      </h2>
      <div class="max-w-3xl mx-auto space-y-6">
        {serviceData.faq.map((item, index) => (
          <div class="group border-b border-brand-muted/10 pb-6">
            <details class="group">
              <summary class="flex justify-between items-center cursor-pointer list-none">
                <h3 class="text-lg font-serif text-brand-accent group-hover:text-brand-accent/80 transition-colors">
                  <span class="inline-block w-8 text-sm font-mono text-brand-muted">{index + 1}.</span>
                  {item.question}
                </h3>
                <Icon name="lucide:chevron-down" class="w-5 h-5 text-brand-muted group-open:rotate-180 transition-transform" />
              </summary>
              <p class="mt-4 text-sm font-light text-brand-primary/70 leading-relaxed pl-8">
                {item.answer}
              </p>
            </details>
          </div>
        ))}
      </div>
    </div>

    <!-- 结尾区块 - 强有力的召唤 -->
    <div class="text-center relative">
      <div class="absolute inset-0 flex items-center justify-center opacity-5">
        <span class="text-[12vw] font-serif text-brand-accent whitespace-nowrap">SWIPE • SWIPE • SWIPE</span>
      </div>
      <h2 class="text-5xl md:text-7xl font-serif text-brand-accent mb-8 uppercase tracking-tight relative">
        YOUR STORY<br />
        <span class="italic font-light text-brand-muted relative inline-block group">
          STARTS HERE
          <span class="absolute -bottom-4 left-1/2 -translate-x-1/2 w-0 h-px bg-brand-accent group-hover:w-full transition-all duration-700"></span>
        </span>
      </h2>
      <p class="text-base font-light text-brand-primary/60 max-w-xl mx-auto mb-16 relative">
        Sydney's full of stories. Let's make yours one that gets told. (And swiped right on.)
      </p>
      
      <!-- 高级按钮 -->
      <a href="/booking" class="group relative inline-flex items-center justify-center px-12 py-6 bg-transparent border border-brand-accent/30 hover:border-brand-accent rounded-full overflow-hidden transition-all duration-500">
        <span class="absolute inset-0 w-0 bg-brand-accent/10 group-hover:w-full transition-all duration-500"></span>
        <span class="relative flex items-center gap-4">
          <span class="text-xs tracking-[0.3em] uppercase font-light text-brand-accent group-hover:tracking-[0.4em] transition-all">
            Book your session
          </span>
          <Icon name="lucide:arrow-right" class="w-4 h-4 text-brand-accent group-hover:translate-x-2 transition-transform" />
        </span>
      </a>
      
      <!-- 装饰元素 -->
      <div class="mt-24 flex justify-center items-center gap-4">
        <span class="w-16 h-px bg-gradient-to-l from-brand-accent/30 to-transparent"></span>
        <div class="flex space-x-3">
          <span class="w-2 h-2 rounded-full bg-brand-accent/30 animate-pulse"></span>
          <span class="w-2 h-2 rounded-full bg-brand-muted/30"></span>
          <span class="w-2 h-2 rounded-full bg-brand-accent/30 animate-pulse animation-delay-300"></span>
        </div>
        <span class="w-16 h-px bg-gradient-to-r from-brand-accent/30 to-transparent"></span>
      </div>
    </div>
  </section>
  </main>

  <Footer />
</Layout>

