---
// src/pages/services/dating-bio-writing-sydney.astro
import '../../styles/global.css'; 
import Layout from "../../layouts/Layout.astro";
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Packages from '../../components/Packages2.astro';
import { Icon } from 'astro-icon/components';

const serviceData = {
  name: "Sydney Dating Photography",
  description: "Professional dating profile portraits in Sydney",
  providerName: "ROSE IS ROSE",
  areaServed: ["Sydney", "Bondi", "Manly", "Parramatta"],
  priceRange: "$$-$$$"
};

const breadcrumbs = [
  { name: "Home", item: "/" },
  { name: "Services", item: "/services" },
  { name: "Dating Photography", item: "/services/sydney-dating-photography" }
];

/**
 * PAGE CONTENT CONFIGURATION
 * 完全无删减版 - 包含所有悉尼本地化细节与专业文案
 */
const pageContent = {
  seo: {
    title: "Dating Bio Writer Sydney | Dating Profile Writer Sydney | ROSE IS ROSE",
    description: "Need a dating bio writer in Sydney? We'll help you write Hinge prompts, Tinder bios and Bumble profiles that attract the right people. Funny, smart, and totally you.",
  },
  hero: {
    badge: "DATING BIO WRITING",
    tagline: "Words That Actually Work",
    titleLine1: "BIO",
    titleLine2: "WRITING",
    desc: "Great photos get them to stop. Great words get them to swipe right. We'll help you write a bio that sounds like you—just funnier, smarter, and way more swipeable.",
    ctaText: "Write me a bio",
    image: "/assets/images/andrey-zvyagintsev-x0c6vTO5ibA-unsplash.jpg"
  },
  story: {
    bgText: "WORDS • WORDS • WORDS",
    h2Main: "SAY",
    h2Italic: "SOMETHING",
    subLabel: "WHY YOUR BIO MATTERS AS MUCH AS YOUR PHOTOS",
    dropCap: "H",
    introPara1: "ere's the thing about dating apps: your photos get them to stop scrolling. Your bio gets them to swipe right.",
    introPara2: "But writing about yourself is weird, right? It feels like you're either bragging or boring. We'll help you find the middle ground—the stuff that's actually interesting, actually you, and actually makes someone want to start a conversation.",
  },
  strategy: [
    {
      title: "DIFFERENT APPS, DIFFERENT VIBES",
      desc: "Hinge wants prompts and personality. Tinder wants short and punchy. Bumble wants... honestly it depends who you ask. We'll tailor your bio to the app—so you're not using Hinge answers on Tinder and wondering why it feels off."
    },
    {
      title: "CONVERSATION STARTERS",
      desc: "The best bios give people something to message about. A controversial opinion about pineapple on pizza. A weird hobby. A question that's actually interesting. We'll plant those hooks."
    }
  ],
  mistakes: {
    title: "BIO MISTAKES WE SEE",
    subtitle: "(and how we fix them)",
    items: [
      {
        no: "01",
        title: "The Generic List",
        content: '"I love food, travel, and good coffee." Cool, so does everyone in Sydney. We\'ll dig deeper—what kind of food? Where did you travel? What\'s your actual coffee order?'
      },
      {
        no: "02",
        title: "The Negativity",
        content: '"Not looking for hookups." "Swipe left if..." It reads as exhausting before anyone\'s even met you. We\'ll flip it to positive—say what you *do* want.'
      },
      {
        no: "03",
        title: "The Blank Space",
        content: "Nothing? Really? You're making them work so hard. Even a little something—a joke, a question, a weird fact—gives them a reason to start the conversation."
      }
    ],
    proTip: "Quick truth: Hinge prompts with specific details get way more responses. \"I'm looking for someone who...\" is forgettable. \"I'm looking for someone who will go halves on a nice bottle of wine and then argue about whether the 2019 was better than the 2021\" actually says something about you."
  },
  appDetails: [
    {
      no: "01",
      platform: "HINGE",
      title: "PROMPTS THAT ACTUALLY WORK",
      content1: "Hinge prompts are basically mini-essays. Most people either write something boring or try too hard to be funny.",
      content2: "We'll find prompts that suit your personality and answers that make someone want to respond. \"I'll fall for you if...\" becomes a real thing, not a cliché.",
      content3: "Three prompts, three chances to show who you are. Let's make them count."
    },
    {
      no: "02",
      platform: "TINDER/BUMBLE",
      title: "SHORT, SWEET, SMART",
      content1: "Less space means every word counts. We'll write bios that are:",
      bullets: [
        "Short enough to read in one glance",
        "Funny without trying too hard",
        "Specific enough to stand out"
      ]
    }
  ],
  manifesto: {
    title: "GIVE THEM SOMETHING TO WORK WITH",
    content: "Most people don't message because they don't know what to say. A good bio fixes that. It hands them an opening line on a silver platter. \"I saw you're into that thing I'm also into—tell me more.\" That's the goal."
  },
  experienceModules: [
    {
      title: "The Deep Dive",
      description: "We'll jump on a call and just... chat. What makes you laugh? What do you do when no one's watching? What's the thing your friends would say about you? We're mining for gold here—and trust me, there's always gold.",
      image: "/assets/images/andrey-zvyagintsev-x0c6vTO5ibA-unsplash.jpg",
      imageAlt: "Dating bio consultation",
      caption: "Yes, we'll make you talk about yourself. It's good for you."
    },
    {
      title: "Hinge Prompts, Solved",
      description: "The 'two truths and a lie' that everyone uses? Skip it. The 'I'm looking for someone who...' cliché? Nah. We'll find prompts and answers that actually make someone want to respond—because that's the whole point, right?",
      image: "/assets/images/stefan-stefancik-QXevDflbl8A-unsplash.jpg",
      imageAlt: "Hinge prompt writing",
      caption: "Give them something to work with."
    },
    {
      title: "The Opener Strategy",
      description: "Here's a secret: a good bio gives them an easy way to message you. We'll plant little hooks—things to ask about, jokes to reference, opinions to debate. Suddenly, 'hey' turns into actual conversations.",
      image: "/assets/images/photo/giovanna-knollseisen-CA4OaE7f500-unsplash.jpg",
      imageAlt: "Dating profile strategy",
      caption: "Make it easy for them to start the chat."
    }
  ],
  faq: {
    title: "YOU'VE GOT QUESTIONS",
    items: [
      {
        question: "Can't I just write my own bio?",
        answer: "Of course you can. But here's the thing—most people either write something boring ('I love food and travel'), something try-hard, or stare at the blank screen for an hour and give up. We'll help you find the words that actually sound like you, just... better. The version of you that's funny in group chat? That's the one we want on your profile."
      },
      {
        question: "Will it still sound like me?",
        answer: "That's literally the whole point. We're not here to make you sound like some generic 'dating coach' wrote it. We'll chat, figure out your actual personality, and write in your voice—just with better punctuation and fewer typos."
      },
      {
        question: "What if I don't know what to say about myself?",
        answer: "Perfect. That's our specialty. Most people are terrible at talking about themselves—it feels weird, right? We'll ask the right questions and pull out the stuff that matters. The hobby you're actually passionate about. The thing your friends make fun of you for. That's the good stuff."
      },
      {
        question: "Does it work for guys and girls?",
        answer: "Yep. Different apps, different audiences, different strategies. We'll tailor your bio to who you're trying to attract and which app you're using. Hinge prompts need a different vibe than Tinder bios."
      }
    ]
  },
  finalCta: {
    bgText: "WORDS • WORDS • WORDS",
    h2Main: "SAY IT",
    h2Italic: "BETTER",
    desc: "You've got the photos. Now let's give them something to say back.",
    buttonText: "Write my bio"
  }
};
---

<Layout 
  title={pageContent.seo.title}
  description={pageContent.seo.description}
  ogImage="/images/dating-photography.jpg"
  pageType="service"
  service={serviceData}
  breadcrumbs={breadcrumbs}
>
  <Header />
  
  <section class="relative h-screen min-h-[800px] flex items-center justify-center overflow-hidden bg-brand-dark">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-b from-brand-dark/95 via-brand-dark/70 to-brand-dark/95 z-10"></div>
      <img src={pageContent.hero.image} alt="Sydney Dating Bio Writing" class="w-full h-full object-cover opacity-50 animate-ken-burns" />
    </div>

    <div class="container relative z-30 mx-auto px-6 text-center reveal-on-scroll">
      <div class="inline-flex items-center gap-3 px-6 py-3 bg-brand-on-dark/5 backdrop-blur-xl rounded-full border border-brand-on-dark/10 mb-8 animate-float">
        <span class="w-2 h-2 rounded-full bg-brand-accent animate-pulse"></span>
        <span class="text-xs tracking-[0.3em] text-brand-on-dark/80 font-light uppercase">{pageContent.hero.badge}</span>
        <span class="text-brand-on-dark/40 mx-2">•</span>
        <span class="text-xs font-mono text-brand-on-dark/60">{pageContent.hero.tagline}</span>
      </div>

      <h1 class="text-5xl md:text-8xl font-serif text-brand-on-dark mb-6 leading-[0.9] tracking-tight uppercase">
        {pageContent.hero.titleLine1}<br/>
        {pageContent.hero.titleLine2}
      </h1>

      <div class="w-24 h-px mx-auto mb-8 bg-gradient-to-r from-transparent via-brand-accent to-transparent"></div>

      <p class="text-lg md:text-xl text-brand-on-dark/70 max-w-2xl mx-auto font-light leading-relaxed mb-12">
        {pageContent.hero.desc}
      </p>

      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
        <a href="/contact" class="btn-brand px-12 py-6 min-w-[200px] justify-center">
          <span class="inline-flex items-center gap-2">
            {pageContent.hero.ctaText}
            <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </span>
        </a>

      </div>
    </div>
  </section>

  <main class="bg-brand-bg">
    <section id="story" class="max-w-7xl mx-auto px-8 py-32 md:py-40 text-brand-primary relative">
      
      <div class="mb-32 relative reveal-on-scroll">
        <div class="absolute -top-20 left-0 text-[12vw] font-serif text-brand-accent/5 leading-none select-none pointer-events-none whitespace-nowrap">
          {pageContent.story.bgText}
        </div>
        <h2 class="text-6xl md:text-8xl font-serif text-brand-accent leading-[0.9] tracking-[-0.03em] uppercase relative">
          {pageContent.story.h2Main}<br />
          <span class="italic font-light text-brand-muted">{pageContent.story.h2Italic}</span>
        </h2>
        <p class="text-xs md:text-sm text-brand-muted/70 tracking-[0.3em] uppercase mt-12 pl-8 border-l border-brand-muted/30 relative">
          {pageContent.story.subLabel}
        </p>
      </div>

      <div class="mb-32 relative reveal-on-scroll pl-16">
        <div class="absolute -left-8 top-0 text-[12rem] font-serif text-brand-accent/5 leading-none">"</div>
        <div class="relative">
          <p class="text-lg md:text-2xl font-light leading-relaxed text-brand-primary/80 mb-8">
            <span class="text-8xl float-left font-serif text-brand-accent mr-6 mt-2 leading-[0.8]">{pageContent.story.dropCap}</span>
            {pageContent.story.introPara1}
          </p>
          <p class="text-lg md:text-xl font-light leading-relaxed text-brand-primary/70 pl-8 border-l-2 border-brand-accent/30 italic">
            {pageContent.story.introPara2}
          </p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-20 mb-40 reveal-on-scroll">
        {pageContent.strategy.map((item) => (
          <div class="relative group">
            <h2 class="text-3xl font-serif text-brand-accent mb-8 uppercase tracking-wide flex items-center">
              <span class="w-12 h-px bg-brand-muted mr-6 group-hover:w-20 transition-all duration-700"></span>
              {item.title}
            </h2>
            <p class="text-base font-light leading-relaxed text-brand-primary/70">{item.desc}</p>
          </div>
        ))}
      </div>

      <div class="mb-40 relative reveal-on-scroll">
        <h2 class="text-4xl md:text-5xl font-serif text-brand-accent mb-16 uppercase tracking-wide text-center">
          {pageContent.mistakes.title}<br />
          <span class="text-xl font-light text-brand-muted block mt-4 tracking-normal">{pageContent.mistakes.subtitle}</span>
        </h2>
        <div class="grid md:grid-cols-3 gap-8">
          {pageContent.mistakes.items.map((item) => (
            <div class="group relative p-10 bg-white/50 border border-brand-dark/5 hover:border-brand-accent/30 transition-all duration-700">
              <span class="absolute -top-6 left-8 text-8xl font-serif text-brand-accent/10 group-hover:text-brand-accent/20 transition-colors">{item.no}</span>
              <h3 class="text-2xl font-serif text-brand-accent mb-4 relative z-10">{item.title}</h3>
              <p class="text-sm font-light text-brand-primary/60 leading-relaxed relative z-10">{item.content}</p>
              <div class="absolute bottom-0 left-0 w-0 h-[2px] bg-brand-accent group-hover:w-full transition-all duration-700"></div>
            </div>
          ))}
        </div>
        <div class="mt-16 p-8 bg-brand-accent/5 border-l-4 border-brand-accent">
          <p class="text-sm font-mono text-brand-primary/80 leading-relaxed italic">{pageContent.mistakes.proTip}</p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-20 mb-40 reveal-on-scroll">
        {pageContent.appDetails.map((detail) => (
          <div class="relative group">
            <h2 class="text-3xl font-serif text-brand-accent mb-10 uppercase tracking-wide">
              <span class="block text-sm font-light text-brand-muted mb-3 tracking-[0.3em]">{detail.no} — {detail.platform}</span>
              {detail.title}
            </h2>
            <div class="space-y-6">
              <p class="text-base font-light leading-relaxed text-brand-primary/70">{detail.content1}</p>
              {detail.content2 && <p class="text-base font-light leading-relaxed text-brand-primary/70 italic pl-6 border-l-2 border-brand-accent/30">{detail.content2}</p>}
              {detail.content3 && <p class="text-base font-light leading-relaxed text-brand-primary/70">{detail.content3}</p>}
              {detail.bullets && (
                <ul class="space-y-4 text-base font-light">
                  {detail.bullets.map(bullet => (
                    <li class="flex items-start">
                      <span class="w-1.5 h-1.5 rounded-full bg-brand-accent mt-2 mr-4"></span>
                      <span class="text-brand-primary/70">{bullet}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        ))}
      </div>

      <div class="mb-40 relative py-24 px-8 bg-brand-dark -mx-8 text-brand-on-dark reveal-on-scroll text-center">
        <h2 class="text-4xl md:text-5xl font-serif mb-8 uppercase tracking-wide">{pageContent.manifesto.title}</h2>
        <div class="w-24 h-px bg-brand-muted/30 mx-auto mb-8"></div>
        <p class="text-lg md:text-xl font-light leading-relaxed max-w-2xl mx-auto opacity-80">{pageContent.manifesto.content}</p>
      </div>

      <div class="mb-40 reveal-on-scroll">
        <h2 class="text-3xl md:text-4xl font-serif text-brand-accent mb-16 text-center uppercase tracking-wide">HOW IT WORKS</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {pageContent.experienceModules.map((module, index) => (
            <div class="group relative bg-white/50 border border-brand-dark/5 hover:border-brand-accent/30 transition-all duration-700">
              <div class="aspect-[4/5] overflow-hidden">
                <img src={module.image} alt={module.imageAlt} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000" />
              </div>
              <div class="p-8 relative">
                <span class="absolute top-4 right-8 text-4xl font-serif text-brand-accent/10">{(index+1).toString().padStart(2, '0')}</span>
                <h3 class="text-xl font-serif text-brand-accent mb-4">{module.title}</h3>
                <p class="text-sm font-light text-brand-primary/70 leading-relaxed mb-4">{module.description}</p>
                <p class="text-xs font-mono text-brand-muted/60 italic">{module.caption}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <Packages />

      <div class="mb-40 mt-40 reveal-on-scroll">
        <h2 class="text-3xl md:text-4xl font-serif text-brand-accent mb-16 text-center uppercase tracking-wide">{pageContent.faq.title}</h2>
        <div class="max-w-3xl mx-auto space-y-6">
          {pageContent.faq.items.map((item, index) => (
            <div class="border-b border-brand-muted/10 pb-6">
              <details class="group">
                <summary class="flex justify-between items-center cursor-pointer list-none">
                  <h3 class="text-lg font-serif text-brand-accent group-hover:opacity-70 transition-opacity">
                    <span class="inline-block w-8 text-sm font-mono text-brand-muted">{(index + 1).toString().padStart(2, '0')}</span>
                    {item.question}
                  </h3>
                  <Icon name="lucide:chevron-down" class="w-5 h-5 text-brand-muted group-open:rotate-180 transition-transform" />
                </summary>
                <p class="mt-4 text-sm font-light text-brand-primary/70 leading-relaxed pl-8">{item.answer}</p>
              </details>
            </div>
          ))}
        </div>
      </div>

      <div class="text-center relative py-20 reveal-on-scroll">
        <div class="absolute inset-0 flex items-center justify-center opacity-5 select-none pointer-events-none">
          <span class="text-[12vw] font-serif text-brand-accent whitespace-nowrap">{pageContent.finalCta.bgText}</span>
        </div>
        <h2 class="text-5xl md:text-7xl font-serif text-brand-accent mb-8 uppercase tracking-tight relative">
          {pageContent.finalCta.h2Main}<br />
          <span class="italic font-light text-brand-muted">{pageContent.finalCta.h2Italic}</span>
        </h2>
        <p class="text-base font-light text-brand-primary/60 max-w-xl mx-auto mb-16 relative">{pageContent.finalCta.desc}</p>
        <a href="/booking" class="btn-brand">
          {pageContent.finalCta.buttonText}
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  function initReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
  }
  document.addEventListener('astro:page-load', initReveal);
  initReveal();
</script>