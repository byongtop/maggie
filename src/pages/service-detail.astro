---
// src/pages/service-detail.astro

import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Service Experience | Elegant Expressions">
  
  <header class="bg-brand-bg pt-32 pb-16 text-center">
    <div class="max-w-7xl mx-auto px-6">
      <span class="text-brand-muted uppercase tracking-[0.4em] text-xs font-medium">
        SERVICE EXPERIENCE
      </span>
      <h1 class="font-serif text-5xl md:text-7xl text-brand-accent mt-6 mb-8 leading-tight tracking-tighter">
        The Photography <span class="block">Journey</span>
      </h1>
      <div class="w-16 h-px bg-brand-muted mx-auto"></div>
    </div>
  </header>

  <section class="bg-brand-bg py-20">
    <div class="max-w-7xl mx-auto px-6 space-y-32">
      
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="space-y-6">
          <span class="text-brand-muted font-serif text-6xl">01</span>
          <h2 class="font-serif text-4xl text-brand-accent">Personal Positioning</h2>
          <p class="text-brand-primary/80 leading-relaxed">
            We start with a deep consultation to identify your core charm points. What makes you unique? Who are you trying to attract? We tailor the shooting style to your personality.
          </p>
        </div>
        <div class="aspect-[4/3] overflow-hidden">
          <img src="/assets/images/photo/andrey-zvyagintsev-x0c6vTO5ibA-unsplash.jpg" alt="Consultation" class="w-full h-full object-cover" />
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-16 items-center md:flex-row-reverse">
        <div class="order-2 md:order-1 aspect-[4/3] overflow-hidden">
          <img src="/assets/images/photo/aykut-aktas-GgaHHe6mow0-unsplash.jpg" alt="Photoshoot" class="w-full h-full object-cover" />
        </div>
        <div class="order-1 md:order-2 space-y-6">
          <span class="text-brand-muted font-serif text-6xl">02</span>
          <h2 class="font-serif text-4xl text-brand-accent">On-Location Shoot</h2>
          <p class="text-brand-primary/80 leading-relaxed">
            Natural scenes in cafés, urban streets, or parks. We don't just take pictures; we capture moments of connection and lifestyle.
          </p>
        </div>
      </div>

    </div>
  </section>

</Layout>