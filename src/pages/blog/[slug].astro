---
// src/pages/blog/[slug].astro
// Blog Post Page - ROSE IS ROSE
// Image-optional: contentBlocks render as single-column prose when no image is provided

import '../../styles/global.css'; 

import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from "../../layouts/Layout.astro";
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Icon } from 'astro-icon/components';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const { data } = entry;

const pageData = {
  ui: {
    backToBlog: "Back to blog",
    shareTitle: "Share",
    readingTimeSuffix: "min read"
  },
  categoryStyles: {
    'Photography Tips & Guides': 'border-brand-accent/30 text-brand-accent',
    'Success Stories':           'border-brand-dark/30 text-brand-dark',
    'Dating Insights':           'border-brand-dark/30 text-brand-dark',
    'Behind the Scenes':         'border-brand-accent/30 text-brand-accent'
  }
};

// ✅ AU date format
const formattedDate = new Date(data.pubDate).toLocaleDateString('en-AU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// ✅ Reading time estimate — based on word count across all blocks
const allText = (data.contentBlocks ?? []).map(b => b.text).join(' ');
const wordCount = allText.replace(/<[^>]+>/g, '').split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.round(wordCount / 200));

const breadcrumbs = [
  { name: "Home",  item: "/" },
  { name: "Blog",  item: "/blog/" },
  { name: data.title, item: `/blog/${entry.slug}/` },
];

// ✅ SEO: use seoTitle/seoDescription if provided, fall back to title/description
const metaTitle       = data.seoTitle       ?? `${data.title} | ROSE IS ROSE`;
const metaDescription = data.seoDescription ?? data.description;
---

<Layout
  title={metaTitle}
  description={metaDescription}
  ogImage={data.image ?? '/images/og-default.jpg'}
  pageType="blog"
  blogPost={data}
  breadcrumbs={breadcrumbs}
  schemas={[
    {
      "@type": "BlogPosting",
      "headline": data.title,
      "description": data.description,
      "datePublished": data.pubDate,
      "author": {
        "@type": "Person",
        "name": "Maggie",
        "worksFor": { "@type": "Organization", "name": "ROSE IS ROSE" }
      },
      "publisher": {
        "@type": "Organization",
        "name": "ROSE IS ROSE",
        "url": "https://roseisrose.com.au"
      },
      ...(data.image ? { "image": `https://roseisrose.com.au${data.image}` } : {})
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbs.map((crumb, index) => ({
        "@type": "ListItem",
        "position": index + 1,
        "name": crumb.name,
        "item": `https://roseisrose.com.au${crumb.item}`
      }))
    }
  ]}
>
  <Header />

  {/* ── Hero ─────────────────────────────────────────────── */}
  <section class="relative min-h-[60vh] flex items-end pt-32 pb-20 bg-brand-dark text-brand-on-dark overflow-hidden">

    {/* Optional hero image — only renders if data.image exists */}
    {data.image && (
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-b from-brand-dark/70 via-brand-dark/60 to-brand-dark z-10"></div>
        <img
          src={data.image}
          alt={data.title}
          class="w-full h-full object-cover opacity-40"
        />
      </div>
    )}

    {/* No hero image — subtle texture only */}
    {!data.image && (
      <div class="absolute inset-0 z-0 opacity-[0.03] bg-[url('/assets/images/grid-pattern.svg')] bg-repeat"></div>
    )}

    <div class="max-w-4xl mx-auto px-6 md:px-12 relative z-10 w-full reveal-on-scroll">

      {/* Category + date */}
      <div class="flex flex-wrap items-center gap-6 mb-8">
        <span class={`text-[10px] tracking-[0.3em] uppercase px-5 py-2 border backdrop-blur-sm ${pageData.categoryStyles[data.category] ?? 'border-brand-on-dark/20 text-brand-on-dark/60'}`}>
          {data.category}
        </span>
        <div class="w-8 h-px bg-brand-accent/40"></div>
        <span class="text-[11px] tracking-widest text-brand-on-dark/50 uppercase">{formattedDate}</span>
        <div class="w-8 h-px bg-brand-accent/40"></div>
        <span class="text-[11px] tracking-widest text-brand-on-dark/50 uppercase">{readingTime} {pageData.ui.readingTimeSuffix}</span>
      </div>

      {/* Title */}
      <h1 class="text-4xl md:text-6xl font-serif mb-8 leading-[1.1] tracking-tight max-w-3xl">
        {data.title}
      </h1>

      {/* Description */}
      <p class="text-lg md:text-xl text-brand-on-dark/70 max-w-2xl font-light leading-relaxed italic border-l-2 border-brand-accent/40 pl-8">
        {data.description}
      </p>

      {/* Tags */}
      {data.tags && data.tags.length > 0 && (
        <div class="flex flex-wrap gap-3 mt-8">
          {data.tags.map(tag => (
            <span class="text-[9px] tracking-[0.25em] uppercase text-brand-on-dark/40 px-3 py-1 border border-brand-on-dark/10">
              {tag}
            </span>
          ))}
        </div>
      )}

    </div>
  </section>

  {/* ── Article body ─────────────────────────────────────── */}
  <main class="bg-brand-bg text-brand-primary">
    <section class="max-w-4xl mx-auto px-6 py-20 md:py-32">

      <article>
        {data.contentBlocks && data.contentBlocks.length > 0 ? (

          <div class="space-y-24">
            {data.contentBlocks.map((block, index) => (

              // ✅ IMAGE PRESENT: two-column layout — text left/right, image on the other side
              block.image ? (
                <div
                  class={`grid md:grid-cols-2 gap-12 md:gap-16 items-center reveal-on-scroll ${
                    block.layout === 'right'
                      ? 'md:[&>div.img-col]:order-last'
                      : ''
                  }`}
                  style={`transition-delay: ${(index % 3) * 80}ms`}
                >
                  {/* Text column */}
                  <div class="rich-content text-base md:text-lg font-light leading-relaxed space-y-5 text-brand-primary/85" set:html={block.text} />

                  {/* Image column */}
                  <div class="img-col relative group">
                    <div class="aspect-[4/5] overflow-hidden border border-brand-dark/5 shadow-sm">
                      <img
                        src={block.image}
                        alt={block.imageAlt ?? ''}
                        class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-1000"
                        loading="lazy"
                      />
                    </div>
                    {/* Corner accent */}
                    <div class={`absolute -z-10 w-16 h-16 border border-brand-accent/20 ${
                      block.layout === 'right' ? '-bottom-3 -left-3' : '-bottom-3 -right-3'
                    }`}></div>
                  </div>
                </div>

              ) : block.layout === 'full' ? (

                // ✅ FULL WIDTH: no image, centred prose column — wider max-width
                <div class="max-w-2xl mx-auto reveal-on-scroll" style={`transition-delay: ${(index % 3) * 80}ms`}>
                  <div class="rich-content text-base md:text-lg font-light leading-relaxed space-y-5 text-brand-primary/85" set:html={block.text} />
                </div>

              ) : (

                // ✅ NO IMAGE: single prose column — same width as full, left-aligned
                <div class="reveal-on-scroll" style={`transition-delay: ${(index % 3) * 80}ms`}>
                  <div class="rich-content text-base md:text-lg font-light leading-relaxed space-y-5 text-brand-primary/85 max-w-2xl" set:html={block.text} />
                </div>

              )
            ))}
          </div>

        ) : (
          // ✅ FALLBACK: no contentBlocks at all — plain slot content
          <div class="rich-content font-light text-lg leading-loose max-w-2xl opacity-85">
            <slot />
          </div>
        )}
      </article>

      {/* ── Article footer ───────────────────────────────── */}
      <div class="mt-32 pt-12 border-t border-brand-muted/10 reveal-on-scroll">
        <div class="flex flex-col md:flex-row justify-between items-center gap-10">

          {/* Back to blog */}
          <a
            href="/blog/"
            class="group flex items-center gap-5 text-brand-primary/50 hover:text-brand-primary transition-colors"
          >
            <div class="w-10 h-10 rounded-full border border-brand-dark/10 flex items-center justify-center group-hover:bg-brand-dark group-hover:text-brand-on-dark group-hover:border-brand-dark transition-all">
              <Icon name="lucide:arrow-left" class="w-4 h-4" />
            </div>
            <span class="text-[10px] tracking-[0.4em] uppercase font-medium">
              {pageData.ui.backToBlog}
            </span>
          </a>

          {/* Share */}
          <div class="flex items-center gap-6">
            <span class="text-[9px] tracking-[0.25em] uppercase text-brand-accent font-medium">
              {pageData.ui.shareTitle}
            </span>
            <div class="flex gap-3">
              {['twitter', 'linkedin', 'facebook'].map(platform => (
                <a
                  href="#"
                  aria-label={`Share on ${platform}`}
                  class="w-9 h-9 rounded-full border border-brand-dark/10 hover:border-brand-dark flex items-center justify-center transition-all group/icon"
                >
                  <Icon name={`lucide:${platform}`} class="w-3.5 h-3.5 text-brand-primary/50 group-hover/icon:text-brand-primary" />
                </a>
              ))}
            </div>
          </div>

        </div>
      </div>

    </section>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* Rich text content typography */
  .rich-content p {
    margin-bottom: 1.4rem;
  }
  .rich-content p:last-child {
    margin-bottom: 0;
  }
  .rich-content strong {
    color: var(--color-brand-dark, #34041A);
    font-weight: 500;
  }
  .rich-content em {
    font-style: italic;
    opacity: 0.8;
  }
  .rich-content a {
    border-bottom: 1px solid currentColor;
    opacity: 0.75;
    transition: opacity 0.2s;
  }
  .rich-content a:hover {
    opacity: 1;
  }
  .rich-content blockquote {
    font-family: serif;
    font-style: italic;
    font-size: 1.35rem;
    line-height: 1.6;
    color: var(--color-brand-accent, #8C7355);
    padding-left: 1.5rem;
    border-left: 2px solid var(--color-brand-dark, #34041A);
    margin: 2.5rem 0;
  }
  .rich-content ul {
    list-style: none;
    space-y: 0.75rem;
    margin: 1.5rem 0;
  }
  .rich-content ul li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .rich-content ul li::before {
    content: '';
    display: inline-block;
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 50%;
    background-color: var(--color-brand-accent, #8C7355);
    margin-top: 0.55rem;
    flex-shrink: 0;
  }
  .rich-content h2,
  .rich-content h3 {
    font-family: serif;
    color: var(--color-brand-dark, #34041A);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  .rich-content h2 { font-size: 1.5rem; }
  .rich-content h3 { font-size: 1.2rem; }

  /* Scroll reveal */
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .reveal-on-scroll.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function initReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('active');
      });
    }, { threshold: 0.08 });
    document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
  }
  document.addEventListener('astro:page-load', initReveal);
  initReveal();
</script>
