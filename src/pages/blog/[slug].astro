---
// src/pages/blog/[slug].astro
// Blog Post Page - Individual Narrative Article - ROSE IS ROSE

import '../../styles/global.css'; 

import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from "../../layouts/Layout.astro";
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Icon } from 'astro-icon/components';

/**
 * 动态路由生成 - 基于内容集合
 */
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const { data } = entry;

// ==========================================
// 页面静态文案与配置 (Static UI Data)
// ==========================================
const pageData = {
  ui: {
    backToBlog: "Back to Stories",
    shareTitle: "Share this narrative",
    readingTimeSuffix: "min read"
  },
  // 分类样式映射
  categoryStyles: {
    'Photography Tips & Guides': 'border-[#8C7355]/30 text-[#8C7355]',
    'Success Stories': 'border-[#34041A]/30 text-[#34041A]',
    'Dating Insights': 'border-[#34041A]/30 text-[#34041A]',
    'Behind the Scenes': 'border-[#8C7355]/30 text-[#8C7355]'
  }
};

// 格式化日期 (AU Standard)
const formattedDate = new Date(data.pubDate).toLocaleDateString('en-AU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<Layout 
  title={`${data.title} | ROSE IS ROSE Blog`}
  description={data.description}
>
  <Header />

  <section class="relative min-h-[70vh] flex items-center pt-32 pb-20 bg-[#34041A] text-[#F9F2E7] overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 opacity-[0.03] bg-[url('/assets/images/grid-pattern.svg')] bg-repeat"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#34041A]/50 to-[#34041A]"></div>
    </div>
    
    <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10 w-full reveal-on-scroll">
      <div class="max-w-4xl">
        <div class="flex flex-wrap items-center gap-6 mb-8">
          <span class={`text-[10px] tracking-[0.3em] uppercase px-5 py-2 border ${pageData.categoryStyles[data.category] || 'border-[#F9F2E7]/20'} backdrop-blur-sm`}>
            {data.category}
          </span>
          <div class="w-8 h-px bg-[#8C7355]/40"></div>
          <span class="text-[11px] tracking-widest text-[#F9F2E7]/50 uppercase">{formattedDate}</span>
        </div>
        
        <h1 class="text-5xl md:text-8xl font-serif mb-10 leading-[1.05] tracking-tight">
          {data.title}
        </h1>
        
        <p class="text-xl md:text-2xl text-[#F9F2E7]/80 max-w-2xl font-light leading-relaxed italic border-l-2 border-[#8C7355]/40 pl-8">
          {data.description}
        </p>
      </div>
    </div>
  </section>

  <main class="bg-[#F9F2E7] text-[#3C3835]">
    <section class="max-w-7xl mx-auto px-6 py-20 md:py-32">
      
      {data.image && (
        <div class="mb-32 max-w-5xl mx-auto reveal-on-scroll">
          <div class="aspect-[16/9] overflow-hidden shadow-[0_20px_50px_rgba(52,4,26,0.15)] rounded-sm">
            <img 
              src={data.image} 
              alt={data.title}
              class="w-full h-full object-cover grayscale-[10%] hover:grayscale-0 transition-all duration-1000"
            />
          </div>
          <div class="mt-6 flex justify-between items-center px-2">
            <p class="text-[9px] tracking-[0.2em] text-[#8C7355] uppercase">Caption: {data.title}</p>
            <div class="flex gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-[#34041A]"></span>
              <span class="w-1.5 h-1.5 rounded-full bg-[#8C7355]/30"></span>
              <span class="w-1.5 h-1.5 rounded-full bg-[#8C7355]/30"></span>
            </div>
          </div>
        </div>
      )}

      <article class="max-w-4xl mx-auto">
        {data.contentBlocks && data.contentBlocks.length > 0 ? (
          <div class="space-y-32">
            {data.contentBlocks.map((block, index) => (
              <div 
                class={`grid md:grid-cols-2 gap-16 items-center reveal-on-scroll ${
                  block.layout === 'right' ? '' : 'md:[&>div:first-child]:order-last'
                } ${block.layout === 'full' ? 'block' : ''}`}
                style={`transition-delay: ${index % 2 * 100}ms`}
              >
                
                <div class={`prose-container ${block.layout === 'full' ? 'max-w-3xl mx-auto mb-16' : ''}`}>
                  <div class="rich-content text-lg font-light leading-relaxed space-y-6 text-[#3C3835]/90" set:html={block.text} />
                </div>

                {block.image && block.layout !== 'full' && (
                  <div class="relative group">
                    <div class="aspect-[4/5] overflow-hidden border border-[#34041A]/5 shadow-sm">
                      <img 
                        src={block.image} 
                        alt={block.imageAlt || 'Story fragment'}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000"
                      />
                    </div>
                    <div class={`absolute -z-10 w-24 h-24 border border-[#8C7355]/20 ${
                      block.layout === 'right' ? '-top-4 -right-4' : '-bottom-4 -left-4'
                    }`}></div>
                  </div>
                )}

                {block.image && block.layout === 'full' && (
                  <div class="md:col-span-2 my-12 reveal-on-scroll">
                    <div class="aspect-[21/9] overflow-hidden rounded-sm">
                      <img 
                        src={block.image} 
                        alt={block.imageAlt} 
                        class="w-full h-full object-cover grayscale-[20%] hover:grayscale-0 transition-all duration-700" 
                      />
                    </div>
                  </div>
                )}
              </div>
            ))}
          </div>
        ) : (
          /* Fallback for simple content without blocks */
          <div class="rich-content font-light text-xl leading-loose max-w-3xl mx-auto opacity-80">
            <slot />
          </div>
        )}
      </article>

      <div class="max-w-4xl mx-auto mt-40 pt-16 border-t border-[#34041A]/10 reveal-on-scroll">
        <div class="flex flex-col md:flex-row justify-between items-center gap-12">
          <a href="/blog" class="group flex items-center gap-6 text-[#34041A]/60 hover:text-[#34041A] transition-colors">
            <div class="w-12 h-12 rounded-full border border-[#34041A]/10 flex items-center justify-center group-hover:bg-[#34041A] group-hover:text-white transition-all">
              <Icon name="lucide:arrow-left" class="w-4 h-4" />
            </div>
            <span class="text-[10px] tracking-[0.4em] uppercase font-medium">{pageData.ui.backToBlog}</span>
          </a>
          
          <div class="flex items-center gap-8">
            <span class="text-[9px] tracking-[0.2em] uppercase text-[#8C7355] font-semibold">{pageData.ui.shareTitle}</span>
            <div class="flex gap-4">
              {['twitter', 'linkedin', 'facebook'].map(platform => (
                <button class="w-10 h-10 rounded-full border border-[#34041A]/10 hover:border-[#34041A] flex items-center justify-center transition-all group/icon">
                  <Icon name={`lucide:${platform}`} class="w-4 h-4 text-[#34041A]/60 group-hover/icon:text-[#34041A]" />
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>

    </section>
  </section>

  <Footer />
</Layout>

<style is:global>
  /* 针对富文本内容的细微排版控制 */
  .rich-content p {
    margin-bottom: 1.5rem;
  }
  .rich-content strong {
    color: #34041A;
    font-weight: 500;
  }
  .rich-content blockquote {
    font-family: serif;
    font-style: italic;
    font-size: 1.5rem;
    color: #8C7355;
    padding-left: 2rem;
    border-left: 2px solid #34041A;
    margin: 3rem 0;
  }
</style>

<script>
  // 滚动动画脚本
  function initReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
  }
  
  document.addEventListener('astro:page-load', initReveal);
  initReveal();
</script>