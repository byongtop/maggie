---
// src/pages/blog/category/index.astro
// 显示所有分类的概览页面

import '../../../styles/global.css';
import { getCollection } from 'astro:content';
import Layout from "../../../layouts/Layout.astro";
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { Icon } from 'astro-icon/components';

// 分类配置
const categoryConfig: Record<string, {
  displayName: string;
  description: string;
  color: string;
  icon?: string;
  slug: string;
}> = {
  'Photography Tips & Guides': {
    displayName: 'Photography Tips & Guides',
    description: 'Expert advice on lighting, posing, and getting the perfect shot for your dating profile.',
    color: 'bg-blue-50 text-blue-700 border-blue-200',
    slug: 'photography-tips-guides'
  },
  'Success Stories': {
    displayName: 'Success Stories',
    description: 'Real stories from real clients who found love (or at least great dates) after their session.',
    color: 'bg-green-50 text-green-700 border-green-200',
    slug: 'success-stories'
  },
  'Dating Insights': {
    displayName: 'Dating Insights',
    description: 'Thoughts on modern dating in Sydney—the apps, the spots, the whole scene.',
    color: 'bg-purple-50 text-purple-700 border-purple-200',
    slug: 'dating-insights'
  },
  'Behind the Scenes': {
    displayName: 'Behind the Scenes',
    description: 'A peek behind the lens—what happens on shoot day, how we work, and why we love it.',
    color: 'bg-amber-50 text-amber-700 border-amber-200',
    slug: 'behind-the-scenes'
  }
};

// 获取每类文章的数量
const allPosts = await getCollection('blog');
const categoryCounts: Record<string, number> = {};

allPosts.forEach(post => {
  const category = post.data.category;
  categoryCounts[category] = (categoryCounts[category] || 0) + 1;
});
---

<Layout 
  title="Blog Categories | ROSE IS ROSE"
  description="Browse our blog posts by category - Photography Tips, Success Stories, Dating Insights, and Behind the Scenes"
>
  <Header />

  {/* 页面标题区 */}
  <section class="relative pt-40 pb-20 md:pt-48 md:pb-24 bg-brand-dark text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[url('/assets/images/grid-pattern.svg')] bg-repeat"></div>
    </div>
    
    <div class="absolute inset-0 bg-gradient-to-b from-brand-dark via-brand-dark/95 to-brand-dark"></div>
    
    <div class="container relative z-10 mx-auto px-6 max-w-4xl text-center">
      <div class="flex justify-center mb-6">
        <span class="text-xs tracking-[0.2em] uppercase px-4 py-2 rounded-full border bg-white/10 text-white border-white/20">
          EXPLORE
        </span>
      </div>
      
      <h1 class="text-5xl md:text-7xl font-serif mb-6">Categories</h1>
      <div class="w-24 h-px bg-brand-accent mx-auto mb-6"></div>
      <p class="text-lg text-white/70 max-w-2xl mx-auto font-light">
        Browse our blog posts by topic—find the content that matters most to you
      </p>
    </div>
  </section>

  {/* 分类列表 */}
  <main class="bg-brand-bg">
    <section class="max-w-7xl mx-auto px-6 py-20 md:py-24">
      
      <div class="flex justify-center mb-16">
        <a 
          href="/blog"
          class="text-xs tracking-[0.2em] uppercase text-brand-muted hover:text-brand-accent transition-colors flex items-center gap-2"
        >
          <Icon name="lucide:arrow-left" class="w-3 h-3" />
          Back to All Posts
        </a>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {Object.entries(categoryConfig).map(([categoryName, config]) => {
          const postCount = categoryCounts[categoryName] || 0;
          
          return (
            <a 
              href={`/blog/category/${config.slug}`}
              class="group block bg-white rounded-2xl border border-brand-muted/10 hover:border-brand-accent/20 transition-all duration-500 hover:shadow-xl hover:-translate-y-1 overflow-hidden"
            >
              <div class="p-8">
                {/* 分类标签 */}
                <div class="flex items-center justify-between mb-6">
                  <span class={`text-xs tracking-[0.2em] uppercase px-4 py-2 rounded-full border ${config.color}`}>
                    {config.displayName}
                  </span>
                  <span class="text-sm text-brand-muted/60 font-mono">
                    {postCount} {postCount === 1 ? 'post' : 'posts'}
                  </span>
                </div>

                {/* 分类描述 */}
                <p class="text-brand-primary/70 font-light leading-relaxed mb-6">
                  {config.description}
                </p>

                {/* 浏览链接 */}
                <div class="flex items-center justify-between">
                  <span class="text-xs tracking-[0.2em] uppercase text-brand-muted group-hover:text-brand-accent transition-colors">
                    Browse Category
                  </span>
                  <div class="w-8 h-8 rounded-full bg-brand-accent/5 group-hover:bg-brand-accent flex items-center justify-center transition-colors">
                    <Icon name="lucide:arrow-right" class="w-4 h-4 text-brand-accent group-hover:text-white transition-colors" />
                  </div>
                </div>
              </div>

              {/* 装饰性元素 */}
              <div class="h-1 w-0 group-hover:w-full bg-brand-accent transition-all duration-700"></div>
            </a>
          );
        })}
      </div>

      {/* 如果没有文章 */}
      {Object.keys(categoryConfig).length === 0 && (
        <div class="text-center py-20">
          <p class="text-brand-muted/60">No categories found.</p>
        </div>
      )}

      {/* 返回博客首页 */}
      <div class="text-center mt-20">
        <a 
          href="/blog"
          class="inline-flex items-center gap-3 text-sm tracking-[0.2em] uppercase text-brand-muted hover:text-brand-accent transition-colors group"
        >
          <span>View All Posts</span>
          <Icon name="lucide:arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;600&display=swap');
  
  @font-face {
    font-family: 'Kudryashev';
    src: local('Georgia'), local('Times New Roman'), serif;
    font-display: swap;
  }

  :root {
    --brand-dark: #0A0A0A;
    --brand-primary: #1A1A1A;
    --brand-accent: #34041A;
    --brand-muted: #6B4E5E;
    --brand-bg: #FDFAF7;
  }

  body {
    font-family: 'Inter', sans-serif;
    background-color: var(--brand-bg);
    color: var(--brand-primary);
  }

  ::-webkit-scrollbar {
    width: 8px;
  }

  ::-webkit-scrollbar-track {
    background: var(--brand-bg);
  }

  ::-webkit-scrollbar-thumb {
    background: var(--brand-muted);
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: var(--brand-accent);
  }

  ::selection {
    background: rgba(52, 4, 26, 0.15);
    color: var(--brand-accent);
  }

  html {
    scroll-behavior: smooth;
  }
</style>