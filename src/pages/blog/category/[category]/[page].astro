---
// src/pages/blog/category/[category]/[page].astro
import '../../../../styles/global.css'; 

import { getCollection } from 'astro:content';
import Layout from "../../../../layouts/Layout.astro";
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import { Icon } from 'astro-icon/components';


// 分类显示名称映射
const categoryDisplayNames: Record<string, string> = {
  'Photography Tips & Guides': 'Photography Tips & Guides',
  'Success Stories': 'Success Stories',
  'Dating Insights': 'Dating Insights',
  'Behind the Scenes': 'Behind the Scenes'
};

// 分类描述（用于SEO）
const categoryDescriptions: Record<string, string> = {
  'Photography Tips & Guides': 'Expert advice on lighting, posing, and getting the perfect shot for your dating profile.',
  'Success Stories': 'Real stories from real clients who found love (or at least great dates) after their session.',
  'Dating Insights': 'Thoughts on modern dating in Sydney—the apps, the spots, the whole scene.',
  'Behind the Scenes': 'A peek behind the lens—what happens on shoot day, how we work, and why we love it.'
};

// 分类颜色映射
const categoryColors: Record<string, string> = {
  'Photography Tips & Guides': 'bg-blue-50 text-blue-700 border-blue-200',
  'Success Stories': 'bg-green-50 text-green-700 border-green-200',
  'Dating Insights': 'bg-purple-50 text-purple-700 border-purple-200',
  'Behind the Scenes': 'bg-amber-50 text-amber-700 border-amber-200'
};

export async function getStaticPaths() {
  const POSTS_PER_PAGE = 9;

  // ✅ 将 slug 映射定义在函数内部
  const categorySlugs: Record<string, string> = {
    'Photography Tips & Guides': 'photography-tips-guides',
    'Success Stories': 'success-stories',
    'Dating Insights': 'dating-insights',
    'Behind the Scenes': 'behind-the-scenes'
  };

  // 反向映射，用于从 slug 获取原始分类名
  const slugsToCategory: Record<string, string> = {
    'photography-tips-guides': 'Photography Tips & Guides',
    'success-stories': 'Success Stories',
    'dating-insights': 'Dating Insights',
    'behind-the-scenes': 'Behind the Scenes'
  };
  
  const allPosts = await getCollection('blog');
  
  const paths = [];
  
  // 遍历所有分类
  for (const [categoryName, slug] of Object.entries(categorySlugs)) {
    // 过滤出该分类的文章
    const categoryPosts = allPosts
      .filter(post => post.data.category === categoryName)
      .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
    
    // 计算总页数
    const totalPages = Math.ceil(categoryPosts.length / POSTS_PER_PAGE);
    
    // 为每一页生成路径
    for (let i = 1; i <= totalPages; i++) {
      paths.push({
        params: { 
          category: slug,
          page: i.toString() 
        },
        props: {
          category: categoryName,
          page: i,
          totalPages,
          posts: categoryPosts.slice((i - 1) * POSTS_PER_PAGE, i * POSTS_PER_PAGE)
        }
      });
    }
  }
  
  return paths;
}

interface Props {
  category: string;
  page: number;
  totalPages: number;
  posts: any[];
}

const { category, page, totalPages, posts } = Astro.props;

---

<Layout 
  title={`${categoryDisplayNames[category] || category} - Page ${page} | ROSE IS ROSE Blog`}
  description={categoryDescriptions[category] || 'Blog posts for ' + category}
>
  <Header />

  <section class="relative pt-40 pb-20 md:pt-48 md:pb-24 bg-brand-dark text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-[url('/assets/images/grid-pattern.svg')] bg-repeat"></div>
    </div>
    
    <div class="absolute inset-0 bg-gradient-to-b from-brand-dark via-brand-dark/95 to-brand-dark"></div>
    
    <div class="container relative z-10 mx-auto px-6 max-w-4xl text-center">
      <div class="flex justify-center mb-6">
        <span class={`text-xs tracking-[0.2em] uppercase px-4 py-2 rounded-full border ${categoryColors[category] || 'bg-gray-50 text-gray-700'}`}>
          {categoryDisplayNames[category] || category}
        </span>
      </div>
      
      <h1 class="text-5xl md:text-7xl font-serif mb-6">{categoryDisplayNames[category] || category}</h1>
      <div class="w-24 h-px bg-brand-accent mx-auto mb-6"></div>
      <p class="text-lg text-white/70 max-w-2xl mx-auto font-light">
        {categoryDescriptions[category] || ''}
      </p>
    </div>
  </section>

  <main class="bg-brand-bg">
    <section class="max-w-7xl mx-auto px-6 py-20 md:py-24">
      
      <div class="flex justify-center mb-16">
        <a 
          href="/blog"
          class="text-xs tracking-[0.2em] uppercase text-brand-muted hover:text-brand-accent transition-colors flex items-center gap-2"
        >
          <Icon name="lucide:arrow-left" class="w-3 h-3" />
          Back to All Posts
        </a>
      </div>
      
      {posts.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 gap-y-12">
          {posts.map((post) => (
            <a 
              href={`/blog/${post.slug}`}
              class="group block"
            >
              <article class="h-full flex flex-col">
                <div class="aspect-[4/3] overflow-hidden bg-brand-dark/5 mb-5">
                  {post.data.image ? (
                    <img 
                      src={post.data.image} 
                      alt={post.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center bg-brand-accent/5">
                      <span class="text-brand-muted/30 font-serif text-6xl">R</span>
                    </div>
                  )}
                </div>
                
                <div class="flex items-center gap-3 mb-3">
                  <span class={`text-[10px] tracking-[0.2em] uppercase px-3 py-1 rounded-full border ${categoryColors[post.data.category] || 'bg-gray-50 text-gray-700'}`}>
                    {post.data.category}
                  </span>
                  <span class="text-xs text-brand-muted/60">
                    {new Date(post.data.pubDate).toLocaleDateString('en-AU', {
                      month: 'short',
                      day: 'numeric',
                      year: 'numeric'
                    })}
                  </span>
                </div>
                
                <h2 class="text-xl font-serif text-brand-accent mb-3 group-hover:underline decoration-1 underline-offset-4 transition-all">
                  {post.data.title}
                </h2>
                
                <p class="text-sm text-brand-primary/60 font-light leading-relaxed line-clamp-3">
                  {post.data.description}
                </p>
                
                <div class="mt-4 flex items-center gap-2 text-[10px] tracking-[0.2em] uppercase text-brand-muted group-hover:text-brand-accent transition-colors">
                  <span>Read More</span>
                  <Icon name="lucide:arrow-right" class="w-3 h-3" />
                </div>
              </article>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <p class="text-brand-muted/60">No posts in this category yet. Check back soon!</p>
        </div>
      )}

      {totalPages > 1 && (
        <div class="mt-20 flex justify-center items-center gap-2">
          {page > 1 ? (
            <a 
              href={`/blog/category/${category.toLowerCase().replace(/\s+/g, '-')}/${page - 1 === 1 ? '' : page - 1}`}
              class="w-10 h-10 rounded-full border border-brand-muted/20 hover:border-brand-accent flex items-center justify-center text-brand-primary/60 hover:text-brand-accent transition-colors"
            >
              <Icon name="lucide:chevron-left" class="w-4 h-4" />
            </a>
          ) : (
            <span class="w-10 h-10 rounded-full border border-brand-muted/10 flex items-center justify-center text-brand-muted/30 cursor-not-allowed">
              <Icon name="lucide:chevron-left" class="w-4 h-4" />
            </span>
          )}

          <div class="flex items-center gap-1">
            {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
              p === page ? (
                <span 
                  key={p}
                  class="w-10 h-10 rounded-full bg-brand-accent text-white flex items-center justify-center text-sm font-mono"
                >
                  {p}
                </span>
              ) : (
                <a 
                  key={p}
                  href={`/blog/category/${category.toLowerCase().replace(/\s+/g, '-')}/${p === 1 ? '' : p}`}
                  class="w-10 h-10 rounded-full border border-brand-muted/20 hover:border-brand-accent flex items-center justify-center text-brand-primary/60 hover:text-brand-accent transition-colors text-sm font-mono"
                >
                  {p}
                </a>
              )
            ))}
          </div>

          {page < totalPages ? (
            <a 
              href={`/blog/category/${category.toLowerCase().replace(/\s+/g, '-')}/${page + 1}`}
              class="w-10 h-10 rounded-full border border-brand-muted/20 hover:border-brand-accent flex items-center justify-center text-brand-primary/60 hover:text-brand-accent transition-colors"
            >
              <Icon name="lucide:chevron-right" class="w-4 h-4" />
            </a>
          ) : (
            <span class="w-10 h-10 rounded-full border border-brand-muted/10 flex items-center justify-center text-brand-muted/30 cursor-not-allowed">
              <Icon name="lucide:chevron-right" class="w-4 h-4" />
            </span>
          )}
        </div>
      )}
    </section>
  </main>

  <Footer />
</Layout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;600&display=swap');
  
  @font-face {
    font-family: 'Kudryashev';
    src: local('Georgia'), local('Times New Roman'), serif;
    font-display: swap;
  }

  :root {
    --brand-dark: #0A0A0A;
    --brand-primary: #1A1A1A;
    --brand-accent: #34041A;
    --brand-muted: #6B4E5E;
    --brand-bg: #FDFAF7;
  }

  body {
    font-family: 'Inter', sans-serif;
    background-color: var(--brand-bg);
    color: var(--brand-primary);
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  ::-webkit-scrollbar {
    width: 8px;
  }

  ::-webkit-scrollbar-track {
    background: var(--brand-bg);
  }

  ::-webkit-scrollbar-thumb {
    background: var(--brand-muted);
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: var(--brand-accent);
  }

  ::selection {
    background: rgba(52, 4, 26, 0.15);
    color: var(--brand-accent);
  }

  html {
    scroll-behavior: smooth;
  }
</style>