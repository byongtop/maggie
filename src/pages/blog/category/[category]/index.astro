---
// src/pages/blog/category/[category]/index.astro
// 重定向到第一页

export async function getStaticPaths() {
  // 从博客文章中提取所有分类
  // 方法1：如果你使用内容集合 (Content Collections)
  const blogCollection = await Astro.glob('../../../../content/blog/*.md');
  // 或者如果使用 getCollection: const posts = await getCollection('blog');
  
  // 提取所有唯一的分类
  const categories = [...new Set(blogCollection.map(post => {
    // 根据你的 frontmatter 结构调整
    return post.frontmatter?.category || post.category || 'uncategorized';
  }))];
  
  // 为每个分类生成路径
  return categories.map(category => ({
    params: { category }
  }));
  
  // 如果你还没有博客数据，也可以先硬编码一些分类用于测试
  // return [
  //   { params: { category: 'technology' } },
  //   { params: { category: 'design' } },
  //   { params: { category: 'news' } }
  // ];
}

const { category } = Astro.params;
const url = `/blog/category/${category}/1`;
---

<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="refresh" content={`0; url=${url}`} />
  </head>
  <body>
    <p>Redirecting to <a href={url}>page 1</a>...</p>
  </body>
</html>