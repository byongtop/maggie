---
// src/pages/blog/category/[category]/index.astro

export async function getStaticPaths() {
  // ✅ 将映射定义在函数内部
  const categoryToSlug: Record<string, string> = {
    'Photography Tips & Guides': 'photography-tips-guides',
    'Success Stories': 'success-stories',
    'Dating Insights': 'dating-insights',
    'Behind the Scenes': 'behind-the-scenes'
  };

  // 只返回实际存在的 slug
  return Object.values(categoryToSlug).map(slug => ({
    params: { category: slug }
  }));
}

const { category } = Astro.params;
// 直接使用 slug 构建 URL
const url = `/blog/category/${category}/1`;
---

<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="refresh" content={`0; url=${url}`} />
  </head>
  <body>
    <p>Redirecting to <a href={url}>page 1</a>...</p>
  </body>
</html>