---
// src/pages/philosophy.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Process from '../components/Process.astro';
import ContactCTA2 from '../components/ContactCTA2.astro';
import { Image } from 'astro:assets';
import philImg from '../assets/images/hero/06.jpg'; 
import '../styles/global.css';

// 关于页面的数据
const aboutData = {
  name: "Rose",
  title: "Portrait Photographer",
  experience: "8+ years",
  location: "Sydney",
  specialties: ["Dating Portraits", "Professional Headshots", "Personal Branding"],
  socialLinks: {
    instagram: "https://instagram.com/roseisrose",
    pinterest: "https://pinterest.com/roseisrose",
    linkedin: "https://linkedin.com/in/roseisrose"
  }
};

// 面包屑导航
const breadcrumbs = [
  { name: "Home", item: "/" },
  { name: "About", item: "/about" }
];

// 自定义 Schema - 添加更详细的个人信息
const customSchemas = [
  {
    "@type": "Person",
    "name": "Rose",
    "description": "Professional portrait photographer specializing in dating and personal branding photography in Sydney.",
    "image": "https://roseisrose.com.au/images/rose-portrait.jpg",
    "jobTitle": "Portrait Photographer",
    "worksFor": {
      "@type": "Organization",
      "name": "ROSE IS ROSE"
    },
    "sameAs": [
      "https://instagram.com/roseisrose",
      "https://pinterest.com/roseisrose",
      "https://linkedin.com/in/roseisrose"
    ],
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Sydney",
      "addressRegion": "NSW",
      "addressCountry": "AU"
    },
    "knowsAbout": ["Photography", "Portrait Photography", "Dating Profile Photography"]
  }
];

const pageData = {
  seo: {
    title: "Our Philosophy & Story | ROSE IS ROSE - Narrative Portraiture",
    description: "Discover the art of narrative photography. We curate visual stories that speak volumes, blending confidence and authenticity for discerning individuals."
  },
  hero: {
    floatingBg: "Philosophy",
    badge: "The Art of Narrative Photography",
    titleMain: "CRAFTING AUTHENTICITY,",
    titleItalic: "MAGNETIZING CONNECTION"
  },
  philosophy: {
    beyond: {
      title: "Beyond the Snap",
      p1: "In an era defined by ephemeral connections and rapid digital swipes, your first impression is not just crucial—it's everything. At ROSE IS ROSE, we transcend the conventional definition of portrait photography. We don't just take pictures; we curate a visual narrative that speaks volumes before you say a single word.",
      p2: "Our specialized dating profile photography service is designed for discerning individuals in Sydney and beyond, who understand that true attraction is a blend of confidence, vulnerability, and authenticity."
    },
    approach: {
      title: "Our Approach: Strategic Storytelling",
      p1: "We believe that the best portraits are born from genuine moments, not staged perfection. Our approach involves deep consultation to understand your personality, your goals, and the message you want to convey to potential partners.",
      list: [
        "Personal brand positioning & consultation",
        "Platform-specific image strategy (Tinder, Hinge, etc.)",
        "Natural light and environmental portraiture",
        "Professional styling and wardrobe advice"
      ]
    },
    quality: {
      title: "Quality & Professionalism",
      p1: "Utilizing the highest quality professional photography equipment, we ensure every detail is crisp, every lighting setup is perfect. Our post-production team specializes in 'natural-look' editing, ensuring you look like the best version of yourself, not a digitally altered stranger."
    },
    caption: "ROSE IS ROSE // NARRATIVE PORTRAITURE"
  }
};
---

<Layout
  title="About Rose | ROSE IS ROSE Portrait Photography"
  description="Meet Rose, Sydney's premier portrait photographer specializing in dating profiles, personal branding, and professional headshots."
  ogImage="/images/about-rose.jpg"
  pageType="about"
  breadcrumbs={breadcrumbs}
  schemas={customSchemas}
>
  <Header />
  
  <main class="bg-brand-bg pt-28 md:pt-36">
    
    <section class="section-padding relative overflow-hidden">
      <div class="absolute top-40 left-[20%] pointer-events-none select-none opacity-[0.06] animate-float">
        <span class="text-[12vw] font-serif italic text-brand-accent leading-none">
          {pageData.hero.floatingBg}
        </span>
      </div>
      
      <div class="container-wide relative z-10">
        <div class="reveal-on-scroll">
            <span class="h-badge">
              <span class="inline-block w-8 h-px bg-brand-muted/40 mr-4 align-middle"></span>
              {pageData.hero.badge}
            </span>
            <h1 class="h-hero max-w-5xl uppercase">
              {pageData.hero.titleMain} <br />
              <span class="italic font-light opacity-80 pl-[10%]">
                {pageData.hero.titleItalic}
              </span>
            </h1>
        </div>
      </div>
    </section>

    <section class="pb-32">
        <div class="container-wide grid md:grid-cols-12 gap-16 items-start">
            
            <div class="md:col-span-7 space-y-20 reveal-on-scroll">
                
                <div class="border-l border-brand-muted/30 pl-8 prose-narrative">
                    <h2 class="h-section !text-3xl !mb-6">{pageData.philosophy.beyond.title}</h2>
                    <p class="drop-cap">{pageData.philosophy.beyond.p1}</p>
                    <p>{pageData.philosophy.beyond.p2}</p>
                </div>

                <div class="border-l border-brand-muted/30 pl-8 prose-narrative">
                    <h3 class="h-section !text-2xl !mb-6">{pageData.philosophy.approach.title}</h3>
                    <p>{pageData.philosophy.approach.p1}</p>
                    <ul class="list-none space-y-4 mt-8">
                        {pageData.philosophy.approach.list.map(item => (
                          <li class="text-sm tracking-wide flex items-center gap-4 text-brand-primary/80">
                            <span class="w-1 h-1 rounded-full bg-brand-accent/40"></span>
                            {item}
                          </li>
                        ))}
                    </ul>
                </div>

                <div class="border-l border-brand-muted/30 pl-8 prose-narrative">
                    <h3 class="h-section !text-2xl !mb-6">{pageData.philosophy.quality.title}</h3>
                    <p>{pageData.philosophy.quality.p1}</p>
                </div>
            </div>

            <div class="md:col-span-5 md:sticky md:top-40 reveal-on-scroll">
                <div class="relative aspect-[3/4] overflow-hidden bg-brand-dark/5 shadow-2xl">
                  <Image 
                    src={philImg} 
                    alt="The art of portrait photography" 
                    class="w-full h-full object-cover" 
                  />
                  <div class="absolute inset-0 z-10 pointer-events-none p-6 opacity-30">
                      <div class="absolute top-6 left-6 w-12 h-12 border-t border-l border-white"></div>
                      <div class="absolute top-6 right-6 w-12 h-12 border-t border-r border-white"></div>
                      <div class="absolute bottom-6 left-6 w-12 h-12 border-b border-l border-white"></div>
                      <div class="absolute bottom-6 right-6 w-12 h-12 border-b border-r border-white"></div>
                  </div>
                </div>
                <p class="h-badge !text-[9px] mt-6 text-center opacity-60">
                    {pageData.philosophy.caption}
                </p>
            </div>
        </div>
    </section>

    <Process />
    
    <ContactCTA2 />

  </main>
  
  <Footer />
</Layout>

<script>
  // 使用统一的 reveal 逻辑
  function initRevealAnimation() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
  }

  document.addEventListener('astro:page-load', initRevealAnimation);
  initRevealAnimation();
</script>