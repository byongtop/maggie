---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Process from '../components/Process.astro';
import ContactCTA2 from '../components/ContactCTA2.astro'
import { Image } from 'astro:assets';

import philImg from '../assets/images/hero/06.jpg'; // 建议换成一张摄影师工作照或富有情绪的特写

import '../styles/global.css';

---

<Layout title="Our Philosophy & Story | ROSE IS ROSE - Narrative Portraiture">
  <Header />
  
  <main class="bg-brand-bg pt-20 md:pt-28">
    
    <section class="py-16 md:py-24 relative overflow-hidden">
      <div class="absolute top-40 left-[25%] pointer-events-none select-none opacity-[0.09] animate-float">
        <span class="text-[10vw] font-serif italic text-brand-dark leading-none">Philosophy</span>
      </div>
      
      <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
        <div class="reveal-text">
            <p class="text-brand-muted text-[10px] tracking-[0.5em] uppercase mb-4 flex items-center">
              <span class="w-8 h-[1px] bg-brand-muted/40 mr-4"></span>
              The Art of Narrative Photography
            </p>
            <h1 class="text-5xl md:text-7xl font-serif leading-[0.9] text-brand-dark mb-10 max-w-4xl">
              CRAFTING AUTHENTICITY, <br />
              <span class="italic font-light opacity-80 pl-[10%]">MAGNETIZING CONNECTION</span>
            </h1>
        </div>
      </div>
    </section>

    <section class="pb-24 md:pb-32">
        <div class="max-w-7xl mx-auto px-6 md:px-12 grid md:grid-cols-12 gap-12 md:gap-16 items-start">
            
            <div class="md:col-span-7 space-y-12 text-brand-primary/80 font-light leading-relaxed reveal-text">
                <div class="border-l-2 border-brand-muted pl-6">
                    <h2 class="text-3xl font-serif text-brand-accent mb-6">Beyond the Snap</h2>
                    <p class="mb-4">
                        In an era defined by ephemeral connections and rapid digital swipes, your first impression is not just crucial—it's everything. At <span class="font-medium text-brand-dark">ROSE IS ROSE</span>, we transcend the conventional definition of portrait photography. We don't just take pictures; we curate a visual narrative that speaks volumes before you say a single word.
                    </p>
                    <p>
                        Our specialized dating profile photography service is designed for discerning individuals in Shanghai and beyond, who understand that true attraction is a blend of confidence, vulnerability, and authenticity.
                    </p>
                </div>

                <div class="border-l-2 border-brand-muted pl-6">
                    <h3 class="text-2xl font-serif text-brand-accent mb-6">Our Approach: Strategic Storytelling</h3>
                    <p class="mb-4">
                        We believe that the best portraits are born from genuine moments, not staged perfection. Our approach involves deep consultation to understand your personality, your goals, and the message you want to convey to potential partners. Whether you are looking for a casual lifestyle vibe in a trendy café or a sophisticated look in a high-rise office environment, we tailor every session to you.
                    </p>
                    <ul class="list-disc list-inside space-y-2 pl-2 text-sm">
                        <li>Personal brand positioning & consultation</li>
                        <li>Platform-specific image strategy (Tinder, Hinge, etc.)</li>
                        <li>Natural light and environmental portraiture</li>
                        <li>Professional styling and wardrobe advice</li>
                    </ul>
                </div>

                <div class="border-l-2 border-brand-muted pl-6">
                    <h3 class="text-2xl font-serif text-brand-accent mb-6">Quality & Professionalism</h3>
                    <p>
                        Utilizing the highest quality professional photography equipment, we ensure every detail is crisp, every lighting setup is perfect. Our post-production team specializes in "natural-look" editing, ensuring you look like the best version of yourself, not a digitally altered stranger. We retain the texture of your skin while optimizing lighting and composition.
                    </p>
                </div>
            </div>

            <div class="md:col-span-5 md:sticky md:top-32 reveal-service">
                <div class="relative aspect-[3/4] overflow-hidden bg-brand-muted/10 shadow-[0_30px_60px_-15px_rgba(0,0,0,0.3)]">
                    <Image 
            src={philImg} 
            alt="The art of portrait photography" 
            class="w-full h-full object-cover grayscale-[15%] contrast-[1.1] hover:scale-105 transition-transform duration-[2s] ease-out"
          />
          {/* 图片上的光影涂层 */}
          <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/10 to-transparent pointer-events-none"></div>
                    <div class="absolute inset-0 z-40 pointer-events-none p-6">
                        <div class="absolute top-6 left-6 w-12 h-12 border-t-[1.5px] border-l-[1.5px] border-white/50"></div>
                        <div class="absolute top-6 right-6 w-12 h-12 border-t-[1.5px] border-r-[1.5px] border-white/50"></div>
                        <div class="absolute bottom-6 left-6 w-12 h-12 border-b-[1.5px] border-l-[1.5px] border-white/50"></div>
                        <div class="absolute bottom-6 right-6 w-12 h-12 border-b-[1.5px] border-r-[1.5px] border-white/50"></div>
                    </div>
                </div>
                <p class="text-[9px] tracking-[0.3em] font-mono uppercase text-brand-muted/60 mt-4 text-center">
                    ROSE IS ROSE // NARRATIVE PORTRAITURE
                </p>
            </div>
        </div>
    </section>

    <Process />
    <ContactCTA2 />

  </main>
  
  <Footer />
</Layout>

<style is:global>
  /* 文字逐行显现动效 */
  .reveal-text {
    opacity: 0;
    transform: translateY(30px);
    transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-text.active {
    opacity: 1;
    transform: translateY(0);
  }

  /* 元素整块进入动效 */
  .reveal-service {
    opacity: 0;
    transform: translateY(60px) scale(0.98);
    transition: all 1.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-service.active {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* 背景文字漂浮动画 */
  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(1deg); }
  }
  .animate-float {
    animation: float 10s ease-in-out infinite;
  }
</style>

<script>
  // 复用 Intersection Observer 逻辑
  function initAboutAnimation() {
    const observerOptions = {
      threshold: 0.1,
      rootMargin: "0px 0px -10% 0px"
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    document.querySelectorAll('.reveal-text, .reveal-service').forEach(el => observer.observe(el));
  }

  document.addEventListener('astro:page-load', initAboutAnimation);
  initAboutAnimation();
</script>