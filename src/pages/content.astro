---
// src/pages/content.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

// 假设这些组件您已经创建，或者为了保证页面运行，我直接在此页编写其核心逻辑
---

<Layout title="Services & Philosophy | Dating Photography">
  <Header />

  <main class="min-h-screen bg-brand-bg text-brand-primary pt-32 pb-20">
    <div class="max-w-5xl mx-auto px-6">
      
      <header class="mb-20 text-center">
        <h1 class="text-5xl font-extrabold text-brand-accent mb-6">
          Your Dating Profile, <span class="text-brand-muted">Elevated</span>.
        </h1>
        <p class="text-lg opacity-80 max-w-2xl mx-auto">
          Explore our tailored approach to capturing images that not only look stunning 
          but tell your unique story.
        </p>
      </header>

      <section class="mb-24">
        <h2 class="text-3xl font-bold text-brand-accent mb-12 border-b-2 border-brand-muted pb-4">Our Core Approach</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {[
            { title: 'Image Consulting', desc: 'Personal styling and brand alignment for your profile.' },
            { title: 'Lifestyle Shooting', desc: 'Natural lighting, real scenarios, authentic moments.' },
            { title: 'Profile Curation', desc: 'Selection and editing optimized for dating apps.' }
          ].map(item => (
            <div class="bg-white p-8 rounded-sm shadow-sm">
              <h3 class="text-xl font-bold text-brand-dark mb-4">{item.title}</h3>
              <p class="text-sm opacity-90 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-24 p-10 bg-brand-dark rounded-sm text-brand-on-dark">
        <h2 class="text-3xl font-bold mb-12 text-center">The Journey</h2>
        <div class="space-y-8">
          <div class="flex gap-6">
            <div class="text-5xl font-light text-brand-muted">01</div>
            <div>
              <h4 class="text-xl font-bold mb-2">Consultation</h4>
              <p class="opacity-80">We discuss your goals, vibe, and plan the perfect locations and outfits.</p>
            </div>
          </div>
          <div class="flex gap-6">
            <div class="text-5xl font-light text-brand-muted">02</div>
            <div>
              <h4 class="text-xl font-bold mb-2">The Session</h4>
              <p class="opacity-80">A relaxed, 2-hour shoot focusing on natural expressions and interaction.</p>
            </div>
          </div>
          <div class="flex gap-6">
            <div class="text-5xl font-light text-brand-muted">03</div>
            <div>
              <h4 class="text-xl font-bold mb-2">Curation</h4>
              <p class="opacity-80">You receive a gallery to select your best shots, followed by professional editing.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="grid md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-3xl font-bold text-brand-accent mb-8">Our Philosophy</h2>
          <p class="leading-relaxed opacity-90 mb-4">
            We believe that the best photographs are not staged; they are discovered. 
            By creating a relaxed atmosphere, we allow your true personality to shine through.
          </p>
          <p class="leading-relaxed opacity-90">
            It's not about being photogenic; it's about being authentic.
          </p>
        </div>
        <div>
          <h2 class="text-3xl font-bold text-brand-accent mb-8">Common Questions</h2>
          <div class="space-y-4">
            <details class="bg-white p-4 rounded-sm shadow-sm">
              <summary class="font-bold text-brand-dark cursor-pointer">What should I wear?</summary>
              <p class="text-sm mt-3 opacity-80">Wear something that feels like "you" on your best day. Avoid busy patterns.</p>
            </details>
            <details class="bg-white p-4 rounded-sm shadow-sm">
              <summary class="font-bold text-brand-dark cursor-pointer">How long does editing take?</summary>
              <p class="text-sm mt-3 opacity-80">Final photos are delivered within 5-7 business days.</p>
            </details>
          </div>
        </div>
      </section>
      
    </div>
  </main>

  <Footer />
</Layout>