---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const breadcrumbs = [
  { name: "Home", item: "/" },
  { name: "Contact", item: "/contact" }
];

// ✅ Schema: only real, verifiable data
// No fake address or coordinates — LocalBusiness schema removed until real address is confirmed
// FAQPage schema kept as it uses accurate service information
const customSchemas = [
  {
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I book a dating profile photography session in Sydney?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Fill out the contact form below or call 0491 649 117. We'll get back to you within 24 hours to talk through what you're looking for and find a time that works."
        }
      },
      {
        "@type": "Question",
        "name": "Where do you shoot in Sydney?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We shoot on location across Sydney — The Rocks, Circular Quay, Surry Hills, Bondi, Barangaroo and more. Locations are chosen based on your vibe, your goals, and where the light is best."
        }
      },
      {
        "@type": "Question",
        "name": "Do you offer hair, makeup and styling as well as photography?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes — hair, makeup, wardrobe styling, profile writing and dating app strategy are all available as add-ons to the photography session, or as standalone services."
        }
      }
    ]
  }
];

const page = {

  // ✅ Single source of truth for SEO — passed directly to Layout
  meta: {
    // ✅ PRIMARY keyword "dating profile photography Sydney" in title
    title: "Contact | Dating Profile Photography Sydney | ROSE IS ROSE",
    description: "Book a dating profile photography session in Sydney with Maggie at ROSE IS ROSE. Call 0491 649 117 or fill out the form — we'll get back to you within 24 hours.",
    ogImage: "/images/contact-roseisrose.jpg"
  },

  hero: {
    badge: "Sydney · Dating Profile Photography",
    // ✅ H1: contains keyword, not a brand slogan
    h1Full: "Book a Dating Profile Photography Session Sydney",
    h1Line1: "BOOK A SESSION.",
    h1Line2: "SYDNEY",
    // Warm, direct — not a sales pitch. This is the last step before they commit.
    desc: "Fill out the form and Maggie will get back to you within 24 hours. No pressure, no package pitch — just a conversation about what you're looking for."
  },

  // ✅ Real contact info only — one source of truth, no duplicate objects
  contact: {
    location: {
      label: "Location",
      value: "Sydney, NSW",
      note: "All sessions on location across Sydney."
    },
    phone: {
      label: "Phone",
      value: "0491 649 117",
      link: "tel:+61491649117"
    },
    social: {
      label: "Follow Along",
      links: [
        { name: "Instagram", url: "https://instagram.com/roseisrose" },
        { name: "小红书", url: "#" }
      ]
    }
  },

  // ✅ Updated to reflect all five real services
  form: {
    fields: {
      name: "Your name",
      email: "Your email",
      message: "What are you looking for? (No wrong answers.)"
    },
    services: [
      { value: "", label: "Which service interests you?" },
      { value: "dating-profile-photography", label: "Dating Profile Photography" },
      { value: "hair-makeup", label: "Dating Styling & Hair" },
      { value: "wardrobe", label: "Dating Wardrobe Styling" },
      { value: "bio-writing", label: "Dating Profile Writing" },
      { value: "app-strategy", label: "Dating App Strategy" },
      { value: "full-package", label: "All of the above / not sure yet" },
      { value: "lifestyle", label: "Lifestyle Portraits" },
      { value: "corporate", label: "Corporate Photography" }
    ],
    button: "Send"
  }

};
---

<Layout
  title={page.meta.title}
  description={page.meta.description}
  ogImage={page.meta.ogImage}
  pageType="contact"
  breadcrumbs={breadcrumbs}
  schemas={customSchemas}
>
  <Header />
  
  <main class="section-padding pt-32 md:pt-48">
    <div class="container-wide">

      {/* Hero */}
      <div class="max-w-3xl mb-20 reveal-on-scroll">
        <span class="h-badge">
          <span class="inline-block w-8 h-px bg-brand-muted/40 mr-4 align-middle"></span>
          {page.hero.badge}
        </span>
        {/*
          ✅ SEO FIX: Single h1. sr-only span = full keyword phrase.
          Visual split is aria-hidden.
        */}
        <h1 class="h-hero !text-5xl md:!text-7xl mt-4 mb-8 uppercase">
          <span class="sr-only">{page.hero.h1Full}</span>
          <span aria-hidden="true">
            {page.hero.h1Line1}<br />
            <span class="italic text-brand-muted/70 font-light">{page.hero.h1Line2}</span>
          </span>
        </h1>
        <p class="prose-narrative opacity-80">
          {page.hero.desc}
        </p>
      </div>

      <div class="grid md:grid-cols-5 gap-16 md:gap-24">

        {/* Left: contact info */}
        <div class="md:col-span-2 space-y-16 reveal-on-scroll">

          <div class="border-l border-brand-accent/20 pl-8">
            <h3 class="h-badge !mb-2 opacity-60">{page.contact.location.label}</h3>
            <p class="text-brand-accent font-medium text-xl font-serif tracking-tight">
              {page.contact.location.value}
            </p>
            <p class="text-brand-primary/60 font-light text-sm mt-1">
              {page.contact.location.note}
            </p>
          </div>

          <div class="border-l border-brand-accent/20 pl-8">
            <h3 class="h-badge !mb-2 opacity-60">{page.contact.phone.label}</h3>
            <a
              href={page.contact.phone.link}
              class="text-brand-accent hover:text-brand-muted transition-colors duration-500 font-medium text-xl font-serif block"
            >
              {page.contact.phone.value}
            </a>
          </div>

          <div class="border-l border-brand-accent/20 pl-8">
            <h3 class="h-badge !mb-2 opacity-60">{page.contact.social.label}</h3>
            <div class="flex gap-6">
              {page.contact.social.links.map(link => (
                <a href={link.url} class="link-underlined">
                  {link.name}
                </a>
              ))}
            </div>
          </div>

        </div>

        {/* Right: form */}
        <div class="md:col-span-3 reveal-on-scroll">
          <form class="space-y-10" netlify>

            <div class="grid md:grid-cols-2 gap-10">
              <input
                type="text"
                placeholder={page.form.fields.name}
                required
                class="w-full bg-transparent border-b border-brand-accent/20 py-4 text-brand-primary placeholder:text-brand-primary/30 focus:outline-none focus:border-brand-accent transition-all duration-500 font-light"
              />
              <input
                type="email"
                placeholder={page.form.fields.email}
                required
                class="w-full bg-transparent border-b border-brand-accent/20 py-4 text-brand-primary placeholder:text-brand-primary/30 focus:outline-none focus:border-brand-accent transition-all duration-500 font-light"
              />
            </div>

            {/* ✅ Updated service dropdown — all five real services */}
            <div class="relative">
              <select
                name="service"
                class="w-full bg-transparent border-b border-brand-accent/20 py-4 text-brand-primary/50 focus:outline-none focus:border-brand-accent transition-all duration-500 appearance-none cursor-pointer font-light"
              >
                {page.form.services.map(service => (
                  <option value={service.value} class="bg-brand-bg text-brand-primary">
                    {service.label}
                  </option>
                ))}
              </select>
              <div class="absolute right-0 top-1/2 -translate-y-1/2 pointer-events-none text-brand-accent/40">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </div>
            </div>

            <textarea
              name="message"
              placeholder={page.form.fields.message}
              rows="4"
              class="w-full bg-transparent border-b border-brand-accent/20 py-4 text-brand-primary placeholder:text-brand-primary/30 focus:outline-none focus:border-brand-accent transition-all duration-500 font-light resize-none"
            ></textarea>

            <div class="pt-6">
              <button type="submit" class="btn-brand w-full md:w-auto text-center">
                {page.form.button}
              </button>
            </div>

          </form>
        </div>

      </div>
    </div>
  </main>
  
  <Footer />
</Layout>

<script>
  function initContactReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
  }
  document.addEventListener('astro:page-load', initContactReveal);
  initContactReveal();
</script>