---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const contactData = {
  seo: {
    title: "Contact | ROSE IS ROSE - Dating Imagery & Strategy",
    description: "Get in touch with ROSE IS ROSE. Start your transformation and elevate your dating profile with professional narrative photography in Sydney."
  },
  hero: {
    badge: "Get in Touch",
    titlePart1: "Start Your",
    titleHighlight: "Transformation",
    description: "Ready to elevate your dating profile? Fill out the form or reach us directly. Let's craft an identity that truly represents you."
  },
  info: {
    location: {
      label: "Location",
      address: "Sydney, Australia",
      note: "Available for travel across NSW."
    },
    direct: {
      label: "Direct Contact",
      email: "hello@roseisrose.com",
      phone: "+61 400 000 000",
      phoneLink: "tel:+61400000000"
    },
    social: {
      label: "Follow Us",
      links: [
        { name: "Instagram", url: "#" },
        { name: "Xiaohongshu", url: "#" }
      ]
    }
  },
  form: {
    placeholders: {
      name: "Name",
      email: "Email",
      message: "Tell us about your goals..."
    },
    services: [
      "Select Service",
      "Lifestyle Portraits",
      "Dating Strategy",
      "Full Agency Package"
    ],
    buttonText: "Send Request"
  }
};
---

<Layout title={contactData.seo.title}>
  <Header />
  
  <main class="section-padding pt-32 md:pt-48">
    <div class="container-wide">
      
      <div class="max-w-3xl mb-20 reveal-on-scroll">
        <span class="h-badge">
          {contactData.hero.badge}
        </span>
        <h1 class="h-hero !text-5xl md:!text-7xl mt-4 mb-8 uppercase">
          {contactData.hero.titlePart1} <br />
          <span class="italic text-brand-muted/70 font-light">{contactData.hero.titleHighlight}</span>
        </h1>
        <p class="prose-narrative opacity-80">
          {contactData.hero.description}
        </p>
      </div>

      <div class="grid md:grid-cols-5 gap-16 md:gap-24">
        
        <div class="md:col-span-2 space-y-16 reveal-on-scroll">
          <div class="border-l border-brand-accent/20 pl-8">
            <h3 class="h-badge !mb-2 opacity-60">{contactData.info.location.label}</h3>
            <p class="text-brand-accent font-medium text-xl font-serif tracking-tight">{contactData.info.location.address}</p>
            <p class="text-brand-primary/60 font-light text-sm mt-1">{contactData.info.location.note}</p>
          </div>
          
          <div class="border-l border-brand-accent/20 pl-8">
            <h3 class="h-badge !mb-2 opacity-60">{contactData.info.direct.label}</h3>
            <a href={`mailto:${contactData.info.direct.email}`} class="text-brand-accent hover:text-brand-muted transition-colors duration-500 font-medium text-xl font-serif block">
              {contactData.info.direct.email}
            </a>
            <a href={contactData.info.direct.phoneLink} class="text-brand-primary/60 hover:text-brand-accent transition-colors font-light text-sm mt-1 inline-block">
              {contactData.info.direct.phone}
            </a>
          </div>

          <div class="border-l border-brand-accent/20 pl-8">
            <h3 class="h-badge !mb-2 opacity-60">{contactData.info.social.label}</h3>
            <div class="flex gap-6">
              {contactData.info.social.links.map(link => (
                <a href={link.url} class="link-underlined">
                  {link.name}
                </a>
              ))}
            </div>
          </div>
        </div>

        <div class="md:col-span-3 reveal-on-scroll">
          <form class="space-y-10">
            <div class="grid md:grid-cols-2 gap-10">
              <div class="group">
                <input 
                  type="text" 
                  placeholder={contactData.form.placeholders.name} 
                  required
                  class="w-full bg-transparent border-b border-brand-accent/20 py-4 text-brand-primary placeholder:text-brand-primary/30 focus:outline-none focus:border-brand-accent transition-all duration-500 font-light"
                />
              </div>
              <div class="group">
                <input 
                  type="email" 
                  placeholder={contactData.form.placeholders.email} 
                  required
                  class="w-full bg-transparent border-b border-brand-accent/20 py-4 text-brand-primary placeholder:text-brand-primary/30 focus:outline-none focus:border-brand-accent transition-all duration-500 font-light"
                />
              </div>
            </div>
            
            <div class="relative group">
              <select 
                class="w-full bg-transparent border-b border-brand-accent/20 py-4 text-brand-primary/50 focus:outline-none focus:border-brand-accent transition-all duration-500 appearance-none cursor-pointer font-light"
              >
                {contactData.form.services.map(service => (
                  <option value={service} class="bg-brand-bg text-brand-primary">{service}</option>
                ))}
              </select>
              <div class="absolute right-0 top-1/2 -translate-y-1/2 pointer-events-none text-brand-accent/40">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </div>
            </div>

            <textarea 
              placeholder={contactData.form.placeholders.message} 
              rows="4"
              class="w-full bg-transparent border-b border-brand-accent/20 py-4 text-brand-primary placeholder:text-brand-primary/30 focus:outline-none focus:border-brand-accent transition-all duration-500 font-light resize-none"
            ></textarea>
            
            <div class="pt-6">
              <button 
                type="submit" 
                class="btn-brand w-full md:w-auto text-center"
              >
                {contactData.form.buttonText}
              </button>
            </div>
          </form>
        </div>
      </div>
      
    </div>
  </main>
  
  <Footer />
</Layout>

<script>
  // 统一的滚动揭幕脚本
  function initContactReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
  }

  document.addEventListener('astro:page-load', initContactReveal);
  initContactReveal();
</script>