---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout title="Contact | ROSE IS ROSE - Dating Imagery">
  <Header />
  
  <main class="pt-32 pb-24 md:pt-40 md:pb-32 bg-brand-bg">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      
      <div class="max-w-3xl mb-20">
        <span class="text-brand-muted uppercase tracking-widest text-sm font-medium">Get in Touch</span>
        <h1 class="text-5xl md:text-6xl font-serif mt-4 mb-8 text-brand-accent">
          Start Your <span class="text-brand-muted">Transformation</span>
        </h1>
        <p class="text-brand-primary/80 text-lg font-light leading-relaxed">
          Ready to elevate your dating profile? Fill out the form or reach us directly. Let's craft an identity that truly represents you.
        </p>
      </div>

      <div class="grid md:grid-cols-5 gap-16">
        
        <div class="md:col-span-2 space-y-12">
          <div class="border-l-2 border-brand-muted pl-6">
            <h3 class="text-xs uppercase tracking-widest text-brand-muted mb-2">Location</h3>
            <p class="text-brand-primary font-medium text-lg">Paris, France</p>
            <p class="text-brand-primary/70 font-light text-sm">Available for international travel.</p>
          </div>
          
          <div class="border-l-2 border-brand-muted pl-6">
            <h3 class="text-xs uppercase tracking-widest text-brand-muted mb-2">Direct Contact</h3>
            <a href="mailto:hello@roseisrose.com" class="text-brand-primary hover:text-brand-muted transition font-medium text-lg block">hello@roseisrose.com</a>
            <a href="tel:+33123456789" class="text-brand-primary/70 hover:text-brand-muted transition font-light text-sm">+33 1 23 45 67 89</a>
          </div>

          <div class="border-l-2 border-brand-muted pl-6">
            <h3 class="text-xs uppercase tracking-widest text-brand-muted mb-2">Follow Us</h3>
            <div class="flex gap-4">
              <a href="#" class="text-brand-primary hover:text-brand-muted transition">Instagram</a>
              <a href="#" class="text-brand-primary hover:text-brand-muted transition">LinkedIn</a>
            </div>
          </div>
        </div>

        <div class="md:col-span-3">
          <form class="space-y-6">
            <div class="grid md:grid-cols-2 gap-6">
              <input 
                type="text" 
                placeholder="Name" 
                required
                class="bg-transparent border-b border-brand-muted/30 py-3 text-brand-primary placeholder:text-brand-primary/40 focus:outline-none focus:border-brand-accent transition"
              />
              <input 
                type="email" 
                placeholder="Email" 
                required
                class="bg-transparent border-b border-brand-muted/30 py-3 text-brand-primary placeholder:text-brand-primary/40 focus:outline-none focus:border-brand-accent transition"
              />
            </div>
            
            <select 
                class="w-full bg-transparent border-b border-brand-muted/30 py-3 text-brand-primary/60 focus:outline-none focus:border-brand-accent transition appearance-none"
            >
                <option>Select Service</option>
                <option>Lifestyle Portraits</option>
                <option>Dating Strategy</option>
                <option>Full Agency Package</option>
            </select>

            <textarea 
              placeholder="Tell us about your goals..." 
              rows="4"
              class="w-full bg-transparent border-b border-brand-muted/30 py-3 text-brand-primary placeholder:text-brand-primary/40 focus:outline-none focus:border-brand-accent transition"
            ></textarea>
            
            <button 
              type="submit" 
              class="w-full md:w-auto bg-brand-accent text-brand-on-dark px-10 py-4 text-xs tracking-[0.2em] font-bold uppercase hover:bg-brand-muted transition-colors duration-300"
            >
              Send Request
            </button>
          </form>
        </div>
      </div>
      
    </div>
  </main>
  <Footer />
</Layout>