---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro'; // 这里的 Hero 将承担开场屏角色
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import SelectedWorks from '../components/SelectedWorks.astro';
import Services from '../components/Services.astro';
import Testimonials from '../components/Testimonials.astro';
import Philosophy from '../components/Philosophy.astro';
import FAQ from '../components/FAQ.astro';
---

<Layout title="Home">
  <h1 class="sr-only">Your Name | Minimalist Photographer</h1>
  
  <Hero />

  <div id="main-content" class="content-wrapper">
    <Header />
    <SelectedWorks />
    <Services />
    <Testimonials />
    <Philosophy />
    <FAQ />
    <Footer />
  </div>
</Layout>

<style>
  /* 初始锁定，不让内容显示或滚动 */
  .content-wrapper {
    opacity: 0;
    visibility: hidden;
    transform: translateY(50px);
    transition: all 1s cubic-bezier(0.19, 1, 0.22, 1);
  }

  /* 点击 ENTER 后激活的类 */
  :global(body.revealed) .content-wrapper {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollToPlugin } from 'gsap/ScrollToPlugin';

  gsap.registerPlugin(ScrollToPlugin);

  function handleEnter() {
    const enterBtn = document.getElementById('enter-btn');
    const content = document.getElementById('main-content');
    const heroSection = document.getElementById('hero-section');

    if (enterBtn && content) {
      enterBtn.addEventListener('click', () => {
        // 1. 在 body 加上标记类，用于解锁 CSS 滚动和样式
        document.body.classList.add('revealed');

        // 2. GSAP 动画：Hero 向上淡出，内容向上滑入
        const tl = gsap.timeline();
        
        tl.to(heroSection, {
          y: -100,
          opacity: 0,
          duration: 1,
          ease: "power4.inOut"
        })
        .to(window, {
          duration: 1,
          scrollTo: content,
          ease: "power3.inOut"
        }, "-=0.5"); // 提前 0.5 秒开始滚动
      });
    }
  }

  // 确保在 Astro 页面加载（包括视图转换）后运行
  document.addEventListener('astro:page-load', handleEnter);
</script>