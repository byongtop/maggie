---
// src/pages/index.astro
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import InitialLoader from '../components/InitialLoader.astro';
import Hero from '../components/Hero.astro';
import SelectedWorks from '../components/SelectedWorks.astro';
import Services from '../components/Services.astro';
import Packages from '../components/Packages.astro';

import Gallery from '../components/Gallery.astro';

import Process from '../components/Process.astro';

import Testimonials from '../components/Testimonials.astro';
import Philosophy from '../components/Philosophy.astro';
import FAQ from '../components/FAQ.astro';
import BlogPreview from '../components/BlogPreview.astro';
import ContactCTA from '../components/ContactCTA.astro';



---

<Layout>
  <InitialLoader />

  <h1 class="sr-only">Your Name | Minimalist Portrait & Lifestyle Photographer in Shanghai</h1>
  
  <Header />
  
  <section class="page-content">
    <Hero />
    <Philosophy />
    <Services />
    <Packages />
    <Gallery />
    <Process />
    <SelectedWorks />
    <Testimonials />
    <FAQ />
    <BlogPreview />
    <ContactCTA />
  </section>

  <Footer />
</Layout>

<style is:global>
  /* 防止加载时页面滚动 */
  body:not(.loaded) {
    overflow: hidden;
  }

  /* 主体内容进场动画 */
  .page-content {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 1.2s ease, transform 1.2s ease;
    transition-delay: 1.5s;
  }

  body.loaded .page-content {
    opacity: 1;
    transform: translateY(0);
  }
</style>