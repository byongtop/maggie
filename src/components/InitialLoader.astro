---
// src/components/InitialLoader.astro
interface Props {
  mode?: "auto" | "manual";
  delayTime?: number;
}

const { mode = "manual", delayTime = 4500 } = Astro.props;
---

<div
  id="loader-overlay"
  class="loader-overlay"
  data-mode={mode}
  data-delay={delayTime}
>
  <div class="loader-bg">
<!--     <img
      src="https://images.unsplash.com/photo-1502323777036-f29e3972d82f?q=80&w=2500&auto=format&fit=crop"
      alt="Portrait Photography"
      id="loader-img"
    /> -->
  </div>

  <div class="loader-mask"></div>

  <div class="loader-content">
    <div class="text-container">
      <div class="loader-line-top"></div>
      <span class="loader-text">ROSE is ROSE</span>
      <!-- <p class="loader-subtext">te amo como se aman ciertas cosas oscuras,secretamente,entre la sombra y el alma</p> -->
      <h3 class="text-lg md:text-xl font-normal leading-relaxed max-w-3xl">
      "te amo como se aman ciertas cosas oscuras, secretamente, entre la sombra y el alma"
    </h3>
      <div class="loader-line-bottom"></div>

      <button id="loader-btn" class="loader-link-btn">
        <span class="btn-text"
          >{mode === "manual" ? "ENTER EXPERIENCE" : "SKIP"}</span
        >
        <span class="btn-underline"></span>
      </button>
    </div>
  </div>
</div>

<style>
  .loader-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 9999;
    overflow: hidden;
    background-color: #34041a;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 1;
    visibility: visible;
    transition:
      opacity 1.5s ease-in-out,
      visibility 1.5s;
  }

  .loader-overlay.fade-out {
    opacity: 0;
    visibility: hidden;
  }

  /* 背景图片动画 */
  .loader-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .loader-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(20%) brightness(80%);
    transform: scale(1.1);
    animation: movieScale 10s ease-out forwards;
  }

  .loader-mask {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(
      circle,
      rgba(0, 0, 0, 0.3) 0%,
      rgba(0, 0, 0, 0.7) 100%
    );
    z-index: 1;
  }

  .loader-content {
    position: relative;
    z-index: 2;
    color: white;
  }

  .text-container {
    text-align: center;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .loader-text {
    font-size: clamp(2rem, 8vw, 3.5rem);
    letter-spacing: 1.2rem;
    font-weight: 200;
    display: block;
    margin: 20px 0;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 1.2s cubic-bezier(0.2, 0, 0.2, 1) forwards 0.8s;
  }

  .loader-subtext {
    font-size: 0.9rem;
    letter-spacing: 0.6rem;
    font-weight: 300;
    opacity: 0;
    margin-bottom: 20px;
    animation: fadeInText 1.5s ease forwards 1.8s;
  }

  /* --- 按钮改为文字链接样式 --- */
  .loader-link-btn {
    background: none;
    border: none;
    padding: 0;
    margin-top: 50px; /* 在原有基础上增加 30px，原先是下方的线，现在整体下移 */
    color: white;
    cursor: pointer;
    position: relative;
    opacity: 0;
    animation: fadeInText 1.5s ease forwards 2.5s;
  }

  .btn-text {
    font-size: 1rem;
    letter-spacing: 0.5rem;
    font-weight: 300;
    text-transform: uppercase;
    transition: opacity 0.3s ease;
  }

  .btn-underline {
    position: absolute;
    bottom: -8px;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: rgba(255, 255, 255, 0.4);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.5s cubic-bezier(0.65, 0.05, 0.36, 1);
  }

  .loader-link-btn:hover .btn-underline {
    transform: scaleX(1);
    transform-origin: left;
  }

  .loader-link-btn:hover .btn-text {
    opacity: 0.8;
  }

  /* 线条动画 */
  .loader-line-top,
  .loader-line-bottom {
    height: 1px;
    background: rgba(255, 255, 255, 0.4);
    width: 0;
    margin: 0 auto;
  }

  .loader-line-top {
    animation: expandLine 1.8s cubic-bezier(0.7, 0, 0.3, 1) forwards 0.4s;
  }
  .loader-line-bottom {
    animation: expandLine 1.8s cubic-bezier(0.7, 0, 0.3, 1) forwards 0.6s;
  }

  @keyframes movieScale {
    to {
      transform: scale(1.3);
    }
  }
  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes fadeInText {
    to {
      opacity: 0.7;
    }
  }
  @keyframes expandLine {
    to {
      width: 120px;
    }
  }
</style>

<script>
  function initLoader() {
    const loader = document.getElementById("loader-overlay");
    const btn = document.getElementById("loader-btn");
    if (!loader || !btn) return;

    btn.addEventListener("click", () => {
      // 1. 移除锁定类名（让 .page-content 变得可见）
      document.body.classList.add("loaded");

      // 2. 暴力重置样式，防止滚动条不显示
      document.body.style.position = "relative";
      document.body.style.overflow = "visible";
      document.body.style.height = "auto";

      // 3. 加载器淡出动画
      loader.classList.add("fade-out");
      loader.style.pointerEvents = "none";

      // 4. 彻底移除组件
      setTimeout(() => {
        loader.style.display = "none";
      }, 1500);
    });
  }

  // 适配 Astro
  window.addEventListener("load", initLoader);
  document.addEventListener("astro:after-swap", initLoader);
</script>

<style>
  .loader-overlay {
    background-color: var(--color-brand-dark); /* #34041A */
  }

  .loader-text {
    color: var(--color-brand-on-dark); /* #F9F2E7 */
    font-family: "Cormorant", serif;
  }

  .loader-subtext {
    color: var(--color-brand-on-dark);
    opacity: 0.7; /* 通过透明度制造层次，而不是新颜色 */
  }

  .loader-line-top,
  .loader-line-bottom {
    background: var(--color-brand-on-dark);
    opacity: 0.4;
  }

  .loader-link-btn .btn-text {
    color: var(--color-brand-on-dark);
  }

  .btn-underline {
    background-color: var(--color-brand-on-dark);
  }

  .loader-overlay.fade-out {
    opacity: 0;
    visibility: hidden; /* 必须有这行，彻底让它不接收点击 */
    pointer-events: none; /* 加上这行，确保鼠标可以穿透它 */
    transition:
      opacity 1.5s ease,
      visibility 1.5s;
  }
</style>
