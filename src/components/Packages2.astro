---
/**
 * Packages.astro - 阶梯式摄影套餐模块 (Dark Mode Version)
 * 核心色值：#34041A (深红底色), #F9F2E7 (羊绒米文字), #8C7355 (金棕辅助)
 */
const packages = [
  {
    name: "ESSENTIALS",
    alias: "You Have No Photos",
    price: "$440",
    duration: "60 min",
    retouched: "8 Photos",
    original: "Review Gallery in 48 hrs",
    outfits: "Outfits Guidance",
    description: "For Dating Apps/Social Media/LinkedIn. The essential starting point to build your online presence with professional clarity.",
    features: ["Pre-shoot consult call", "1 x location (multiple settings)", "Photographer’s favs list", "Profile strategy suggestion"],
    isPopular: false
  },
  {
    name: "SIGNATURE",
    alias: "Update Your Photos",
    price: "$640",
    duration: "90 min",
    retouched: "16 Photos",
    original: "Review Gallery in 48 hrs",
    outfits: "Outfits Guidance",
    description: "For Dating Apps/Social Media/LinkedIn. A comprehensive session designed to refresh your profile with a diverse range of looks.",
    features: ["Pre-shoot consult call", "1 x location (multiple settings)", "Photographer’s favs list", "Enhanced narrative depth"],
    isPopular: true
  },
  {
    name: "PREMIUM",
    alias: "Tell Your Own Story",
    price: "$840",
    duration: "2 x 60 min",
    retouched: "24 Photos",
    original: "Review Gallery in 48 hrs",
    outfits: "Outfits Guidance",
    description: "For Dating Apps/Social Media/LinkedIn. The ultimate storytelling experience across multiple sessions and locations.",
    features: ["2 x 60 min Photo Shoots", "2 x locations (multiple settings)", "Pre-shoot consult call", "Photographer’s favs list"],
    isPopular: false
  }
];
---

<section class="py-24 md:py-36 bg-[#34041A] text-[#F9F2E7] overflow-hidden">
  <div class="max-w-7xl mx-auto px-8 md:px-12">
    
    <div class="mb-24 text-center">
      <p class="text-[#8C7355] text-[10px] tracking-[0.6em] uppercase mb-6 reveal-up">The Investment</p>
      <h2 class="text-5xl md:text-7xl font-serif text-[#F9F2E7] leading-tight reveal-up uppercase">
        Curated <span class="italic font-light opacity-60 lowercase">Packages</span>
      </h2>
      <div class="w-16 h-[0.5px] bg-[#F9F2E7]/20 mx-auto mt-10 reveal-up"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 items-start">
      {packages.map((pkg, index) => (
        <div 
          class={`reveal-card group relative p-10 md:p-12 transition-all duration-1000 ease-out 
          ${pkg.isPopular 
            ? 'scale-105 z-10 border border-[#F9F2E7]/30 bg-[#4A1A2A]' 
            : 'mt-0 lg:mt-10 border border-[#F9F2E7]/10 bg-[#3C0B21]'}
          hover:border-[#F9F2E7]/50 hover:-translate-y-3 hover:shadow-[0_30px_60px_-15px_rgba(0,0,0,0.6)]`}
        >
          {pkg.isPopular && (
            <div class="absolute top-0 right-10 -translate-y-1/2 bg-[#F9F2E7] text-[#34041A] px-5 py-1.5 text-[9px] tracking-[0.3em] font-bold uppercase">
              Recommended
            </div>
          )}

          <div class="mb-14 border-b border-[#F9F2E7]/10 pb-10">
            <div class="flex justify-between items-baseline mb-6">
              <div>
                <h3 class="text-3xl font-serif text-[#F9F2E7] tracking-wider mb-2 uppercase font-medium">{pkg.name}</h3>
                <span class="text-[10px] text-[#8C7355] tracking-[0.4em] uppercase font-light">{pkg.alias}</span>
              </div>
              <span class="text-2xl font-serif text-[#F9F2E7]">{pkg.price}</span>
            </div>
            <p class="text-[13px] text-[#F9F2E7]/70 leading-relaxed font-sans font-light italic">
              {pkg.description}
            </p>
          </div>

          <div class="grid grid-cols-2 gap-y-8 mb-14">
            {[
              { label: 'Duration', value: pkg.duration },
              { label: 'Retouched', value: pkg.retouched },
              { label: 'Outfits', value: pkg.outfits },
              { label: 'Originals', value: pkg.original }
            ].map(item => (
              <div class="flex flex-col">
                <span class="text-[9px] text-[#8C7355] uppercase tracking-widest mb-2 opacity-80">{item.label}</span>
                <span class="text-[13px] text-[#F9F2E7] font-mono font-bold uppercase tracking-tight">{item.value}</span>
              </div>
            ))}
          </div>

          <ul class="space-y-5 mb-16">
            {pkg.features.map(feature => (
              <li class="flex items-center text-[12px] text-[#F9F2E7]/80 font-light tracking-wide">
                <span class="w-1 h-1 rounded-full bg-[#8C7355] mr-4"></span>
                {feature}
              </li>
            ))}
          </ul>

          <a 
            href="/booking" 
            class={`block w-full text-center py-6 text-[10px] tracking-[0.5em] uppercase transition-all duration-700 border
            ${pkg.isPopular 
              ? 'bg-[#F9F2E7] text-[#34041A] border-[#F9F2E7] hover:bg-transparent hover:text-[#F9F2E7]' 
              : 'bg-transparent text-[#F9F2E7] border-[#F9F2E7]/30 hover:border-[#F9F2E7] hover:bg-[#F9F2E7]/5'}`}
          >
            Choose Package
          </a>
          
          <span class="absolute bottom-6 right-8 text-[7rem] font-serif italic text-[#F9F2E7]/[0.03] pointer-events-none select-none group-hover:text-[#F9F2E7]/[0.08] transition-all duration-1000 leading-none">
            0{index + 1}
          </span>
        </div>
      ))}
    </div>

    <div class="mt-24 text-center reveal-up">
      <p class="text-[10px] text-[#F9F2E7]/40 tracking-[0.2em] uppercase font-sans leading-loose">
        * Additional hours and retouching available upon request. <br class="hidden md:block" /> 
        Travel fees may apply for locations outside the Sydney metropolitan area.
      </p>
    </div>
  </div>
</section>

<style is:global>
  .reveal-up {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .reveal-up.active {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-card {
    opacity: 0;
    transform: translateY(60px);
    transition: all 1.2s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.6s ease, border-color 0.6s ease;
  }
  .reveal-card.active {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-card:nth-child(2) { transition-delay: 0.2s; }
  .reveal-card:nth-child(3) { transition-delay: 0.4s; }
</style>

<script>
  function initPackages() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.05 });

    document.querySelectorAll('.reveal-up, .reveal-card').forEach(el => observer.observe(el));
  }

  document.addEventListener('astro:page-load', initPackages);
  initPackages();
</script>