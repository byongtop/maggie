---
/**
 * Philosophy.astro - 创作理念模块
 * 视觉风格：极简大白空间、衬线体艺术字、图文错位排版
 */
const philosophy = {
  title: "A Pursuit of Light & Time",
  subtitle: "MY PHILOSOPHY",
  content: [
    "I believe that photography is not merely the act of capturing a subject, but the art of observing how time whispers through light. In the stillness of a frame, we find the echoes of emotions that words often fail to carry.",
    "My work is a continuous exploration of minimalism—stripping away the noise to reveal the raw, warm essence of the human experience. Every shadow has a story, and every highlight is a memory waiting to be felt."
  ],
  image: "/assets/images/philosophy.jpg", // 建议使用一张色调温暖、低对比度的工作照
  signature: "THE ARTIST'S VOICE"
};
---

<section class="py-40 px-6 md:px-12 bg-brand-bg overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col lg:flex-row items-center gap-20 lg:gap-32">
      
      <div class="relative w-full lg:w-1/2 reveal-left">
        <div class="absolute -top-10 -left-10 w-64 h-80 bg-brand-muted/30 -z-10 transition-transform duration-1000 group-hover:translate-x-5"></div>
        
        <div class="overflow-hidden bg-brand-muted aspect-[3/4] shadow-2xl">
          <img 
            src={philosophy.image} 
            alt="Photographer at work" 
            class="w-full h-full object-cover grayscale-[20%] sepia-[10%] opacity-90 hover:scale-105 transition-transform duration-1000"
          />
        </div>
        
        <p class="mt-6 text-[10px] tracking-[0.5em] text-brand-accent uppercase font-light">
          — Capturing the invisible
        </p>
      </div>

      <div class="w-full lg:w-1/2 flex flex-col items-start reveal-right">
        <span class="text-brand-contrast text-xs tracking-[0.8em] uppercase mb-8 italic">
          {philosophy.subtitle}
        </span>
        
        <h2 class="text-4xl md:text-6xl font-light text-brand-accent tracking-tight leading-tight mb-12 font-serif italic">
          {philosophy.title}
        </h2>

        <div class="space-y-8 max-w-lg">
          {philosophy.content.map((para) => (
            <p class="text-brand-primary text-base md:text-lg leading-relaxed font-light opacity-90">
              {para}
            </p>
          ))}
        </div>

        <div class="mt-16 flex items-center space-x-6">
          <div class="w-12 h-[1px] bg-brand-contrast"></div>
          <span class="text-[10px] tracking-[0.6em] text-brand-contrast uppercase font-medium">
            {philosophy.signature}
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* 左右对向滑入动画 */
  .reveal-left {
    opacity: 0;
    transform: translateX(-50px);
    transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .reveal-right {
    opacity: 0;
    transform: translateX(50px);
    transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: 0.2s;
  }

  .reveal-left.active, .reveal-right.active {
    opacity: 1;
    transform: translateX(0);
  }

  /* 增加字体的优雅感 */
  h2 {
    text-underline-offset: 8px;
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
      }
    });
  }, { threshold: 0.2 });

  document.querySelectorAll('.reveal-left, .reveal-right').forEach(el => observer.observe(el));
</script>