---
/**
 * Philosophy.astro - 创作理念模块 (ROSE IS ROSE)
 * 核心色值：#F9F2E7 (背景), #34041A (文字), #8C7355 (辅助/装饰)
 * 适配：Tailwind CSS v4 & Astro 
 */
import { Image } from 'astro:assets';
import philImg from '../assets/images/maggie.jpg'; // 建议使用 Maggie 工作照或极具情绪感的作品

const philosophy = {
  title: "Dating Profile Photography for the Discerning Sydney-sider",
  subtitle: "The Art of Being Seen",
  content: [
    "Welcome to Rose Is Rose, a refined portrait and dating profile photography experience based in Sydney.. We help you present your most magnetic self — effortlessly natural, quietly confident, and undeniably attractive.",
    "Your dating profile is more than a photo; it’s your personal brand, your energy, your story in a single glance. Through thoughtful styling, guided posing, and an empowering studio experience, we create images that spark curiosity and invite connection.",
    "At Rose Is Rose, we don't just take photos — we shape first impressions that open doors to meaningful conversations and extraordinary connections."
  ],
  signature: "Maggie / Lead Photographer"
};
---

<section class="py-24 md:py-36 px-8 md:px-20 bg-[#F9F2E7] overflow-hidden relative min-h-screen flex items-center">
  <div class="absolute top-20 right-[-5%] pointer-events-none select-none hidden lg:block opacity-[0.03]">
    <span class="text-[18vw] font-serif italic text-[#34041A] tracking-tighter">Aesthetic</span>
  </div>

  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-32">
      
      <div class="relative w-full lg:w-5/12 reveal-left">
        {/* 装饰边框 */}
        <div class="absolute -top-8 -left-8 w-32 h-48 border border-[#8C7355]/20 -z-10"></div>
        <div class="absolute -bottom-8 -right-8 w-full h-full bg-[#34041A]/5 -z-20"></div>
        
        <div class="overflow-hidden bg-[#8C7355]/10 aspect-[3/4] relative shadow-2xl">
          <Image 
            src={philImg} 
            alt="The art of portrait photography" 
            class="w-full h-full object-cover grayscale-[20%] contrast-[1.05] hover:scale-105 transition-transform duration-[3s] ease-out"
          />
          {/* 氛围遮罩层 */}
          <div class="absolute inset-0 bg-gradient-to-t from-[#34041A]/20 to-transparent pointer-events-none"></div>
        </div>
        
        <p class="mt-12 text-[10px] tracking-[0.6em] text-[#8C7355] uppercase font-semibold flex items-center">
          <span class="w-10 h-[1px] bg-[#8C7355]/40 mr-6"></span>
          The Essence of Connection
        </p>
      </div>

      <div class="w-full lg:w-7/12 flex flex-col items-start reveal-right">
        <span class="text-[#8C7355] text-[10px] tracking-[0.6em] uppercase mb-10 font-bold">
          {philosophy.subtitle}
        </span>
        
        <h2 class="text-4xl md:text-5xl lg:text-7xl font-serif text-[#34041A] leading-[1.1] mb-14 tracking-tight">
          {philosophy.title.split(' ').map((word, i) => (
            // 特意给特定单词增加斜体样式增强节奏感
            (i === 2 || i === 6) ? <span class="italic font-light opacity-80 block md:inline">{word} </span> : <span>{word} </span>
          ))}
        </h2>

        <div class="space-y-12 max-w-xl">
          {philosophy.content.map((para) => (
            <p class="text-[#3C3835]/90 text-base md:text-lg leading-[2.1] font-light tracking-wide">
              {para}
            </p>
          ))}
        </div>

        <div class="mt-20 flex items-center space-x-10 group cursor-default">
          <div class="relative">
             <div class="w-20 h-[1px] bg-[#34041A] group-hover:w-32 transition-all duration-1000 ease-in-out"></div>
          </div>
          <div class="flex flex-col">
            <span class="text-[11px] tracking-[0.5em] text-[#34041A] uppercase font-bold italic">
              {philosophy.signature}
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* 左右滑入动效 */
  .reveal-left {
    opacity: 0;
    transform: translateX(-60px);
    transition: all 2s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }
  
  .reveal-right {
    opacity: 0;
    transform: translateX(60px);
    transition: all 2s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: 0.4s;
    will-change: transform, opacity;
  }

  .reveal-left.active, .reveal-right.active {
    opacity: 1;
    transform: translateX(0);
  }

  /* 针对中文字体渲染的微调（如果是中英文混合） */
  .font-serif {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
</style>

<script>
  const observePhilosophy = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
          // 触发一次后停止观察
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    document.querySelectorAll('.reveal-left, .reveal-right').forEach(el => observer.observe(el));
  };

  // 初始化并兼容 Astro 视图转换
  document.addEventListener('astro:page-load', observePhilosophy);
  observePhilosophy();
</script>