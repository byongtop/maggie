---
/**
 * FAQ.astro - 艺术重构版
 * 风格：法式极简 / 艺术画报感
 */
const faqs = [
  {
    num: "01",
    question: "What is your photography style?",
    answer: "Our style is rooted in warm minimalism and cinematic storytelling. We focus on authentic emotions and natural light, capturing moments that feel timeless rather than staged."
  },
  {
    num: "02",
    question: "How soon will we receive the photos?",
    answer: "Quality takes time. You will receive a 'sneak peek' selection within 48 hours. The full professionally edited gallery is typically delivered within 4 to 6 weeks."
  },
  {
    num: "03",
    question: "Do you travel for destination shoots?",
    answer: "Absolutely. We have a deep passion for exploring new landscapes. Whether it's a remote mountain range or an urban cityscape, we are available for travel worldwide."
  },
  {
    num: "04",
    question: "What should we wear for the session?",
    answer: "We recommend neutral tones and natural fabrics that complement our warm aesthetic. Once booked, we provide a detailed 'Style Guide' to help you prepare."
  }
];
---

<section class="py-48 bg-brand-bg px-6 md:px-20 relative overflow-hidden">
  
  <div class="absolute left-10 bottom-10 text-[15vw] font-serif italic text-brand-accent/[0.03] pointer-events-none leading-none select-none">
    Essence
  </div>

  <div class="max-w-[1600px] mx-auto">
    
    <div class="w-full h-[0.5px] bg-brand-accent/20 mb-20"></div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
      
      <div class="lg:col-span-4">
        <div class="lg:sticky lg:top-40">
          <p class="text-[10px] tracking-[0.8em] text-brand-accent/50 uppercase mb-8 font-medium">
            Perspective / 004
          </p>
          <h2 class="text-5xl md:text-7xl font-serif font-extralight text-brand-accent leading-[0.85] tracking-tighter uppercase">
            The <br />
            <span class="italic opacity-40 ml-12 lowercase">Journal</span> <br />
            <span class="ml-4">Faq</span>
          </h2>
          
          <div class="mt-20 hidden lg:block">
             <div class="w-px h-32 bg-gradient-to-b from-brand-accent/40 to-transparent mx-auto"></div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-8">
        {faqs.map((faq) => (
          <div class="faq-item border-b border-brand-accent/10 group overflow-hidden">
            <button 
              class="faq-trigger w-full py-14 flex items-start justify-between text-left focus:outline-none transition-all duration-700 group-hover:pl-4"
              aria-expanded="false"
            >
              <div class="flex gap-8 md:gap-16 items-start">
                <span class="font-mono text-[9px] text-brand-accent/30 mt-3 tracking-tighter italic">
                  ({faq.num})
                </span>
                <h3 class="faq-question text-2xl md:text-4xl font-serif font-light text-brand-accent/90 tracking-tight leading-snug transition-all duration-700">
                  {faq.question}
                </h3>
              </div>

              <div class="relative w-10 h-10 mt-1 shrink-0 flex items-center justify-center transition-transform duration-700 icon-box">
                 <div class="absolute w-6 h-[0.5px] bg-brand-accent/40"></div>
                 <div class="absolute h-6 w-[0.5px] bg-brand-accent/40 vertical-bar transition-transform duration-700"></div>
                 <div class="absolute inset-0 border border-brand-accent/5 rounded-full scale-50 opacity-0 group-hover:scale-100 group-hover:opacity-100 transition-all duration-700"></div>
              </div>
            </button>

            <div class="faq-content max-h-0 opacity-0 transition-all duration-1000 ease-[cubic-bezier(0.19,1,0.22,1)]">
              <div class="pb-16 pl-20 md:pl-32 max-w-3xl">
                <p class="text-brand-accent/70 text-lg md:text-xl leading-relaxed font-serif italic tracking-wide">
                  "{faq.answer}"
                </p>
                
                <div class="mt-8 h-px w-12 bg-brand-accent/20"></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* 极致顺滑的展开逻辑 */
  .faq-item.is-active .faq-content {
    max-height: 1000px;
    opacity: 1;
    margin-top: -1rem; /* 紧凑修正 */
  }

  .faq-item.is-active .faq-question {
    font-style: italic;
    color: #34041A; /* 展开后加深颜色 */
    transform: translateX(10px);
  }

  .faq-item.is-active .vertical-bar {
    transform: rotate(90deg) scaleX(0); /* 变横线 */
  }

  .faq-item.is-active .icon-box {
    transform: rotate(180deg);
  }

  /* 字体渲染优化 */
  .faq-question {
    -webkit-font-smoothing: antialiased;
    letter-spacing: -0.02em;
  }
</style>

<script>
  function setupFAQ() {
    const items = document.querySelectorAll('.faq-item');

    items.forEach(item => {
      const trigger = item.querySelector('.faq-trigger');
      
      trigger?.addEventListener('click', () => {
        const isCurrentlyActive = item.classList.contains('is-active');

        // 关闭所有已打开的 (独占模式，更具高级感)
        items.forEach(i => {
          i.classList.remove('is-active');
          i.querySelector('.faq-trigger')?.setAttribute('aria-expanded', 'false');
        });

        // 如果之前没开，现在开启
        if (!isCurrentlyActive) {
          item.classList.add('is-active');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }

  // 兼容 Astro 视图切换
  setupFAQ();
  document.addEventListener('astro:page-load', setupFAQ);
</script>