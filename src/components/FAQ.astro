---
/**
 * FAQ.astro - Homepage FAQ component - ROSE IS ROSE
 * Four questions covering the real concerns of someone considering booking.
 * Keeps the existing accordion interaction and visual style intact.
 */

const faqs = [
  {
    num: "01",
    question: "How is this different from just taking my own photos?",
    answer: "Most people's self-taken photos look like self-taken photos — and on a dating app, that reads as someone who either doesn't have anyone to take their photo, or couldn't be bothered. The difference isn't just technical quality. It's that a good session gives you photos where you look relaxed, lit properly, and like yourself on a genuinely good day. That combination is very hard to achieve pointing a phone at your own reflection."
  },
  {
    num: "02",
    question: "How long does a session take, and when do I get the photos?",
    answer: "Most sessions run two to three hours — long enough to shoot across a couple of locations and let you settle into it, not so long that it becomes exhausting. Edited images are delivered within two weeks. Every final image is individually edited, so you receive a finished set rather than a folder of hundreds of half-decent shots to sort through yourself."
  },
  {
    num: "03",
    question: "Do I need to book all the services together?",
    answer: "No. Most people start with the photography session and add from there. Hair and makeup, wardrobe styling, profile writing and app strategy are all available as add-ons — or as standalone sessions if you've already got the photos sorted. There's no package you have to buy. You just book what's actually useful for where you're at."
  },
  {
    num: "04",
    question: "I'm nervous about being photographed. Will that show?",
    answer: "It shows in the first twenty minutes, and then it usually doesn't. The beginning of every session is warm-up — walking, talking, getting comfortable with the camera present. The good photos almost always happen after that, once you've stopped thinking about being photographed. Most people are surprised by how quickly that happens. And for what it's worth: nearly everyone says some version of 'I'm terrible in photos' before we start, and nearly everyone ends up with photos they actually like."
  }
];
---

<section class="py-32 bg-brand-bg px-6 md:px-20 relative overflow-hidden text-brand-primary">

  {/* Faint background word */}
  <div class="absolute left-[-5%] top-40 text-[18vw] font-serif italic text-brand-dark/[0.03] pointer-events-none leading-none select-none">
    Questions
  </div>

  <div class="max-w-7xl mx-auto relative z-10">

    <div class="w-full h-px bg-brand-dark/10 mb-24"></div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 md:gap-24">

      {/* Left: sticky label */}
      <div class="lg:col-span-4">
        <div class="lg:sticky lg:top-40">
          <p class="text-[10px] tracking-[0.8em] text-brand-accent uppercase mb-10 font-medium">
            Before you book
          </p>
          <h2 class="text-6xl md:text-8xl font-serif font-extralight text-brand-dark leading-[0.85] tracking-tighter uppercase">
            Good<br />
            <span class="italic opacity-30 ml-12 lowercase font-light">to</span><br />
            <span class="ml-4">Know</span>
          </h2>

          <div class="mt-16 hidden lg:block">
            <div class="w-px h-32 bg-gradient-to-b from-brand-accent/30 to-transparent"></div>
          </div>

          {/* Link to full FAQ on booking page */}
          <a
            href="/booking"
            class="hidden lg:inline-flex items-center gap-3 mt-8 text-[10px] tracking-[0.3em] uppercase text-brand-muted/60 hover:text-brand-accent transition-colors duration-300"
          >
            <span>More questions</span>
            <span>→</span>
          </a>
        </div>
      </div>

      {/* Right: accordion */}
      <div class="lg:col-span-8">
        {faqs.map((faq) => (
          <div class="faq-item border-b border-brand-dark/10 group transition-all duration-700">
            <button
              class="faq-trigger w-full py-14 flex items-start justify-between text-left focus:outline-none transition-all duration-500 hover:pl-4"
              aria-expanded="false"
            >
              <div class="flex gap-8 md:gap-16 items-start">
                <span class="font-mono text-[10px] text-brand-accent/40 mt-2.5 tracking-tighter shrink-0">
                  ({faq.num})
                </span>
                <h3 class="faq-question text-xl md:text-3xl font-serif font-light text-brand-dark/85 tracking-tight leading-[1.25] transition-all duration-500">
                  {faq.question}
                </h3>
              </div>

              {/* Plus / minus icon */}
              <div class="relative w-10 h-10 mt-1 shrink-0 flex items-center justify-center transition-transform duration-700 icon-box ml-6">
                <div class="absolute w-5 h-px bg-brand-dark/30"></div>
                <div class="absolute h-5 w-px bg-brand-dark/30 vertical-bar transition-transform duration-500"></div>
                <div class="absolute inset-0 border border-brand-dark/5 rounded-full scale-50 opacity-0 group-hover:scale-100 group-hover:opacity-100 transition-all duration-500"></div>
              </div>
            </button>

            <div class="faq-content max-h-0 opacity-0 overflow-hidden transition-all duration-700 ease-[cubic-bezier(0.19,1,0.22,1)]">
              <div class="pb-16 pl-16 md:pl-32 max-w-2xl">
                <p class="text-brand-primary/70 text-base md:text-lg leading-relaxed font-light">
                  {faq.answer}
                </p>
                <div class="mt-8 h-px w-12 bg-brand-accent/25"></div>
              </div>
            </div>

          </div>
        ))}

        {/* Mobile link to booking page */}
        <div class="lg:hidden mt-12">
          <a
            href="/booking"
            class="inline-flex items-center gap-3 text-[10px] tracking-[0.3em] uppercase text-brand-muted/60 hover:text-brand-accent transition-colors duration-300"
          >
            <span>More questions on the booking page</span>
            <span>→</span>
          </a>
        </div>

      </div>
    </div>
  </div>
</section>

<style is:global>
  .faq-item.is-active .faq-content {
    max-height: 600px;
    opacity: 1;
  }

  .faq-item.is-active .faq-question {
    font-style: italic;
    color: #34041A;
    transform: translateX(12px);
  }

  .faq-item.is-active .vertical-bar {
    transform: rotate(90deg) scaleY(0);
  }

  .faq-item.is-active .icon-box {
    transform: rotate(45deg);
  }

  .faq-question {
    -webkit-font-smoothing: antialiased;
  }
</style>

<script>
  function setupFAQ() {
    const items = document.querySelectorAll('.faq-item');

    items.forEach(item => {
      const trigger = item.querySelector('.faq-trigger');

      trigger?.addEventListener('click', () => {
        const isActive = item.classList.contains('is-active');

        // Close all
        items.forEach(i => {
          i.classList.remove('is-active');
          i.querySelector('.faq-trigger')?.setAttribute('aria-expanded', 'false');
        });

        // Open clicked if it was closed
        if (!isActive) {
          item.classList.add('is-active');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }

  setupFAQ();
  document.addEventListener('astro:page-load', setupFAQ);
</script>
