---
/**
 * FAQ.astro - 艺术重构版 (ROSE IS ROSE)
 * 风格：法式极简 / 艺术画报感 / 极致丝滑交互
 */
const faqs = [
  {
    num: "01",
    question: "What is your photography style?",
    answer: "Our style is rooted in warm minimalism and cinematic storytelling. We focus on authentic emotions and natural light, capturing moments that feel timeless rather than staged."
  },
  {
    num: "02",
    question: "How soon will we receive the photos?",
    answer: "Quality takes time. You will receive a 'sneak peek' selection within 48 hours. The full professionally edited gallery is typically delivered within 4 to 6 weeks."
  },
  {
    num: "03",
    question: "Do you travel for destination shoots?",
    answer: "Absolutely. We have a deep passion for exploring new landscapes. Whether it's a remote mountain range or an urban cityscape, we are available for travel worldwide."
  },
  {
    num: "04",
    question: "What should we wear for the session?",
    answer: "We recommend neutral tones and natural fabrics that complement our warm aesthetic. Once booked, we provide a detailed 'Style Guide' to help you prepare."
  }
];
---

<section class="py-32 bg-[#F9F2E7] px-6 md:px-20 relative overflow-hidden text-[#3C3835]">
  
  <div class="absolute left-[-5%] top-40 text-[18vw] font-serif italic text-[#34041A]/[0.03] pointer-events-none leading-none select-none">
    Essence
  </div>

  <div class="max-w-7xl mx-auto relative z-10">
    
    <div class="w-full h-[0.5px] bg-[#34041A]/10 mb-24"></div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 md:gap-24">
      
      <div class="lg:col-span-4">
        <div class="lg:sticky lg:top-40">
          <p class="text-[10px] tracking-[0.8em] text-[#8C7355] uppercase mb-10 font-medium">
            Perspective / 004
          </p>
          <h2 class="text-6xl md:text-8xl font-serif font-extralight text-[#34041A] leading-[0.8] tracking-tighter uppercase">
            The <br />
            <span class="italic opacity-30 ml-12 lowercase font-light">Journal</span> <br />
            <span class="ml-4">Faq</span>
          </h2>
          
          <div class="mt-24 hidden lg:block">
             <div class="w-px h-40 bg-gradient-to-b from-[#8C7355]/40 to-transparent"></div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-8">
        {faqs.map((faq) => (
          <div class="faq-item border-b border-[#34041A]/10 group transition-all duration-700">
            <button 
              class="faq-trigger w-full py-16 flex items-start justify-between text-left focus:outline-none transition-all duration-700 hover:pl-6"
              aria-expanded="false"
            >
              <div class="flex gap-10 md:gap-20 items-start">
                <span class="font-mono text-[10px] text-[#8C7355]/40 mt-3 tracking-tighter">
                  ({faq.num})
                </span>
                <h3 class="faq-question text-2xl md:text-4xl font-serif font-light text-[#34041A]/90 tracking-tight leading-[1.2] transition-all duration-700">
                  {faq.question}
                </h3>
              </div>

              <div class="relative w-12 h-12 mt-1 shrink-0 flex items-center justify-center transition-transform duration-700 icon-box">
                 <div class="absolute w-6 h-[0.5px] bg-[#34041A]/30"></div>
                 <div class="absolute h-6 w-[0.5px] bg-[#34041A]/30 vertical-bar transition-transform duration-700"></div>
                 <div class="absolute inset-0 border border-[#34041A]/5 rounded-full scale-50 opacity-0 group-hover:scale-100 group-hover:opacity-100 transition-all duration-700"></div>
              </div>
            </button>

            <div class="faq-content max-h-0 opacity-0 transition-all duration-1000 ease-[cubic-bezier(0.19,1,0.22,1)] overflow-hidden">
              <div class="pb-20 pl-24 md:pl-44 max-w-3xl">
                <p class="text-[#3C3835]/80 text-xl md:text-2xl leading-relaxed font-serif italic tracking-wide">
                  "{faq.answer}"
                </p>
                
                <div class="mt-10 h-px w-16 bg-[#8C7355]/30"></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* 极致顺滑的展开逻辑 */
  .faq-item.is-active .faq-content {
    max-height: 800px;
    opacity: 1;
    margin-top: 0;
  }

  .faq-item.is-active .faq-question {
    font-style: italic;
    color: #34041A;
    transform: translateX(20px);
  }

  /* 加号变横线动画 */
  .faq-item.is-active .vertical-bar {
    transform: rotate(90deg) scaleY(0);
  }

  /* 整体旋转 */
  .faq-item.is-active .icon-box {
    transform: rotate(180deg);
  }

  /* 针对中文字符的微调（如果之后加入中文） */
  .faq-question {
    -webkit-font-smoothing: antialiased;
    letter-spacing: -0.01em;
  }
</style>

<script>
  function setupFAQ() {
    const items = document.querySelectorAll('.faq-item');

    items.forEach(item => {
      const trigger = item.querySelector('.faq-trigger');
      
      trigger?.addEventListener('click', () => {
        const isCurrentlyActive = item.classList.contains('is-active');

        // 排他模式：点击一个时关闭其他，保持页面整洁
        items.forEach(i => {
          i.classList.remove('is-active');
          i.querySelector('.faq-trigger')?.setAttribute('aria-expanded', 'false');
        });

        if (!isCurrentlyActive) {
          item.classList.add('is-active');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }

  // 确保在 Astro 的不同生命周期下都能运行
  setupFAQ();
  document.addEventListener('astro:page-load', setupFAQ);
</script>