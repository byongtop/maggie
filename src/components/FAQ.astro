---
/**
 * FAQ.astro - 高级风琴交互模块
 * 视觉风格：宽度与全站对齐 (max-w-7xl)，内容右侧偏置排版
 */
const faqs = [
  {
    question: "WHAT IS YOUR PHOTOGRAPHY STYLE?",
    answer: "Our style is rooted in warm minimalism and cinematic storytelling. We focus on authentic emotions and natural light, capturing moments that feel timeless rather than staged."
  },
  {
    question: "HOW SOON WILL WE RECEIVE THE PHOTOS?",
    answer: "Quality takes time. You will receive a 'sneak peek' selection within 48 hours. The full professionally edited gallery is typically delivered within 4 to 6 weeks."
  },
  {
    question: "DO YOU TRAVEL FOR DESTINATION SHOOTS?",
    answer: "Absolutely. We have a deep passion for exploring new landscapes. Whether it's a remote mountain range or an urban cityscape, we are available for travel worldwide."
  },
  {
    question: "WHAT SHOULD WE WEAR FOR THE SESSION?",
    answer: "We recommend neutral tones and natural fabrics that complement our warm aesthetic. Once booked, we provide a detailed 'Style Guide' to help you prepare."
  }
];
---

<section class="py-40 px-6 md:px-12 bg-brand-bg">
  <div class="max-w-7xl mx-auto">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">
      
      <div class="lg:col-span-4 flex flex-col items-start lg:sticky lg:top-32 h-fit">
        <span class="text-brand-accent text-[10px] tracking-[0.6em] uppercase mb-4 italic">— Information</span>
        <h2 class="text-3xl md:text-5xl font-light text-brand-contrast tracking-tighter leading-tight">
          COMMON <br />
          <span class="italic font-serif opacity-80">QUESTIONS</span>
        </h2>
      </div>

      <div class="lg:col-span-8 border-t border-brand-muted">
        {faqs.map((faq) => (
          <div class="accordion-item border-b border-brand-muted group transition-colors duration-500 hover:bg-brand-muted/10">
            <button 
              class="accordion-trigger w-full py-10 flex justify-between items-center text-left focus:outline-none cursor-pointer"
              aria-expanded="false"
            >
              <span class="question-text text-lg md:text-xl font-light text-brand-contrast tracking-widest group-hover:text-brand-accent transition-all duration-500">
                {faq.question}
              </span>
              
              <div class="relative w-6 h-6 flex items-center justify-center shrink-0 ml-4">
                <div class="absolute w-full h-[1px] bg-brand-accent transition-transform duration-500"></div>
                <div class="absolute w-[1px] h-full bg-brand-accent transition-transform duration-500 origin-center icon-vertical-line"></div>
              </div>
            </button>

            <div class="accordion-content overflow-hidden max-h-0 transition-all duration-700 ease-[cubic-bezier(0.4,0,0.2,1)]">
              <div class="pb-10 pr-12">
                <p class="text-brand-primary text-base md:text-lg leading-relaxed opacity-80 max-w-2xl">
                  {faq.answer}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<script>
  // 保持逻辑不变
  const items = document.querySelectorAll('.accordion-item');

  items.forEach(item => {
    const trigger = item.querySelector('.accordion-trigger');
    const content = item.querySelector('.accordion-content') as HTMLElement;
    const verticalLine = item.querySelector('.icon-vertical-line') as HTMLElement;
    const questionText = item.querySelector('.question-text');

    trigger?.addEventListener('click', () => {
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';
      
      if (!isOpen) {
        trigger.setAttribute('aria-expanded', 'true');
        content.style.maxHeight = content.scrollHeight + 'px';
        verticalLine.style.transform = 'rotate(90deg)';
        questionText?.classList.add('text-brand-accent');
      } else {
        trigger.setAttribute('aria-expanded', 'false');
        content.style.maxHeight = '0px';
        verticalLine.style.transform = 'rotate(0deg)';
        questionText?.classList.remove('text-brand-accent');
      }
    });
  });
</script>

<style>
  .accordion-content {
    will-change: max-height;
  }
</style>