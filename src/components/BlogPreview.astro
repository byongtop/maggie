---
/**
 * BlogPreview.astro - 首页博客预览模块 (ROSE IS ROSE 专供版)
 * 动态从 content/blog 获取数据
 */

import { getCollection } from "astro:content";

// 从 content/blog 获取博客数据
const posts = (await getCollection("blog"))
  .map((post) => ({
    date: post.data.pubDate.toISOString().split("T")[0].replace(/-/g, "."), // 格式化日期
    category: post.data.category,
    title: post.data.title,
    excerpt: post.data.description,
    image: post.data.image || "", // 如果没有图片则为空字符串
    slug: `/blog/${post.slug}/`,
  }))
  .slice(0, 3); // 仅显示最新的 3 篇文章
---

<section
  class="section-padding bg-brand-bg border-t border-brand-dark/5 relative overflow-hidden text-brand-primary"
>
  <div
    class="absolute top-10 left-10 pointer-events-none select-none opacity-[0.04]"
  >
    <span class="h-hero italic text-brand-dark">Perspective</span>
  </div>

  <div class="container-wide relative z-10">
    <div
      class="flex flex-col md:flex-row md:items-end justify-between mb-24 gap-12"
    >
      <div class="flex flex-col">
        <p class="h-badge">The Journal</p>
        <h2 class="h-section">
          Latest <br />
          <span class="italic opacity-40 ml-12 lowercase font-light"
            >Perspectives</span
          >
        </h2>
      </div>

      <a href="/blog/" class="link-underlined group flex items-center gap-6">
        View All Stories
        <span
          class="inline-block transition-transform duration-700 group-hover:translate-x-3"
          >→</span
        >
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-20">
      {
        posts.map((post, index) => (
          <article
            class={`flex flex-col group reveal-item`}
            style={`transition-delay: ${index * 0.2}s`}
          >
            <a
              href={post.slug}
              class="relative aspect-[3/4] overflow-hidden bg-brand-dark mb-12 block shadow-sm"
            >
              <div class="absolute inset-0 z-20 pointer-events-none p-8 opacity-0 group-hover:opacity-100 transition-all duration-700">
                <div class="absolute top-0 left-0 w-10 h-10 border-t border-l border-brand-on-dark/60 transition-all duration-500 group-hover:m-4" />
                <div class="absolute bottom-0 right-0 w-10 h-10 border-b border-r border-brand-on-dark/60 transition-all duration-500 group-hover:m-4" />
              </div>

              <img
                src={post.image}
                alt={post.title}
                class="w-full h-full object-cover grayscale-[30%] group-hover:grayscale-0 scale-110 group-hover:scale-100 transition-all duration-[2s] ease-out opacity-90 group-hover:opacity-100"
                loading="lazy"
              />
            </a>

            <div class="flex flex-col space-y-6">
              <div class="flex items-center gap-5">
                <span class="text-[10px] font-mono text-brand-muted uppercase tracking-widest">
                  {post.date}
                </span>
                <span class="w-8 h-[0.5px] bg-brand-muted/30" />
                <span class="text-[10px] font-sans text-brand-dark tracking-[0.3em] uppercase font-bold">
                  {post.category}
                </span>
              </div>

              <h3 class="text-3xl font-serif text-brand-dark leading-snug tracking-tight group-hover:italic transition-all duration-700">
                <a href={post.slug}>{post.title}</a>
              </h3>

              <p class="prose-narrative text-brand-primary/70 line-clamp-2 italic">
                {post.excerpt}
              </p>

              <a
                href={post.slug}
                class="pt-4 text-[10px] text-brand-dark tracking-[0.3em] uppercase font-bold flex items-center gap-3 opacity-0 group-hover:opacity-100 transition-all duration-700 -translate-x-6 group-hover:translate-x-0 italic"
              >
                Read Entry{" "}
                <span class="w-2 h-2 rounded-full bg-brand-muted/40" />
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style is:global>
  /* 模块进入动效 */
  .reveal-item {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1.5s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }
  .reveal-item.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function initBlogReveal() {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("active");
            observer.unobserve(entry.target); // 只触发一次
          }
        });
      },
      { threshold: 0.1 }
    );

    document
      .querySelectorAll(".reveal-item")
      .forEach((el) => observer.observe(el));
  }

  // 确保在 Astro 的不同加载机制下都能生效
  document.addEventListener("astro:page-load", initBlogReveal);
  initBlogReveal();
</script>
