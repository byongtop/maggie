---
/**
 * BlogPreview.astro - 首页博客预览模块
 * 布局：一排 3 个 (md:grid-cols-3)
 * 风格：画报感 / 极简线条 / 品牌色调
 */
const posts = [
  {
    date: "2026.02.15",
    category: "Technique",
    title: "The Art of Natural Light in Portraiture",
    excerpt: "Exploring how the golden hour transforms skin tones and narrative depth in outdoor sessions.",
    image: "https://images.unsplash.com/photo-1554080353-a576cf803bda",
    slug: "/blog/natural-light"
  },
  {
    date: "2026.01.28",
    category: "Philosophy",
    title: "Minimalism: Finding Silence in Chaos",
    excerpt: "Why reducing visual noise allows the true essence of the subject to speak louder than props.",
    image: "https://images.unsplash.com/photo-1494438639946-1ebd1d20bf85",
    slug: "/blog/minimalism"
  },
  {
    date: "2025.12.10",
    category: "Archive",
    title: "Behind the Lens: Paris Autumn Series",
    excerpt: "A technical breakdown of the equipment and emotional journey behind our latest travel collection.",
    image: "https://images.unsplash.com/photo-1502602898657-3e91760cbb34",
    slug: "/blog/paris-series"
  }
];
---

<section class="py-40 bg-brand-bg px-6 md:px-12 border-t border-brand-accent/10">
  <div class="max-w-7xl mx-auto">
    
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-24 gap-8">
      <div class="flex flex-col">
        <span class="text-brand-accent text-[10px] tracking-[0.6em] uppercase mb-4 italic font-bold">— The Journal</span>
        <h2 class="text-5xl md:text-7xl font-serif font-light text-brand-accent tracking-tighter leading-none uppercase">
          Latest <br />
          <span class="italic opacity-60 ml-12 lowercase">Perspectives</span>
        </h2>
      </div>
      
      <a href="/blog" class="group flex items-center gap-4 text-brand-accent text-[10px] tracking-[0.4em] uppercase font-bold border-b border-brand-accent/20 pb-2 transition-all hover:border-brand-accent">
        View All Stories
        <span class="inline-block transition-transform duration-500 group-hover:translate-x-2">→</span>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
      {posts.map((post, index) => (
        <article class="flex flex-col group reveal-item">
          
          <a href={post.slug} class="relative aspect-[3/4] overflow-hidden bg-brand-dark mb-10 block">
            <div class="absolute inset-0 z-20 pointer-events-none p-6 opacity-0 group-hover:opacity-100 transition-all duration-700">
              <div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-brand-on-dark transition-all duration-500 group-hover:m-2"></div>
              <div class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-brand-on-dark transition-all duration-500 group-hover:m-2"></div>
            </div>

            <img 
              src={post.image} 
              alt={post.title}
              class="w-full h-full object-cover grayscale-[20%] group-hover:grayscale-0 scale-105 group-hover:scale-100 transition-all duration-[1.5s] ease-out opacity-90 group-hover:opacity-100"
            />
          </a>

          <div class="flex flex-col space-y-4">
            <div class="flex items-center gap-4">
              <span class="text-[9px] font-mono text-brand-accent/40 uppercase tracking-widest">{post.date}</span>
              <span class="w-6 h-[1px] bg-brand-accent/20"></span>
              <span class="text-[9px] font-sans text-brand-accent tracking-[0.3em] uppercase font-bold">{post.category}</span>
            </div>

            <h3 class="text-2xl font-serif text-brand-accent leading-tight tracking-tight group-hover:italic transition-all duration-500">
              <a href={post.slug}>{post.title}</a>
            </h3>

            <p class="text-brand-accent/60 text-sm leading-relaxed font-sans line-clamp-2">
              {post.excerpt}
            </p>

            <a href={post.slug} class="pt-4 text-[10px] text-brand-accent tracking-[0.2em] uppercase font-bold flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-all duration-500 -translate-x-4 group-hover:translate-x-0 italic">
              Read Entry <span class="text-[8px]">●</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* 滚动展示动画 */
  .reveal-item {
    opacity: 0;
    transform: translateY(30px);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-item.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function initBlogReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-item').forEach(el => observer.observe(el));
  }

  initBlogReveal();
  document.addEventListener('astro:page-load', initBlogReveal);
</script>