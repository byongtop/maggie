---
/**
 * BlogPreview.astro - 首页博客预览模块 (ROSE IS ROSE 专供版)
 * 核心色值：#F9F2E7 (背景), #34041A (深红), #8C7355 (金棕)
 */
const posts = [
  {
    date: "2026.02.15",
    category: "Technique",
    title: "The Art of Natural Light in Portraiture",
    excerpt: "Exploring how the golden hour transforms skin tones and narrative depth in outdoor sessions.",
    image: "https://images.unsplash.com/photo-1554080353-a576cf803bda",
    slug: "/blog/natural-light"
  },
  {
    date: "2026.01.28",
    category: "Philosophy",
    title: "Minimalism: Finding Silence in Chaos",
    excerpt: "Why reducing visual noise allows the true essence of the subject to speak louder than props.",
    image: "https://images.unsplash.com/photo-1494438639946-1ebd1d20bf85",
    slug: "/blog/minimalism"
  },
  {
    date: "2025.12.10",
    category: "Archive",
    title: "Behind the Lens: Paris Autumn Series",
    excerpt: "A technical breakdown of the equipment and emotional journey behind our latest travel collection.",
    image: "https://images.unsplash.com/photo-1502602898657-3e91760cbb34",
    slug: "/blog/paris-series"
  }
];
---

<section class="py-32 md:py-48 bg-[#F9F2E7] px-6 md:px-12 border-t border-[#34041A]/5 relative overflow-hidden text-[#3C3835]">
  
  <div class="absolute top-10 left-10 pointer-events-none select-none opacity-[0.04]">
    <span class="text-[10vw] font-serif italic text-[#34041A] leading-none">Perspective</span>
  </div>  

  <div class="max-w-7xl mx-auto relative z-10">
    
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-24 gap-12">
      <div class="flex flex-col">
        <p class="text-[10px] tracking-[0.8em] text-[#8C7355] uppercase mb-8 font-semibold">The Journal</p>
        <h2 class="text-6xl md:text-8xl font-serif font-extralight text-[#34041A] tracking-tighter leading-[0.9] uppercase">
          Latest <br />
          <span class="italic opacity-40 ml-12 lowercase font-light">Perspectives</span>
        </h2>
      </div>
      
      <a href="/blog" class="group flex items-center gap-6 text-[#34041A] text-[10px] tracking-[0.4em] uppercase font-bold border-b border-[#34041A]/20 pb-3 transition-all duration-700 hover:border-[#34041A]">
        View All Stories
        <span class="inline-block transition-transform duration-700 group-hover:translate-x-3">→</span>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-20">
      {posts.map((post, index) => (
        <article class={`flex flex-col group reveal-item`} style={`transition-delay: ${index * 0.2}s`}>
          
          <a href={post.slug} class="relative aspect-[3/4] overflow-hidden bg-[#34041A] mb-12 block shadow-sm">
            <div class="absolute inset-0 z-20 pointer-events-none p-8 opacity-0 group-hover:opacity-100 transition-all duration-700">
              <div class="absolute top-0 left-0 w-10 h-10 border-t border-l border-[#F9F2E7]/60 transition-all duration-500 group-hover:m-4"></div>
              <div class="absolute bottom-0 right-0 w-10 h-10 border-b border-r border-[#F9F2E7]/60 transition-all duration-500 group-hover:m-4"></div>
            </div>

            <img 
              src={post.image} 
              alt={post.title}
              class="w-full h-full object-cover grayscale-[30%] group-hover:grayscale-0 scale-110 group-hover:scale-100 transition-all duration-[2s] ease-out opacity-90 group-hover:opacity-100"
              loading="lazy"
            />
          </a>

          <div class="flex flex-col space-y-6">
            <div class="flex items-center gap-5">
              <span class="text-[10px] font-mono text-[#8C7355] uppercase tracking-widest">{post.date}</span>
              <span class="w-8 h-[0.5px] bg-[#8C7355]/30"></span>
              <span class="text-[10px] font-sans text-[#34041A] tracking-[0.3em] uppercase font-bold">{post.category}</span>
            </div>

            <h3 class="text-3xl font-serif text-[#34041A] leading-snug tracking-tight group-hover:italic transition-all duration-700">
              <a href={post.slug}>{post.title}</a>
            </h3>

            <p class="text-[#3C3835]/70 text-[14px] leading-[1.8] font-light line-clamp-2 italic">
              {post.excerpt}
            </p>

            <a href={post.slug} class="pt-4 text-[10px] text-[#34041A] tracking-[0.3em] uppercase font-bold flex items-center gap-3 opacity-0 group-hover:opacity-100 transition-all duration-700 -translate-x-6 group-hover:translate-x-0 italic">
              Read Entry <span class="w-2 h-2 rounded-full bg-[#8C7355]/40"></span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
  /* 模块进入动效 */
  .reveal-item {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1.5s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }
  .reveal-item.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function initBlogReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
          observer.unobserve(entry.target); // 只触发一次
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-item').forEach(el => observer.observe(el));
  }

  // 确保在 Astro 的不同加载机制下都能生效
  document.addEventListener('astro:page-load', initBlogReveal);
  initBlogReveal();
</script>