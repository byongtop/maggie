---
/**
 * Services.astro - 内容集合适配版 (ROSE IS ROSE)
 * 功能：自动从 src/content/services 读取服务数据
 * 视觉：取景器动效 / 错位布局 / REC 录制交互状态
 */
import { getCollection } from 'astro:content';

// 获取主服务数据并排序
const allServices = await getCollection('services', ({ data }) => {
  return data.isPublished !== false;
});

const services = allServices.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
---

<section class="py-24 md:py-48 bg-[#F9F2E7] px-8 md:px-10 relative overflow-hidden">
  <div class="absolute top-40 left-[5%] pointer-events-none select-none opacity-[0.03] animate-float">
    <span class="text-[18vw] font-serif italic text-[#34041A] leading-none tracking-tighter">Perspective</span>
  </div>  
  
  <div class="max-w-7xl mx-auto relative z-10">
    <div class="mb-32 flex flex-col md:flex-row md:items-end justify-between gap-12">
      <div class="max-w-3xl reveal-text">
        <p class="text-[#8C7355] text-[10px] tracking-[0.6em] uppercase mb-8 flex items-center font-bold">
          <span class="w-12 h-[1px] bg-[#8C7355]/30 mr-6"></span>
          Our Expertise
        </p>
        <h2 class="text-6xl md:text-9xl font-serif leading-[0.85] text-[#34041A] tracking-tighter">
          CRAFTING <br />
          <span class="italic font-light opacity-60 pl-[15%]">ATTRACTION</span>
        </h2>
      </div>
      <p class="text-[#3C3835]/70 text-sm md:text-base max-w-[350px] leading-relaxed tracking-wide font-light mb-6 reveal-text" style="transition-delay: 0.3s;">
        We transcend mere photography. We curate your first impression, crafting an irreplaceable visual narrative that magnetizes attraction in the Sydney elite market.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-20 gap-y-40">
      {services.map((service, index) => (
        <div class={`reveal-service group relative ${index % 2 !== 0 ? 'md:mt-64' : ''}`}>
          
          <div class="relative aspect-[3/4] overflow-hidden bg-[#34041A]/5 shadow-[0_40px_80px_-20px_rgba(52,4,26,0.15)]">
            
            <div class="absolute inset-0 z-40 pointer-events-none p-8">
              <div class="absolute top-8 left-8 w-16 h-16 border-t-[1px] border-l-[1px] border-white/50 group-hover:m-2 transition-all duration-1000"></div>
              <div class="absolute top-8 right-8 w-16 h-16 border-t-[1px] border-r-[1px] border-white/50 group-hover:m-2 transition-all duration-1000"></div>
              <div class="absolute bottom-8 left-8 w-16 h-16 border-b-[1px] border-l-[1px] border-white/50 group-hover:m-2 transition-all duration-1000"></div>
              <div class="absolute bottom-8 right-8 w-16 h-16 border-b-[1px] border-r-[1px] border-white/50 group-hover:m-2 transition-all duration-1000"></div>
              
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-6 h-6 opacity-0 group-hover:opacity-60 transition-opacity duration-1000">
                  <div class="absolute top-1/2 left-0 w-full h-[0.5px] bg-white"></div>
                  <div class="absolute top-0 left-1/2 w-[0.5px] h-full bg-white"></div>
              </div>
            </div>

            <div class="absolute inset-0 scale-110 group-hover:scale-105 transition-transform duration-[3s] ease-out">
              <img 
                src={service.data.image} 
                alt={service.data.title}
                class="w-full h-full object-cover brightness-[0.7] group-hover:brightness-[0.5] transition-all duration-1000"
              />
            </div>
            
            <div class="absolute inset-0 bg-gradient-to-t from-[#34041A]/90 via-transparent to-transparent z-10"></div>
            
            <div class="absolute inset-0 p-12 md:p-16 flex flex-col justify-end z-30">
              <div class="overflow-hidden mb-6">
                <span class="inline-block translate-y-full group-hover:translate-y-0 transition-transform duration-700 ease-out text-[#F9F2E7]/50 text-[10px] tracking-[0.4em] font-mono">
                   META_DATA: 0{index + 1} // {service.data.subtitle || 'COLLECTION'}
                </span>
              </div>

              <h3 class="text-5xl md:text-6xl font-serif text-[#F9F2E7] leading-[1.1] uppercase font-light tracking-tighter mb-10 transform group-hover:-translate-y-3 transition-transform duration-1000">
                {service.data.title}
              </h3>
              
              <div class="relative overflow-hidden pt-8 border-t border-[#F9F2E7]/10">
                <p class="text-[14px] text-[#F9F2E7]/70 leading-relaxed font-light tracking-wide max-w-xs transform translate-y-6 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-1000 delay-100 italic">
                  {service.data.desc}
                </p>
              </div>

              <div class="mt-12 self-end">
                <a href={`/services/${service.slug}`} class="flex flex-col items-end group/btn">
                  <span class="text-[9px] tracking-[0.5em] text-[#F9F2E7]/30 uppercase mb-3 font-mono group-hover/btn:text-[#8C7355] transition-colors">ISO 200 f/1.4</span>
                  <div class="overflow-hidden">
                    <span class="inline-block text-[11px] tracking-[0.6em] text-[#F9F2E7] border-b border-[#F9F2E7]/20 pb-2 uppercase font-bold group-hover/btn:translate-x-2 transition-all duration-700">
                      Explore Series
                    </span>
                  </div>
                </a>
              </div>
            </div>
          </div>

          <div class="mt-8 flex items-center justify-between overflow-hidden px-2">
            <div class="flex items-center space-x-3">
               <span class="w-2 h-2 rounded-full bg-red-600 animate-pulse shadow-[0_0_10px_rgba(220,38,38,0.5)]"></span>
               <span class="text-[10px] font-mono text-[#34041A] font-bold tracking-[0.3em] uppercase opacity-80">Rec Active</span>
            </div>
            <div class="h-[0.5px] flex-1 mx-6 bg-[#34041A]/10 relative overflow-hidden">
                <div class="absolute inset-0 bg-[#8C7355]/40 -translate-x-full group-hover:translate-x-full transition-transform duration-[2s] ease-in-out"></div>
            </div>
            <span class="text-[10px] font-mono text-[#34041A] uppercase tracking-tighter opacity-40">Focus_Locked: AF-C</span>
          </div>

        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .reveal-text {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-text.active {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-service {
    opacity: 0;
    transform: translateY(100px) scale(0.96);
    transition: all 2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-service.active {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-30px) rotate(1.5deg); }
  }
  .animate-float {
    animation: float 12s ease-in-out infinite;
  }
</style>

<script>
  function initService() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: "0px 0px -10% 0px" });

    document.querySelectorAll('.reveal-service, .reveal-text').forEach(el => observer.observe(el));
  }

  document.addEventListener('astro:page-load', initService);
  initService();
</script>