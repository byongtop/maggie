---
/**
 * Services.astro - 视觉增强版
 * 效果：图片背景 + 动态遮罩 + 序列号浮层
 */
const services = [
  { 
    no: "01", 
    title: "FINE ART PORTRAIT", 
    desc: "Capturing the unspoken essence of the soul through delicate light and shadow play.",
    image: "https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?auto=format&fit=crop&q=80&w=800"
  },
  { 
    no: "02", 
    title: "DATING PROFILE PORTRAIT", 
    desc: "Crafting natural, confident images that tell your unique story and create meaningful connections.",
    image: "https://images.unsplash.com/photo-1517841905240-472988babdf9?auto=format&fit=crop&q=80&w=800"
  },
  { 
    no: "03", 
    title: "COMMERCIAL PRODUCT", 
    desc: "Elevating brand identity through meticulous texture capturing and minimalist visual language.",
    image: "https://images.unsplash.com/photo-1523275335684-37898b6baf30?auto=format&fit=crop&q=80&w=800"
  },
  { 
    no: "04", 
    title: "SPATIAL ARCHITECTURE", 
    desc: "Exploring the balance between geometric lines and the rhythmic flow of ambient light.",
    image: "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&q=80&w=800"
  },
];
---

<section class="py-40 px-6 md:px-12 bg-brand-bg overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <div class="mb-32 flex flex-col items-center text-center">
      <span class="text-brand-contrast text-xs tracking-[0.8em] uppercase mb-6">— Our Expertise</span>
      <h2 class="text-4xl md:text-6xl font-light text-brand-accent tracking-tighter leading-none">
        PROFESSIONAL <br />
        <span class="italic font-serif opacity-80">SERVICES</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-12">
      {services.map((service, index) => (
        <div class={`
          group relative overflow-hidden aspect-[4/3] flex items-end p-8 md:p-12 reveal-service
          ${index % 2 !== 0 ? 'md:mt-24' : ''}
        `}>
          <div class="absolute inset-0 z-0">
            <img 
              src={service.image} 
              alt={service.title}
              class="w-full h-full object-cover grayscale-[100%] sepia-[20%] opacity-20 group-hover:opacity-60 group-hover:grayscale-0 group-hover:scale-110 transition-all duration-[1.5s] ease-out"
            />
            <div class="absolute inset-0 bg-linear-to-t from-brand-bg via-brand-bg/40 to-transparent z-10 group-hover:from-brand-bg/80"></div>
          </div>

          <span class="absolute top-4 right-8 text-[10rem] font-bold leading-none select-none pointer-events-none z-20
            text-transparent bg-clip-text bg-linear-to-b from-brand-muted/40 to-transparent
            group-hover:from-brand-accent/20 transition-all duration-1000">
            {service.no}
          </span>

          <div class="relative z-30 w-full">
            <div class="w-8 h-[1px] bg-brand-accent group-hover:w-20 transition-all duration-700 mb-8"></div>
            
            <div class="space-y-4">
              <h3 class="text-2xl md:text-3xl font-light text-brand-contrast tracking-[0.1em]">
                {service.title}
              </h3>
              <p class="text-brand-primary text-sm leading-relaxed max-w-sm opacity-0 group-hover:opacity-100 translate-y-4 group-hover:translate-y-0 transition-all duration-700">
                {service.desc}
              </p>
            </div>
            
            <div class="pt-8 opacity-0 group-hover:opacity-100 transition-opacity duration-700 delay-100">
              <a href="/contact" class="inline-flex items-center text-[10px] tracking-[0.5em] text-brand-contrast uppercase">
                Explore <span class="ml-4 transition-transform group-hover:translate-x-2">→</span>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .reveal-service {
    opacity: 0;
    transform: translateY(50px);
    transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-service.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('active');
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal-service').forEach(el => observer.observe(el));
</script>