---
// Services.astro - 使用独立数据文件 (完整版)

// 手动构建服务数组 - 所有5个服务
const services = [
  {
    slug: "dating-profile-writer-sydney",
    data: {
      title: "Dating Profile Writer Sydney",
      subtitle: "Words That Actually Work",
      desc: "Great photos get them to stop. Great words get them to swipe right. We'll help you write a bio that sounds like you—just funnier, smarter, and way more swipeable.",
      image: "/assets/images/photo/s3.jpg",
      order: 4,
    },
  },
  {
    slug: "dating-styling-sydney",
    data: {
      title: "dating photoshoot hair and makeup",
      subtitle: "Look Like You, But Make It Sydney",
      desc: "Great dating photos start with great styling. We'll help you look like the best version of you—without feeling like you're wearing a costume.",
      image: "/assets/images/photo/stefan-stefancik-QXevDflbl8A-unsplash.jpg",
      order: 2,
    },
  },
  {
    slug: "dating-wardrobe-stylist-sydney",
    data: {
      title: "personal stylist dating Sydney",
      subtitle: "Wear What Works",
      desc: "Stop staring at your closet wondering what works. We'll help you figure out exactly what to wear—so you look confident, comfortable, and totally you.",
      image: "/assets/images/photo/aykut-aktas-GgaHHe6mow0-unsplash.jpg",
      order: 3,
    },
  },
  {
    slug: "dating-app-strategy-sydney",
    data: {
      title: "DATING APP STRATEGY SYDNEY",
      subtitle: "Swipe Smarter, Not Harder",
      desc: "Tinder, Hinge, Bumble—they're all different games. We'll teach you how to play each one. Less mindless swiping, more actual dates with people you actually want to meet.",
      image: "/assets/images/photo/s2.jpg",
      order: 5,
    },
  },
  {
    slug: "sydney-dating-photography",
    data: {
      title: "Dating Profile Photography",
      subtitle: "Sydney Dating Portraits",
      desc: "Real photos, real Sydney locations, real you. We'll help you stand out on Tinder, Hinge and Bumble—without feeling like you're trying too hard.",
      image: "/assets/images/s1.jpg",
      order: 1,
    },
  },
].sort((a, b) => a.data.order - b.data.order);
---

<section class="section-padding bg-brand-bg relative overflow-hidden">
  <div
    class="absolute top-40 left-[5%] pointer-events-none select-none opacity-[0.03] animate-float"
  >
    <span class="h-hero italic text-brand-dark">Perspective</span>
  </div>

  <div class="container-wide relative z-10">
    <div
      class="mb-32 flex flex-col md:flex-row md:items-end justify-between gap-12"
    >
      <div class="max-w-3xl reveal-text">
        <p class="h-badge flex items-center">
          <span class="w-12 h-[1px] bg-brand-muted/30 mr-6"></span>
          Our Expertise
        </p>
        <h2 class="h-section">
          CRAFTING <br />
          <span class="italic font-light opacity-60 pl-[15%]">ATTRACTION</span>
        </h2>
      </div>
      <p
        class="prose-narrative text-brand-primary/70 mb-6 reveal-text"
        style="transition-delay: 0.3s;"
      >
        We transcend mere photography. We curate your first impression, crafting
        an irreplaceable visual narrative that magnetizes attraction in the
        Sydney elite market.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-20 gap-y-10">
      {
        services.map((service, index) => (
          <div
            class={`reveal-service group relative ${index % 2 !== 0 ? "md:mt-64" : ""}`}
          >
            <div class="relative aspect-[3/4] overflow-hidden bg-brand-dark/5 shadow-[0_40px_80px_-20px_rgba(52,4,26,0.15)]">
              <div class="absolute inset-0 z-40 pointer-events-none p-8">
                <div class="absolute top-8 left-8 w-16 h-16 border-t-[1px] border-l-[1px] border-brand-on-dark/50 group-hover:m-2 transition-all duration-1000" />
                <div class="absolute top-8 right-8 w-16 h-16 border-t-[1px] border-r-[1px] border-brand-on-dark/50 group-hover:m-2 transition-all duration-1000" />
                <div class="absolute bottom-8 left-8 w-16 h-16 border-b-[1px] border-l-[1px] border-brand-on-dark/50 group-hover:m-2 transition-all duration-1000" />
                <div class="absolute bottom-8 right-8 w-16 h-16 border-b-[1px] border-r-[1px] border-brand-on-dark/50 group-hover:m-2 transition-all duration-1000" />

                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-6 h-6 opacity-0 group-hover:opacity-60 transition-opacity duration-1000">
                  <div class="absolute top-1/2 left-0 w-full h-[0.5px] bg-brand-on-dark" />
                  <div class="absolute top-0 left-1/2 w-[0.5px] h-full bg-brand-on-dark" />
                </div>
              </div>

              <div class="absolute inset-0 scale-110 group-hover:scale-105 transition-transform duration-[3s] ease-out">
                <img
                  src={service.data.image}
                  alt={service.data.title}
                  class="w-full h-full object-cover brightness-[0.7] group-hover:brightness-[0.5] transition-all duration-1000"
                />
              </div>

              <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/90 via-transparent to-transparent z-10" />

              <div class="absolute inset-0 p-12 md:p-16 flex flex-col justify-end z-30">
                <div class="overflow-hidden mb-6">
                  <span class="inline-block translate-y-full group-hover:translate-y-0 transition-transform duration-700 ease-out text-brand-on-dark/50 text-[10px] tracking-[0.4em] font-mono">
                    0{index + 1} //{" "}
                    {service.data.subtitle || "COLLECTION"}
                  </span>
                </div>

                <h3 class="text-5xl md:text-6xl font-serif text-brand-on-dark leading-[1.1] uppercase font-light tracking-tighter mb-10 transform group-hover:-translate-y-3 transition-transform duration-1000">
                  {service.data.title}
                </h3>

                <div class="relative overflow-hidden pt-8 border-t border-brand-on-dark/10">
                  <p class="text-[14px] text-brand-on-dark/70 leading-relaxed font-light tracking-wide max-w-xs transform translate-y-6 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-1000 delay-100 italic">
                    {service.data.desc}
                  </p>
                </div>

                <div class="mt-12 self-end">
                  <a
                    href={`/services/${service.slug}`}
                    class="flex flex-col items-end group/btn"
                  >
                    <span class="text-[9px] tracking-[0.5em] text-brand-on-dark/30 uppercase mb-3 font-mono group-hover/btn:text-brand-muted transition-colors">
                      ISO 200 f/1.4
                    </span>
                    <div class="overflow-hidden">
                      <span class="inline-block text-[11px] tracking-[0.6em] text-brand-on-dark border-b border-brand-on-dark/20 pb-2 uppercase font-bold group-hover/btn:translate-x-2 transition-all duration-700">
                        Explore Series
                      </span>
                    </div>
                  </a>
                </div>
              </div>
            </div>

            <div class="mt-8 flex items-center justify-between overflow-hidden px-2">
              <div class="flex items-center space-x-3">
                <span class="w-2 h-2 rounded-full bg-brand-accent animate-pulse shadow-[0_0_10px_rgba(220,38,38,0.5)]" />
                <span class="text-[10px] font-mono text-brand-dark font-bold tracking-[0.3em] uppercase opacity-80">
                  Rec Active
                </span>
              </div>
              <div class="h-[0.5px] flex-1 mx-6 bg-brand-dark/10 relative overflow-hidden">
                <div class="absolute inset-0 bg-brand-muted/40 -translate-x-full group-hover:translate-x-full transition-transform duration-[2s] ease-in-out" />
              </div>
              <span class="text-[10px] font-mono text-brand-dark uppercase tracking-tighter opacity-40">
                Focus_Locked: AF-C
              </span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style is:global>
  .reveal-text {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-text.active {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-service {
    opacity: 0;
    transform: translateY(100px) scale(0.96);
    transition: all 2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-service.active {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-30px) rotate(1.5deg);
    }
  }
  .animate-float {
    animation: float 12s ease-in-out infinite;
  }
</style>

<script>
  function initService() {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("active");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -10% 0px" }
    );

    document
      .querySelectorAll(".reveal-service, .reveal-text")
      .forEach((el) => observer.observe(el));
  }

  document.addEventListener("astro:page-load", initService);
  initService();
</script>
