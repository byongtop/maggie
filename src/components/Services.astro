---
/**
 * Services.astro - 内容集合适配版
 * 1. 自动从 src/content/services 获取所有 md 文件
 * 2. 动效升级：增加取景器交互动画、文字流光、视口序列动画
 */
import { getCollection } from 'astro:content';

// 1. 获取所有已发布的 Markdown 服务文件，并按 order 排序
const allServices = await getCollection('services', ({ data }) => {
  return data.isPublished !== false && data.level === 1; // 首页只展示 Level 1 主服务
});

const services = allServices.sort((a, b) => a.data.order - b.data.order);
---

<section class="py-24 md:py-40 bg-brand-bg px-8 md:px-10 relative overflow-hidden">
  <div class="absolute top-40 left-[10%] pointer-events-none select-none opacity-[0.05] animate-float">
    <span class="text-[15vw] font-serif italic text-brand-dark leading-none">Perspective</span>
  </div>  
  
  <div class="max-w-7xl mx-auto relative z-10">
    <div class="mb-24 flex flex-col md:flex-row md:items-end justify-between gap-8">
      <div class="max-w-2xl reveal-text">
        <p class="text-brand-muted text-[10px] tracking-[0.5em] uppercase mb-6 flex items-center">
          <span class="w-8 h-[1px] bg-brand-muted/40 mr-4"></span>
          Our Expertise
        </p>
        <h2 class="text-5xl md:text-8xl font-serif leading-[0.9] text-brand-dark">
          CRAFTING <br />
          <span class="italic font-light opacity-80 pl-[10%]">ATTRACTION</span>
        </h2>
      </div>
      <p class="text-brand-primary/60 text-xs md:text-sm max-w-[320px] leading-relaxed tracking-[0.15em] font-sans mb-4 reveal-text" style="transition-delay: 0.3s;">
        We transcend mere photography. We curate your first impression, crafting an irreplaceable visual narrative that magnetizes attraction.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-32">
      {services.map((service, index) => (
        <div class={`reveal-service group relative ${index % 2 !== 0 ? 'md:mt-48' : ''}`}>
          
          <div class="relative aspect-[4/5] overflow-hidden bg-brand-muted/10 shadow-[0_30px_60px_-15px_rgba(0,0,0,0.3)]">
            
            <div class="absolute inset-0 z-40 pointer-events-none p-6">
              <div class="absolute top-6 left-6 w-12 h-12 border-t-[1.5px] border-l-[1.5px] border-white/70 group-hover:top-8 group-hover:left-8 transition-all duration-700 ease-out"></div>
              <div class="absolute top-6 right-6 w-12 h-12 border-t-[1.5px] border-r-[1.5px] border-white/70 group-hover:top-8 group-hover:right-8 transition-all duration-700 ease-out"></div>
              <div class="absolute bottom-6 left-6 w-12 h-12 border-b-[1.5px] border-l-[1.5px] border-white/70 group-hover:bottom-8 group-hover:left-8 transition-all duration-700 ease-out"></div>
              <div class="absolute bottom-6 right-6 w-12 h-12 border-b-[1.5px] border-r-[1.5px] border-white/70 group-hover:bottom-8 group-hover:right-8 transition-all duration-700 ease-out"></div>
              
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-4 h-4 opacity-0 group-hover:opacity-40 transition-opacity duration-700">
                  <div class="absolute top-1/2 left-0 w-full h-[1px] bg-white"></div>
                  <div class="absolute top-0 left-1/2 w-[1px] h-full bg-white"></div>
              </div>
            </div>

            <div class="absolute inset-0 scale-110 group-hover:scale-100 transition-transform duration-[2s] ease-out">
              <img 
                src={service.data.image} 
                alt={service.data.seo.imageAlt}
                class="w-full h-full object-cover brightness-[0.6] group-hover:brightness-[0.45] transition-all duration-1000"
              />
            </div>
            
            <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/80 via-transparent to-transparent z-10"></div>
            
            <div class="absolute inset-0 p-10 md:p-14 flex flex-col justify-end z-30">
              <div class="overflow-hidden mb-4">
                <span class="inline-block translate-y-full group-hover:translate-y-0 transition-transform duration-700 ease-out text-brand-on-dark/70 text-[10px] tracking-[0.3em] font-sans">
                    METADATA: {service.data.no} // {service.data.subtitle}
                </span>
              </div>

              <h3 class="text-4xl md:text-5xl font-serif text-brand-on-dark leading-none uppercase font-light tracking-tight mb-8 transform group-hover:-translate-y-2 transition-transform duration-1000">
                {service.data.title.split(' ').map((word, i) => (
                  <span class={i === 1 ? "block italic font-light opacity-70 ml-6" : "block font-medium"}>{word}</span>
                ))}
              </h3>
              
              <div class="relative overflow-hidden pt-6 border-t border-white/10">
                <p class="text-[13px] md:text-[14px] text-white/70 leading-relaxed font-light tracking-wide max-w-xs transform translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-700 delay-100">
                  {service.data.desc}
                </p>
              </div>

              <div class="mt-10 self-end">
                <a href={`/services/${service.slug}`} class="flex flex-col items-end group/btn">
                  <span class="text-[8px] tracking-[0.4em] text-white/30 uppercase mb-2 font-mono group-hover/btn:text-brand-accent transition-colors">ISO 400 f/2.8</span>
                  <div class="overflow-hidden">
                    <span class="inline-block text-[10px] tracking-[0.5em] text-brand-on-dark border-b border-brand-on-dark/30 pb-1 uppercase font-medium group-hover/btn:translate-x-1 transition-all duration-500">
                      Explore More
                    </span>
                  </div>
                </a>
              </div>
            </div>
          </div>

          <div class="mt-6 flex items-center justify-between overflow-hidden">
            <div class="flex items-center space-x-2">
               <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
               <span class="text-[9px] font-mono text-brand-dark font-bold tracking-widest uppercase">Rec Live</span>
            </div>
            <div class="h-[1px] flex-1 mx-4 bg-brand-dark/10 relative overflow-hidden">
                <div class="absolute inset-0 bg-brand-dark/40 -translate-x-full group-hover:translate-x-full transition-transform duration-[1.5s] ease-in-out"></div>
            </div>
            <span class="text-[9px] font-mono text-brand-dark uppercase tracking-tighter opacity-50">Focus_Locked</span>
          </div>

        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  /* 动效保持不变 */
  .reveal-text {
    opacity: 0;
    transform: translateY(30px);
    transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-text.active {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-service {
    opacity: 0;
    transform: translateY(60px) scale(0.98);
    transition: all 1.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-service.active {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(1deg); }
  }
  .animate-float {
    animation: float 10s ease-in-out infinite;
  }
</style>

<script>
  function initService() {
    const observerOptions = {
      threshold: 0.15,
      rootMargin: "0px 0px -10% 0px"
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    document.querySelectorAll('.reveal-service, .reveal-text').forEach(el => observer.observe(el));
  }

  document.addEventListener('astro:page-load', initService);
  initService();
</script>