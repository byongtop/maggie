---
/**
 * Footer.astro - 暖调极简摄影师网站页脚
 * 视觉风格：深色对比模式 (brand-contrast)
 */
const currentYear = new Date().getFullYear();
const socialLinks = [
  { name: 'Instagram', href: '#' },
  { name: 'Behance', href: '#' },
  { name: 'Xiaohongshu', href: '#' },
  { name: 'Vogue Me', href: '#' }
];
---

<footer class="bg-brand-contrast text-brand-bg py-20 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-12 pb-16 border-b border-brand-primary/20">
      <div class="max-w-xl">
        <h2 class="text-3xl md:text-5xl font-light tracking-tight leading-tight mb-6">
          Ready to capture your <span class="italic text-brand-accent">unspoken</span> stories?
        </h2>
        <p class="text-brand-muted/60 text-sm tracking-widest uppercase">
          Available for worldwide travel & creative collaborations.
        </p>
      </div>
      
      <a 
        href="mailto:hello@example.com" 
        class="group relative overflow-hidden bg-brand-accent text-brand-bg px-12 py-5 text-xs tracking-[0.3em] uppercase transition-all duration-500 hover:pr-16"
      >
        <span class="relative z-10">Start a Project</span>
        <span class="absolute right-4 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-all duration-300">→</span>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 py-16">
      <div class="col-span-1 md:col-span-2">
        <div class="text-2xl font-light tracking-[0.2em] mb-6">
          PHOTO<span class="text-brand-accent font-bold">GRAPH</span>
        </div>
        <p class="text-brand-muted/50 text-sm leading-relaxed max-w-xs">
          基于暖调极简主义，用光影捕捉每一个稍纵即逝的瞬间。作为前端专家与摄影师，我追求视觉与代码的完美契合。
        </p>
      </div>

      <div>
        <h4 class="text-brand-accent text-xs tracking-[0.2em] uppercase mb-8">Navigation</h4>
        <ul class="space-y-4 text-sm font-light">
          <li><a href="/works" class="hover:text-brand-accent transition-colors">Portfolio</a></li>
          <li><a href="/archive" class="hover:text-brand-accent transition-colors">Archive</a></li>
          <li><a href="/about" class="hover:text-brand-accent transition-colors">About Studio</a></li>
          <li><a href="/journal" class="hover:text-brand-accent transition-colors">Journal</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-brand-accent text-xs tracking-[0.2em] uppercase mb-8">Connect</h4>
        <ul class="space-y-4 text-sm font-light">
          {socialLinks.map(link => (
            <li>
              <a href={link.href} class="hover:text-brand-accent transition-colors flex items-center group">
                {link.name}
                <span class="ml-2 opacity-0 -translate-y-1 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">↗</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-brand-primary/10 flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="text-[10px] tracking-[0.2em] text-brand-muted/30 uppercase">
        © {currentYear} All Rights Reserved. Designed by Astro & Tailwind v4.
      </div>
      
      <div class="flex items-center space-x-6">
        <a href="/privacy" class="text-[10px] tracking-[0.2em] text-brand-muted/30 hover:text-brand-accent">PRIVACY POLICY</a>
        <button id="scroll-to-top" class="text-brand-accent text-[10px] tracking-[0.2em] hover:opacity-70 flex items-center">
          BACK TO TOP <span class="ml-2">↑</span>
        </button>
      </div>
    </div>
  </div>
</footer>

<script>
  // 回到顶部功能
  document.getElementById('scroll-to-top')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>