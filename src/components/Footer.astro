---
/**
 * Footer.astro - ROSE IS ROSE
 * Clean, high-end layout. All links real. No placeholder copy.
 */

const currentYear = new Date().getFullYear();

const navLinks = [
  { id: "01", name: "Portfolio",  href: "/portfolio" },
  { id: "02", name: "Services",   href: "/services" },
  { id: "03", name: "About",      href: "/about" },
  { id: "04", name: "Contact",    href: "/contact" },
];

// ✅ Services sub-links — gives the footer more depth and SEO value
const serviceLinks = [
  { name: "Dating Profile Photography", href: "/services/sydney-dating-photography/" },
  { name: "Hair & Makeup",              href: "/services/dating-styling-sydney/" },
  { name: "Wardrobe Styling",           href: "/services/dating-wardrobe-stylist-sydney/" },
  { name: "Profile Writing",            href: "/services/dating-profile-writer-sydney/" },
  { name: "App Strategy",               href: "/services/dating-app-strategy-sydney/" },
];

const socialLinks = [
  { name: "Instagram",    href: "https://instagram.com/roseisrose" },
  { name: "小红书",        href: "#" },
  { name: "Facebook",     href: "https://facebook.com/roseisrose" },
  { name: "Pinterest",    href: "https://pinterest.com/roseisrose" },
];
---

<footer class="bg-brand-dark text-brand-on-dark relative overflow-hidden">

  {/* Decorative top line */}
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-on-dark/10 to-transparent"></div>

  {/* Faint background word */}
  <div class="absolute bottom-0 right-0 pointer-events-none select-none opacity-[0.025] leading-none overflow-hidden">
    <span class="text-[18vw] font-serif italic text-brand-on-dark whitespace-nowrap">
      ROSE
    </span>
  </div>

  <div class="max-w-7xl mx-auto px-8 md:px-12 relative z-10">

    {/* ── Top section ──────────────────────────────────── */}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 pt-20 pb-20 border-b border-brand-on-dark/10">

      {/* Brand + CTA — col 1–4 */}
      <div class="lg:col-span-4 space-y-12">

        {/* Logo */}
        <div class="font-serif text-3xl tracking-[0.08em]">
          ROSE<span class="italic font-light text-brand-muted">IS</span>ROSE
        </div>

        {/* One-line positioning statement — no AI copy */}
        <p class="text-sm font-light text-brand-on-dark/50 leading-relaxed max-w-xs">
          Dating profile photography, styling and strategy.<br />
          Sydney.
        </p>

        {/* Phone — real number */}
        <div class="group inline-block">
          <p class="text-[9px] tracking-[0.4em] text-brand-on-dark/30 uppercase mb-3">
            Call or text
          </p>
          <a
            href="tel:+61491649117"
            class="text-xl font-light tracking-tight hover:text-brand-muted transition-colors duration-500"
          >
            0491 649 117
          </a>
          <div class="h-px w-full bg-brand-muted/30 mt-3 origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-700"></div>
        </div>

      </div>

      {/* Navigation — col 5–7 */}
      <div class="lg:col-span-3 space-y-8">
        <p class="text-[9px] tracking-[0.4em] text-brand-on-dark/30 uppercase">
          Pages
        </p>
        <ul class="space-y-4">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="flex items-center gap-3 text-xs tracking-[0.2em] uppercase text-brand-on-dark/70 hover:text-brand-on-dark transition-colors duration-300"
              >
                <span class="text-[8px] text-brand-muted font-mono opacity-60">{link.id}</span>
                <span>{link.name}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Services sub-links — col 8–10 */}
      <div class="lg:col-span-3 space-y-8">
        <p class="text-[9px] tracking-[0.4em] text-brand-on-dark/30 uppercase">
          Services
        </p>
        <ul class="space-y-4">
          {serviceLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-xs tracking-wide text-brand-on-dark/50 hover:text-brand-on-dark transition-colors duration-300 leading-relaxed"
              >
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Socials — col 11–12 */}
      <div class="lg:col-span-2 space-y-8">
        <p class="text-[9px] tracking-[0.4em] text-brand-on-dark/30 uppercase">
          Follow
        </p>
        <ul class="space-y-4">
          {socialLinks.map(link => (
            <li>
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs tracking-[0.2em] uppercase text-brand-on-dark/50 hover:text-brand-on-dark hover:italic transition-all duration-300"
              >
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    {/* ── Bottom bar ───────────────────────────────────── */}
    <div class="flex flex-col md:flex-row justify-between items-center gap-8 py-10">

      {/* Copyright */}
      <p class="text-[9px] tracking-[0.35em] text-brand-on-dark/25 uppercase">
        © {currentYear} ROSE IS ROSE · Sydney · All rights reserved
      </p>

      {/* Back to top */}
      <button
        id="back-to-top"
        class="group flex items-center gap-4 text-[9px] tracking-[0.4em] text-brand-on-dark/30 hover:text-brand-on-dark transition-all duration-500 outline-none"
        aria-label="Back to top"
      >
        <span class="uppercase">Back to top</span>
        <div class="w-8 h-8 border border-brand-on-dark/10 rounded-full flex items-center justify-center group-hover:border-brand-muted transition-colors duration-500 overflow-hidden relative">
          <span class="relative z-10 transition-transform duration-500 group-hover:-translate-y-8">↑</span>
          <span class="absolute translate-y-8 z-10 transition-transform duration-500 group-hover:translate-y-0 text-brand-muted">↑</span>
        </div>
      </button>

    </div>

  </div>
</footer>

<style is:global>
  footer .font-serif,
  footer .logo-area {
    font-family: "Cormorant Garamond", serif;
  }
</style>

<script>
  function setupFooter() {
    const btt = document.getElementById("back-to-top");
    if (btt) {
      btt.onclick = () => window.scrollTo({ top: 0, behavior: "smooth" });
    }
  }
  setupFooter();
  document.addEventListener("astro:page-load", setupFooter);
</script>