---
// src/components/SEO/SEO.astro

export interface Schema {
  "@type": string;
  [key: string]: any;
}

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  pageType?: "home" | "about" | "service" | "blog" | "contact" | "portfolio" | "blog-list";
  schema?: Schema;
  schemas?: Schema[];
  includeBaseSchemas?: boolean;
  breadcrumbs?: { name: string; item: string }[];
  images?: { url: string; caption?: string; description?: string }[];
  service?: {
    name: string;
    description: string;
    providerName: string;
    areaServed: string[];
    priceRange?: string;
  };
  blogPost?: {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    category: string;
    image?: string;
    contentBlocks?: Array<{
      image?: string;
      imageAlt?: string;
      text: string;
      layout: "left" | "right" | "full";
    }>;
    seoTitle: string;
    seoDescription: string;
  };
  blogList?: {
    title?: string;
    description?: string;
    category?: string;
    currentPage?: number;
    totalPages?: number;
    posts: Array<{
      title: string;
      description: string;
      pubDate: Date;
      category: string;
      image?: string;
      slug: string;
    }>;
  };
  pagination?: {
    currentPage: number;
    totalPages: number;
    baseUrl: string;
  };
}

// ─── 站点常量（统一维护） ───────────────────────────────────────────────────────
const SITE_NAME    = "ROSE IS ROSE";
const SITE_URL     = (Astro.site || "https://roseisrose.com.au").toString().replace(/\/$/, "");
const PHONE        = "0491649117";
const PHONE_INTL   = "+61491649117";
const EMAIL        = "hello@roseisrose.com.au";
const PRICE_RANGE  = "$440-$880";
const TWITTER      = "@roseisrose";
const LOCALE       = "en_AU";
const LOGO_URL     = `${SITE_URL}/logo.png`;
const SOCIAL_URLS  = [
  "https://instagram.com/roseisrose",
  "https://facebook.com/roseisrose",
  "https://pinterest.com/roseisrose",
];

// ─── Props 解构 ───────────────────────────────────────────────────────────────
const {
  title,
  description,
  ogImage,
  pageType = "home",
  schema,
  schemas = [],
  includeBaseSchemas = true,
  breadcrumbs = [],
  images = [],
  service,
  blogPost,
  blogList,
  pagination,
} = Astro.props;

// ─── URL 工具 ─────────────────────────────────────────────────────────────────
const canonicalURL = new URL(Astro.url.pathname, SITE_URL).toString();
const imageURL     = ogImage ? new URL(ogImage, SITE_URL).toString() : "";

// og:type 只允许合法值
const ogType =
  pageType === "blog"  ? "article"  :
  pageType === "about" ? "profile"  :
  "website";

// ─── Schema 构建 ──────────────────────────────────────────────────────────────
const allSchemas: Schema[] = [];

// 1. 基础 Schema（Organization + WebSite）
if (includeBaseSchemas) {
  allSchemas.push({
    "@type": "Organization",
    "@id": `${SITE_URL}/#organization`,
    "name": SITE_NAME,
    "url": SITE_URL,
    "logo": {
      "@type": "ImageObject",
      "url": LOGO_URL,
    },
    "telephone": PHONE_INTL,
    "email": EMAIL,
    "sameAs": SOCIAL_URLS,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Sydney",
      "addressRegion": "NSW",
      "addressCountry": "AU",
    },
  });

  // WebSite — 不包含 SearchAction（无搜索页面）
  allSchemas.push({
    "@type": "WebSite",
    "@id": `${SITE_URL}/#website`,
    "name": SITE_NAME,
    "url": SITE_URL,
    "publisher": {
      "@id": `${SITE_URL}/#organization`,
    },
  });
}

// 2. 页面类型 Schema
switch (pageType) {
  case "home": {
    allSchemas.push({
      "@type": "LocalBusiness",
      "@id": `${SITE_URL}/#localbusiness`,
      "name": SITE_NAME,
      "description": description,
      "url": SITE_URL,
      "telephone": PHONE_INTL,
      "email": EMAIL,
      "priceRange": PRICE_RANGE,
      "openingHours": "Mo-Fr 09:00-17:00",
      "image": imageURL || undefined,
      "parentOrganization": {
        "@id": `${SITE_URL}/#organization`,
      },
      "sameAs": SOCIAL_URLS,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Sydney",
        "addressRegion": "NSW",
        "addressCountry": "AU",
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "-33.8688",
        "longitude": "151.2093",
      },
    });
    break;
  }

  case "about": {
    allSchemas.push({
      "@type": "ProfilePage",
      "mainEntity": {
        "@type": "Person",
        "name": "Maggie",
        "description": description,
        "image": imageURL || undefined,
        "jobTitle": "Portrait Photographer",
        "worksFor": {
          "@id": `${SITE_URL}/#organization`,
        },
        "url": `${SITE_URL}/about`,
      },
    });
    break;
  }

  case "service": {
    if (service) {
      allSchemas.push({
        "@type": "Service",
        "name": service.name,
        "description": service.description,
        "provider": {
          "@id": `${SITE_URL}/#organization`,
        },
        "areaServed": service.areaServed.map((area) => ({
          "@type": "City",
          "name": area,
        })),
        "priceRange": service.priceRange || PRICE_RANGE,
      });
    }
    break;
  }

  case "blog": {
    if (blogPost) {
      // 收集文章图片
      const articleImages: string[] = [];
      if (blogPost.image) {
        articleImages.push(new URL(blogPost.image, SITE_URL).toString());
      }
      blogPost.contentBlocks?.forEach((block) => {
        if (block.image) {
          articleImages.push(new URL(block.image, SITE_URL).toString());
        }
      });

      // 计算字数和阅读时间
      const bodyText = blogPost.contentBlocks
        ?.map((b) => b.text.replace(/<[^>]*>/g, ""))
        .join(" ") ?? "";
      const wordCount   = bodyText.split(/\s+/).filter(Boolean).length;
      const readingTime = Math.max(1, Math.ceil(wordCount / 200));

      allSchemas.push({
        "@type": "BlogPosting",
        "headline": blogPost.seoTitle || blogPost.title,
        "description": blogPost.seoDescription || blogPost.description,
        "image": articleImages.length > 0 ? articleImages : undefined,
        "datePublished": blogPost.pubDate.toISOString(),
        // 有 updatedDate 就用，没有就省略（不输出错误的占位值）
        ...(blogPost.updatedDate
          ? { "dateModified": blogPost.updatedDate.toISOString() }
          : {}),
        "author": {
          "@type": "Person",
          "name": "Maggie",
          "url": `${SITE_URL}/about`,
        },
        "keywords": blogPost.category,
        "articleSection": blogPost.category,
        "wordCount": wordCount,
        "timeRequired": `PT${readingTime}M`,
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": canonicalURL,
        },
        "publisher": {
          "@id": `${SITE_URL}/#organization`,
        },
      });
    }
    break;
  }

  case "blog-list": {
    if (blogList) {
      allSchemas.push({
        "@type": "Blog",
        "name": blogList.title || `${SITE_NAME} Blog`,
        "description": blogList.description || "Photography tips, success stories, and dating insights",
        "url": canonicalURL,
        "publisher": {
          "@id": `${SITE_URL}/#organization`,
        },
        "blogPost": blogList.posts.map((post) => ({
          "@type": "BlogPosting",
          "headline": post.title,
          "description": post.description,
          "url": `${SITE_URL}/blog/${post.slug}`,
          "datePublished": post.pubDate.toISOString(),
          "image": post.image ? new URL(post.image, SITE_URL).toString() : undefined,
        })),
      });

      allSchemas.push({
        "@type": "ItemList",
        "itemListElement": blogList.posts.map((post, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "url": `${SITE_URL}/blog/${post.slug}`,
        })),
      });

      if (blogList.category) {
        allSchemas.push({
          "@type": "CollectionPage",
          "name": `${blogList.category} | ${SITE_NAME} Blog`,
          "description": `Articles about ${blogList.category} from ${SITE_NAME}`,
          "mainEntity": {
            "@type": "ItemList",
            "itemListElement": blogList.posts.map((post, i) => ({
              "@type": "ListItem",
              "position": i + 1,
              "item": {
                "@type": "BlogPosting",
                "url": `${SITE_URL}/blog/${post.slug}`,
              },
            })),
          },
        });
      }
    }
    break;
  }

  case "portfolio": {
    allSchemas.push({
      "@type": "ImageGallery",
      "name": title,
      "description": description,
      "image": images.map((img) => ({
        "@type": "ImageObject",
        "url": img.url,
        "caption": img.caption,
        "description": img.description,
      })),
    });
    break;
  }

  case "contact": {
    allSchemas.push({
      "@type": "ContactPage",
      "name": "Contact",
      "description": description,
      "mainEntity": {
        "@type": "Organization",
        "@id": `${SITE_URL}/#organization`,
        "email": EMAIL,
        "telephone": PHONE_INTL,
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": PHONE_INTL,
          "contactType": "customer service",
          "availableLanguage": ["English"],
        },
      },
    });
    break;
  }
}

// 3. 面包屑
if (breadcrumbs.length > 0) {
  allSchemas.push({
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbs.map((crumb, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": crumb.name,
      "item": `${SITE_URL}${crumb.item}`,
    })),
  });
}

// 4. 调用方传入的自定义 Schema
if (schema) allSchemas.push(schema);
allSchemas.push(...schemas);
---

<!-- 标准 Meta Tags -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:type"        content={ogType} />
<meta property="og:url"         content={canonicalURL} />
<meta property="og:title"       content={title} />
<meta property="og:description" content={description} />
<meta property="og:site_name"   content={SITE_NAME} />
<meta property="og:locale"      content={LOCALE} />
{ogImage && <meta property="og:image" content={imageURL} />}

<!-- Twitter Card -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:site"        content={TWITTER} />
<meta name="twitter:creator"     content={TWITTER} />
<meta name="twitter:url"         content={canonicalURL} />
<meta name="twitter:title"       content={title} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={imageURL} />}

<!-- 分页 rel 标签 -->
{pagination && pagination.currentPage > 1 && (
  <link
    rel="prev"
    href={`${SITE_URL}${pagination.baseUrl}${pagination.currentPage - 1 === 1 ? "" : `/${pagination.currentPage - 1}`}`}
  />
)}
{pagination && pagination.currentPage < pagination.totalPages && (
  <link
    rel="next"
    href={`${SITE_URL}${pagination.baseUrl}/${pagination.currentPage + 1}`}
  />
)}

<!-- 结构化数据 (JSON-LD) -->
{allSchemas.map((s, i) => (
  <script
    type="application/ld+json"
    set:html={JSON.stringify({ "@context": "https://schema.org", ...s }, null, 2)}
    data-schema-index={i}
    data-schema-type={s["@type"]}
  />
))}
