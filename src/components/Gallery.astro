---
/**
 * Gallery.astro - 动态分类作品集 (ROSE IS ROSE 专供版)
 * 核心色值：#F9F2E7 (背景), #34041A (深红), #8C7355 (金棕)
 */
const categories = ["ALL", "PORTRAIT", "LIFESTYLE", "BUSINESS"];

const galleryItems = [
  {
    category: "PORTRAIT",
    title: "Noir Mood",
    image: "https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?auto=format&fit=crop&q=80&w=800",
    span: "md:col-span-1 md:row-span-1"
  },
  {
    category: "LIFESTYLE",
    title: "Urban Silence",
    image: "https://images.unsplash.com/photo-1492633423870-43d1cd2775eb?auto=format&fit=crop&q=80&w=800",
    span: "md:col-span-1 md:row-span-2"
  },
  {
    category: "BUSINESS",
    title: "The Visionary",
    image: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&q=80&w=800",
    span: "md:col-span-1 md:row-span-1"
  },
  {
    category: "PORTRAIT",
    title: "Soft Light",
    image: "https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&q=80&w=800",
    span: "md:col-span-1 md:row-span-1"
  },
  {
    category: "LIFESTYLE",
    title: "Golden Hour",
    image: "https://images.unsplash.com/photo-1517841905240-472988babdf9?auto=format&fit=crop&q=80&w=800",
    span: "md:col-span-2 md:row-span-1"
  },
  {
    category: "BUSINESS",
    title: "Architectural Mind",
    image: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&q=80&w=800",
    span: "md:col-span-1 md:row-span-1"
  }
];
---

<section class="py-24 md:py-40 bg-[#F9F2E7] overflow-hidden">
  <div class="max-w-7xl mx-auto px-8">
    
    <div class="flex flex-col lg:flex-row lg:items-end justify-between mb-20 gap-12">
      <div class="reveal-up">
        <p class="text-[#8C7355] text-[10px] tracking-[0.6em] uppercase mb-6 font-bold">The Portfolio</p>
        <h2 class="text-5xl md:text-7xl font-serif text-[#34041A] uppercase tracking-tighter leading-none">
          Selected <span class="italic font-light opacity-50 lowercase">Fragments</span>
        </h2>
      </div>

      <nav class="flex flex-wrap gap-8 md:gap-12 border-b border-[#34041A]/5 pb-4 reveal-up" style="transition-delay: 0.2s">
        {categories.map((cat) => (
          <button
            class="filter-btn group relative text-[10px] tracking-[0.4em] uppercase font-bold text-[#34041A]/40 hover:text-[#34041A] transition-all duration-700 pb-2 cursor-pointer"
            data-filter={cat}
          >
            {cat}
            <span class="absolute bottom-0 left-0 w-0 h-[1.5px] bg-[#8C7355] transition-all duration-700 group-hover:w-full"></span>
            <span class="active-indicator absolute bottom-0 left-0 w-full h-[1.5px] bg-[#34041A] scale-x-0 transition-transform duration-700 origin-left"></span>
          </button>
        ))}
      </nav>
    </div>

    <div class="gallery-grid grid grid-cols-1 md:grid-cols-3 gap-8 auto-rows-[350px] md:auto-rows-[450px]">
      {galleryItems.map((item) => (
        <div 
          class="gallery-item group relative overflow-hidden bg-[#34041A]/5 transition-all duration-1000 ease-[cubic-bezier(0.23,1,0.32,1)]"
          data-category={item.category}
          class:list={[item.span]}
        >
          <div class="absolute inset-0 z-20 opacity-0 group-hover:opacity-100 transition-all duration-1000 pointer-events-none p-6">
             <div class="absolute top-6 left-6 w-6 h-6 border-t border-l border-white/40 group-hover:m-2 transition-all duration-700"></div>
             <div class="absolute bottom-6 right-6 w-6 h-6 border-b border-r border-white/40 group-hover:m-2 transition-all duration-700"></div>
          </div>

          <img 
            src={item.image} 
            alt={item.title}
            class="w-full h-full object-cover grayscale-[40%] group-hover:grayscale-0 group-hover:scale-110 transition-all duration-[2.5s] ease-out"
            loading="lazy"
          />

          <div class="absolute inset-0 bg-gradient-to-t from-[#34041A]/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-1000 z-10 flex flex-col justify-end p-10">
            <p class="text-[#F9F2E7]/60 text-[10px] tracking-[0.4em] uppercase mb-3 translate-y-6 group-hover:translate-y-0 transition-transform duration-1000">
              {item.category}
            </p>
            <h3 class="text-[#F9F2E7] text-2xl font-serif italic tracking-wide translate-y-6 group-hover:translate-y-0 transition-transform duration-1000 delay-100">
              {item.title}
            </h3>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  /* 初始加载动效 */
  .reveal-up {
    opacity: 0;
    transform: translateY(30px);
    transition: all 1.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-up.active {
    opacity: 1;
    transform: translateY(0);
  }

  /* 过滤动画：通过缩放和透明度处理 */
  .gallery-item.is-hidden {
    opacity: 0;
    transform: scale(0.9);
    pointer-events: none;
  }

  /* 滤镜激活样式 */
  .filter-btn.is-active {
    color: #34041A !important;
  }
  .filter-btn.is-active .active-indicator {
    scale-x: 1;
  }
</style>

<script>
  function initGallery() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const galleryItems = document.querySelectorAll<HTMLElement>('.gallery-item');

    // 默认激活 "ALL"
    const allBtn = document.querySelector('[data-filter="ALL"]');
    if (allBtn) allBtn.classList.add('is-active');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');

        // 切换按钮状态
        filterBtns.forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');

        // 执行过滤
        galleryItems.forEach(item => {
          const category = item.getAttribute('data-category');
          
          if (filter === 'ALL' || category === filter) {
            // 显示
            item.style.display = 'block';
            // 微延时确保 display: block 生效后触发 opacity 动画
            requestAnimationFrame(() => {
              item.classList.remove('is-hidden');
            });
          } else {
            // 隐藏
            item.classList.add('is-hidden');
            // 等待动画结束后隐藏布局占用
            setTimeout(() => {
              if (item.classList.contains('is-hidden')) {
                item.style.display = 'none';
              }
            }, 600);
          }
        });
      });
    });

    // 基础曝光动效
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-up').forEach(el => observer.observe(el));
  }

  document.addEventListener('astro:page-load', initGallery);
  initGallery();
</script>