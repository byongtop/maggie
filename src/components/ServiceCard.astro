---
/**
 * ServiceCard.astro - 高级服务展示卡片 (ROSE IS ROSE)
 * 核心色值：#F9F2E7 (背景), #34041A (深红), #8C7355 (金棕)
 */
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string; // 支持 SVG 字符串或 Emoji
  step?: string; // 可选的阶段编号
}

const { title, description, href, icon, step = "01" } = Astro.props;
---

<a 
  href={href} 
  class="group block relative p-10 md:p-12 bg-white border border-[#34041A]/5 transition-all duration-700 hover:z-10"
>
  <div class="absolute inset-0 bg-[#F9F2E7] scale-y-0 group-hover:scale-y-100 transition-transform duration-700 origin-bottom ease-[cubic-bezier(0.19,1,0.22,1)]"></div>

  <div class="relative z-10 flex flex-col h-full">
    <div class="flex justify-between items-start mb-12">
      <span class="font-mono text-[10px] tracking-[0.4em] text-[#8C7355] opacity-50 group-hover:opacity-100 transition-opacity">
        MOD_{step}
      </span>
      <span class="text-4xl font-serif text-[#34041A]/20 group-hover:text-[#34041A] group-hover:-translate-y-2 transition-all duration-700 ease-out">
        {icon}
      </span>
    </div>
    
    <div class="flex-grow">
      <h3 class="text-2xl md:text-3xl font-serif text-[#34041A] mb-6 tracking-tight leading-none group-hover:italic transition-all duration-500">
        {title}
      </h3>
      <p class="text-[#3C3835]/70 font-light text-sm md:text-base leading-relaxed mb-12 max-w-[90%]">
        {description}
      </p>
    </div>
    
    <div class="flex items-center text-[#8C7355] text-[10px] tracking-[0.4em] font-bold uppercase overflow-hidden">
      <span class="relative">
        <span class="inline-block transition-transform duration-500 group-hover:-translate-y-full">Explore Service</span>
        <span class="absolute top-0 left-0 inline-block translate-y-full transition-transform duration-500 group-hover:translate-y-0 text-[#34041A]">Explore Service</span>
      </span>
      <div class="ml-4 flex-grow h-[0.5px] bg-[#8C7355]/20 relative">
        <div class="absolute inset-0 bg-[#34041A] scale-x-0 group-hover:scale-x-100 transition-transform duration-700 origin-left"></div>
      </div>
    </div>
  </div>

  <div class="absolute inset-0 border border-[#34041A]/0 group-hover:border-[#34041A]/10 transition-colors duration-700"></div>
</a>

<style>
  /* 针对中文字体优化 */
  h3, p {
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
</style>