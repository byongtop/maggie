---
const works = [
  { src: 'https://images.unsplash.com/photo-1542038784456-1ea8e935640e', w: 1200, h: 1600, title: 'Abstract Light', category: 'Portrait' },
  { src: 'https://images.unsplash.com/photo-1493863641943-9b68992a8d07', w: 1600, h: 1067, title: 'Urban Silence', category: 'Architecture' },
  { src: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e', w: 1200, h: 1500, title: 'Golden Hour', category: 'Nature' },
  { src: 'https://images.unsplash.com/photo-1470770841072-f978cf4d019e', w: 1200, h: 1200, title: 'Minimal Geometry', category: 'Studio' },
  { src: 'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f', w: 1600, h: 1200, title: 'The Seeker', category: 'Travel' },
  { src: 'https://images.unsplash.com/photo-1505330622279-bf7d7fc918f4', w: 1600, h: 1200, title: 'Studio Still Life', category: 'Still Life' },
  { src: 'https://images.unsplash.com/photo-1494438639946-1ebd1d20bf85', w: 1600, h: 1200, title: 'Geometric Silence', category: 'Studio' },
  { src: 'https://images.unsplash.com/photo-1452421822248-d4c2b47f0c81', w: 1600, h: 1200, title: 'Traveler Memories', category: 'Travel' },
];
---

<section class="py-32 px-6 md:px-12 bg-brand-bg">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col mb-24">
      <span class="text-brand-contrast text-xs tracking-[0.5em] uppercase mb-4 italic">— Portfolio Index</span>
      <h2 class="text-4xl md:text-7xl font-light text-brand-accent tracking-tighter leading-none">
        SELECTED <br />
        <span class="ml-12 md:ml-24 italic">COLLECTIONS</span>
      </h2>
    </div>

    <div id="gallery" class="pswp-gallery grid grid-cols-1 md:grid-cols-12 gap-y-24 md:gap-x-12 items-start">
      {works.map((work, index) => (
        <div class="portfolio-item reveal-item relative group md:col-span-6 lg:col-span-4">
          <a 
            href={work.src} 
            data-pswp-width={work.w} 
            data-pswp-height={work.h} 
            class="block overflow-hidden relative aspect-[4/5] bg-brand-muted"
          >
            <div class="absolute inset-0 bg-brand-contrast/10 opacity-0 group-hover:opacity-100 transition-opacity duration-700 z-10"></div>
            <img 
              src={work.src} 
              alt={work.title}
              class="portfolio-img w-full h-full object-cover grayscale-[40%] group-hover:grayscale-0 transition-all duration-[1.5s] ease-out scale-110 group-hover:scale-100"
            />
          </a>

          <div class="mt-8 flex flex-col items-start space-y-2 group-hover:translate-x-4 transition-transform duration-500">
            <span class="text-[10px] text-brand-accent tracking-[0.3em] uppercase">{work.category}</span>
            <h3 class="text-brand-contrast text-xl font-light tracking-wide">{work.title}</h3>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* 在 v4 中，我们可以直接在 style 标签里写更复杂的非对称逻辑 */
  @media (min-width: 768px) {
    /* 每 3 张图为一个排版周期 */
    .portfolio-item:nth-child(3n+1) { grid-column: span 8 / span 8; }
    .portfolio-item:nth-child(3n+2) { grid-column: span 4 / span 4; margin-top: 12rem; }
    .portfolio-item:nth-child(3n+3) { grid-column: span 6 / span 6; margin-top: -6rem; }
    
    /* 大屏下更精细的比例 */
    @media (min-width: 1024px) {
        .portfolio-item:nth-child(3n+1) { grid-column: span 7 / span 7; }
        .portfolio-item:nth-child(3n+2) { grid-column: span 5 / span 5; }
        .portfolio-item:nth-child(3n+3) { grid-column: span 4 / span 4; }
    }
  }

  .reveal-item {
    opacity: 0;
    transform: translateY(40px);
    transition: all 1s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .reveal-item.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#gallery',
    children: 'a',
    pswpModule: () => import('photoswipe'),
  });
  lightbox.init();

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('active');
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal-item').forEach(el => observer.observe(el));
</script>