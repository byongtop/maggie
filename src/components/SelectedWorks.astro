---
/**
 * Gallery.astro - 紧凑画廊艺术版
 * 1. 移除松散留白，采用紧凑的 Grid 布局
 * 2. 增强取景框与边框的联系，形成“底片切片”感
 * 3. PhotoSwipe v5 高级集成
 */
const works = [
  { src: 'https://images.unsplash.com/photo-1542038784456-1ea8e935640e', w: 1200, h: 1600, title: 'Abstract Light', category: 'Portrait', span: 'md:col-span-8' },
  { src: 'https://images.unsplash.com/photo-1493863641943-9b68992a8d07', w: 1600, h: 1067, title: 'Urban Silence', category: 'Architecture', span: 'md:col-span-4' },
  { src: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e', w: 1200, h: 1500, title: 'Golden Hour', category: 'Nature', span: 'md:col-span-4' },
  { src: 'https://images.unsplash.com/photo-1470770841072-f978cf4d019e', w: 1200, h: 1200, title: 'Minimal Geometry', category: 'Studio', span: 'md:col-span-4' },
  { src: 'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f', w: 1600, h: 1200, title: 'The Seeker', category: 'Travel', span: 'md:col-span-4' },
  { src: 'https://images.unsplash.com/photo-1505330622279-bf7d7fc918f4', w: 1600, h: 1200, title: 'Studio Still Life', category: 'Still Life', span: 'md:col-span-6' },
  { src: 'https://images.unsplash.com/photo-1494438639946-1ebd1d20bf85', w: 1600, h: 1200, title: 'Geometric Silence', category: 'Studio', span: 'md:col-span-6' },
  { src: 'https://images.unsplash.com/photo-1452421822248-d4c2b47f0c81', w: 1600, h: 1200, title: 'Traveler Memories', category: 'Travel', span: 'md:col-span-12' },
];
---

<section class="py-20 bg-brand-bg px-4 md:px-10">
  <div class="max-w-7xl mx-auto ">
    
    <div class="mb-16 flex items-end justify-between border-b-2 border-brand-accent pb-6">
      <h2 class="text-4xl md:text-6xl font-serif font-black text-brand-accent tracking-tighter uppercase leading-none">
        Selected <span class="italic font-light">Archive</span>
      </h2>
      <span class="text-brand-accent text-[10px] tracking-[0.4em] font-mono hidden md:block">INDEX: PORTFOLIO_V2.0</span>
    </div>

    <div id="gallery" class="max-w-7xl mx-auto pswp-gallery grid grid-cols-1 md:grid-cols-12 gap-4">
      {works.map((work, index) => (
        <div class={`portfolio-item reveal-item relative group overflow-hidden ${work.span}`}>
          
          <a 
            href={work.src} 
            data-pswp-width={work.w} 
            data-pswp-height={work.h} 
            target="_blank"
            class="block relative aspect-square md:aspect-video w-full h-full bg-brand-dark overflow-hidden"
          >
            <div class="absolute inset-0 z-30 pointer-events-none p-6 md:p-10 opacity-60 group-hover:opacity-100 transition-opacity">
              <div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-brand-on-dark transition-all duration-500 group-hover:m-2"></div>
              <div class="absolute top-0 right-0 w-8 h-8 border-t-2 border-r-2 border-brand-on-dark transition-all duration-500 group-hover:m-2"></div>
              <div class="absolute bottom-0 left-0 w-8 h-8 border-b-2 border-l-2 border-brand-on-dark transition-all duration-500 group-hover:m-2"></div>
              <div class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-brand-on-dark transition-all duration-500 group-hover:m-2"></div>
            </div>

            <div class="absolute top-6 left-8 z-30 overflow-hidden">
              <p class="text-[9px] font-mono text-brand-on-dark/50 uppercase tracking-widest bg-brand-accent/30 backdrop-blur-sm px-2 py-1 translate-x-[-110%] group-hover:translate-x-0 transition-transform duration-500">
                SCENE_{index + 1} / F2.8
              </p>
            </div>

            <img 
              src={work.src} 
              alt={work.title}
              class="portfolio-img w-full h-full object-cover grayscale-[30%] group-hover:grayscale-0 group-hover:scale-105 transition-all duration-1000"
            />

            <div class="absolute inset-0 bg-brand-accent/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-20 flex flex-col justify-end p-8">
               <span class="text-[10px] text-brand-on-dark tracking-[0.3em] uppercase mb-1">{work.category}</span>
               <h3 class="text-brand-on-dark text-xl font-serif italic">{work.title}</h3>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  /* 引入 PhotoSwipe 样式 */
  @import "photoswipe/dist/photoswipe.css";

  .reveal-item {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-item.active {
    opacity: 1;
    transform: translateY(0);
  }

  /* 适配品牌色 */
  .pswp {
    --pswp-bg: #34041A;
  }
</style>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';

  function initGallery() {
    const lightbox = new PhotoSwipeLightbox({
      gallery: '#gallery',
      children: 'a',
      pswpModule: () => import('photoswipe'),
    });
    lightbox.init();

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('active');
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-item').forEach(el => observer.observe(el));
  }

  initGallery();
  document.addEventListener('astro:page-load', initGallery);
</script>