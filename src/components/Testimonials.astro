---
/**
 * Testimonials.astro - 字体微调精致版
 * 修复：缩小了 quote 字体，增强了空气感和呼吸感
 */
const testimonials = [
  {
    quote: "Maggie 不仅仅是在拍照，她捕捉到了我连自己都没察觉到的那份自信。在社交软件上使用这组照片后，我感受到了前所未有的正向反馈。",
    author: "ZHAN LIU",
    location: "Tech Entrepreneur, Shanghai"
  },
  {
    quote: "光影的处理极具电影感。以前我觉得面对镜头很尴尬，但在 Maggie 的引导下，一切都变得自然而有张力。这是一次审视自我的过程。",
    author: "ELENA WANG",
    location: "Creative Producer"
  },
  {
    quote: "在这个看脸的时代，Maggie 帮我拍出了‘脸’之后的故事。那种磁场和质感是任何滤镜都无法模拟的，专业度满分。",
    author: "KEVIN GAO",
    location: "Finance Director"
  }
];
---

<section class="py-24 md:py-32 px-8 md:px-20 bg-brand-dark relative overflow-hidden text-brand-on-dark">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none select-none">
    <span class="text-[80px] md:text-[120px] font-serif italic text-brand-on-dark/[0.09] leading-none tracking-[0.2em] uppercase">
      Testimonials
    </span>
  </div>

  <div class="max-w-7xl mx-auto text-center relative z-20">
    <div class="font-serif text-4xl md:text-5xl text-brand-muted opacity-20 mb-10 select-none">
      “
    </div>

    <div class="swiper testimonialSwiper">
      <div class="swiper-wrapper">
        {testimonials.map((item) => (
          <div class="swiper-slide flex flex-col items-center">
            {/* 核心修改：字号缩小至 text-base 到 text-xl，增加 tracking-wide 和 leading-relaxed */}
            <blockquote class="text-base md:text-lg lg:text-xl font-serif font-light leading-[2] italic mb-16 tracking-widest max-w-2xl mx-auto opacity-90 text-center">                
              {item.quote}
            </blockquote>
            
            <div class="flex flex-col items-center">
              <div class="w-8 h-[1px] bg-brand-muted/30 mb-6"></div>
              <cite class="not-italic text-[10px] tracking-[0.5em] text-brand-on-dark font-medium uppercase mb-2">
                {item.author}
              </cite>
              <span class="text-[8px] tracking-[0.3em] text-brand-on-dark/30 uppercase font-sans">
                {item.location}
              </span>
            </div>
          </div>
        ))}
      </div>

      <div class="flex justify-center items-center space-x-10 mt-16">
        <button class="ts-prev text-brand-muted hover:text-brand-on-dark transition-all duration-500 cursor-pointer p-2">
          <svg width="30" height="10" viewBox="0 0 40 12" fill="none" class="stroke-current opacity-40 hover:opacity-100">
            <path d="M40 6H1M1 6L6 1M1 6L6 11" stroke-width="1"/>
          </svg>
        </button>
        
        <div class="ts-pagination !w-auto !relative text-[9px] tracking-[0.4em] text-brand-on-dark/20 font-sans"></div>
        
        <button class="ts-next text-brand-muted hover:text-brand-on-dark transition-all duration-500 cursor-pointer p-2">
          <svg width="30" height="10" viewBox="0 0 40 12" fill="none" class="stroke-current opacity-40 hover:opacity-100">
            <path d="M0 6H39M39 6L34 1M39 6L34 11" stroke-width="1"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(140,115,85,0.05)_0%,transparent_70%)] pointer-events-none"></div>
</section>

<script>
  import Swiper from 'swiper';
  import { Navigation, Pagination, Autoplay, EffectFade } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/effect-fade';

  function initTestimonials() {
    new Swiper('.testimonialSwiper', {
      modules: [Navigation, Pagination, Autoplay, EffectFade],
      effect: 'fade',
      fadeEffect: { crossFade: true },
      loop: true,
      speed: 2000,
      autoplay: {
        delay: 6000,
        disableOnInteraction: false,
      },
      navigation: {
        nextEl: '.ts-next',
        prevEl: '.ts-prev',
      },
      pagination: {
        el: '.ts-pagination',
        type: 'fraction',
        formatFractionCurrent: (number) => number.toString().padStart(2, '0'),
        formatFractionTotal: (number) => number.toString().padStart(2, '0'),
      },
    });
  }

  initTestimonials();
  document.addEventListener('astro:page-load', initTestimonials);
</script>

<style is:global>
  .ts-pagination .swiper-pagination-current {
    color: #F9F2E7;
    font-weight: 400;
  }
  
  .testimonialSwiper blockquote {
    -webkit-font-smoothing: antialiased;
    word-break: break-word;
    /* 增加文本渲染的优雅度 */
    text-rendering: optimizeLegibility;
  }

  .testimonialSwiper .swiper-slide-active blockquote {
    animation: testimonialReveal 3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes testimonialReveal {
    from {
      filter: blur(8px);
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      filter: blur(0);
      opacity: 0.9;
      transform: translateY(0);
    }
  }
</style>