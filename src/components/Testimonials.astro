---
/**
 * Testimonials.astro - 深色情绪版
 * 视觉风格：深色背景 (brand-contrast)、中轴对称、柔和反差
 */
const testimonials = [
  {
    quote: "Capturing our wedding wasn't just about photos; it was about preserving the atmosphere we felt. The results were beyond our imagination—pure, raw, and timeless.",
    author: "EMILY & JAMES",
    location: "London, UK"
  },
  {
    quote: "The attention to detail and the way light is handled is sheer artistry. A true minimalist who understands that sometimes, less is infinitely more.",
    author: "MARCUS CHEN",
    location: "Creative Director, VOGUE"
  },
  {
    quote: "Professional, discreet, and incredibly talented. They managed to capture the most intimate moments without us even noticing the camera.",
    author: "SARAH JENKINS",
    location: "Founder, Bloom Studio"
  }
];
---

<section class="py-40 px-6 md:px-12 bg-brand-contrast relative overflow-hidden">
  <div class="max-w-4xl mx-auto text-center relative z-20">
    
    <div class="text-brand-bg/5 text-[15rem] font-serif absolute top-0 left-1/2 -translate-x-1/2 select-none pointer-events-none">
      “
    </div>

    <div class="swiper testimonialSwiper pt-10">
      <div class="swiper-wrapper">
        {testimonials.map((item) => (
          <div class="swiper-slide flex flex-col items-center">
            <blockquote class="text-2xl md:text-3xl lg:text-4xl font-light text-brand-bg leading-relaxed italic mb-12 tracking-tight">
              "{item.quote}"
            </blockquote>
            
            <div class="flex flex-col items-center space-y-2">
              <div class="w-8 h-[1px] bg-brand-accent mb-4"></div>
              <cite class="not-italic text-sm tracking-[0.4em] text-brand-bg font-medium uppercase">
                {item.author}
              </cite>
              <span class="text-[10px] tracking-[0.2em] text-brand-bg/40 uppercase">
                {item.location}
              </span>
            </div>
          </div>
        ))}
      </div>

      <div class="flex justify-center items-center space-x-8 mt-16">
        <button class="ts-prev text-brand-accent hover:text-brand-bg transition-colors cursor-none p-2">
          <svg width="30" height="15" viewBox="0 0 30 15" fill="none" class="stroke-current"><path d="M30 7.5H1M1 7.5L7.5 1M1 7.5L7.5 14" stroke-width="1"/></svg>
        </button>
        <div class="ts-pagination !w-auto !relative text-[10px] tracking-widest text-brand-bg/30 font-serif italic"></div>
        <button class="ts-next text-brand-accent hover:text-brand-bg transition-colors cursor-none p-2">
          <svg width="30" height="15" viewBox="0 0 30 15" fill="none" class="stroke-current"><path d="M0 7.5H29M29 7.5L22.5 1M29 7.5L22.5 14" stroke-width="1"/></svg>
        </button>
      </div>
    </div>
  </div>

  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-[radial-gradient(circle_at_center,rgba(140,115,85,0.05)_0%,transparent_70%)] pointer-events-none"></div>
</section>

<script>
  import Swiper from 'swiper';
  import { Navigation, Pagination, Autoplay, EffectFade } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/effect-fade';

  new Swiper('.testimonialSwiper', {
    modules: [Navigation, Pagination, Autoplay, EffectFade],
    effect: 'fade',
    fadeEffect: { crossFade: true },
    loop: true,
    speed: 1500, // 稍微调慢一点，增加沉稳感
    autoplay: {
      delay: 5000,
      disableOnInteraction: false,
    },
    navigation: {
      nextEl: '.ts-next',
      prevEl: '.ts-prev',
    },
    pagination: {
      el: '.ts-pagination',
      type: 'fraction',
      formatFractionCurrent: (number) => number.toString().padStart(2, '0'),
      formatFractionTotal: (number) => number.toString().padStart(2, '0'),
    },
  });
</script>

<style is:global>
  /* 针对深色背景的分页符高亮 */
  .ts-pagination .swiper-pagination-current {
    color: #8C7355; /* brand-accent */
    font-weight: 500;
  }
  
  /* 文字模糊进入动画：在深色背景下更有“浮现”感 */
  .testimonialSwiper .swiper-slide-active blockquote {
    animation: textBlurInLight 2s ease-out forwards;
  }

  @keyframes textBlurInLight {
    from {
      filter: blur(15px);
      opacity: 0;
      transform: translateY(15px);
    }
    to {
      filter: blur(0);
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>