---
/**
 * Testimonials.astro - 字体微调精致版 (ROSE IS ROSE)
 * 核心设计：小字号、高行间距、电影感 Fade 转场
 * 色值：#34041A (背景), #F9F2E7 (文字), #8C7355 (强调)
 */
const testimonials = [
{
  quote: "Honestly I was pretty nervous going in. Never really done anything like this before. But Maggie just has this way of making you feel comfortable. Ended up having fun which I did NOT expect. Photos came out great—actually look like me but better?",
  author: "SAM C.",
  location: "Product Designer, Sydney"
},
{
  quote: "The thing that got me was the attention to detail. Like she noticed how I tilt my head when I'm thinking and worked with that instead of against it. Little things like that make all the difference. Really happy with how these turned out.",
  author: "JESS T.",
  location: "Marketing, Bondi"
},
{
  quote: "I've avoided professional photos for years because I always feel awkward. Maggie gets that. She talks you through it, shows you what works, and somehow makes the whole thing feel like a conversation. Would recommend to anyone who's camera-shy.",
  author: "MARC L.",
  location: "Founder, Pyrmont"
}
];
---

<section class="py-24 md:py-40 px-8 md:px-20 bg-[#34041A] relative overflow-hidden text-[#F9F2E7]">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none select-none z-0">
    <span class="text-[10vw] md:text-[12vw] font-serif italic text-[#F9F2E7]/[0.04] leading-none tracking-[0.2em] uppercase whitespace-nowrap">
      Testimonials
    </span>
  </div>

  <div class="max-w-5xl mx-auto text-center relative z-20">
    <div class="font-serif text-5xl md:text-6xl text-[#8C7355] opacity-30 mb-12 select-none leading-none">
      “
    </div>

    <div class="swiper testimonialSwiper">
      <div class="swiper-wrapper">
        {testimonials.map((item) => (
          <div class="swiper-slide flex flex-col items-center">
            <blockquote class="text-[15px] md:text-[17px] lg:text-[19px] font-serif font-light leading-[2.4] italic mb-16 tracking-[0.12em] max-w-2xl mx-auto opacity-80 text-center px-4 md:px-0">                
              {item.quote}
            </blockquote>
            
            <div class="flex flex-col items-center">
              <div class="w-10 h-[0.5px] bg-[#8C7355]/40 mb-8"></div>
              <cite class="not-italic text-[10px] tracking-[0.5em] text-[#F9F2E7] font-bold uppercase mb-3">
                {item.author}
              </cite>
              <span class="text-[9px] tracking-[0.3em] text-[#8C7355] uppercase font-sans font-medium">
                {item.location}
              </span>
            </div>
          </div>
        ))}
      </div>

      <div class="flex justify-center items-center space-x-12 mt-20">
        <button class="ts-prev group cursor-pointer p-2 outline-none">
          <svg width="45" height="12" viewBox="0 0 45 12" fill="none" class="stroke-[#F9F2E7] opacity-30 group-hover:opacity-100 group-hover:-translate-x-2 transition-all duration-500">
            <path d="M45 6H1M1 6L7 1M1 6L7 11" stroke-width="0.75"/>
          </svg>
        </button>
        
        <div class="ts-pagination !w-auto !relative text-[10px] tracking-[0.4em] text-[#F9F2E7]/20 font-mono"></div>
        
        <button class="ts-next group cursor-pointer p-2 outline-none">
          <svg width="45" height="12" viewBox="0 0 45 12" fill="none" class="stroke-[#F9F2E7] opacity-30 group-hover:opacity-100 group-hover:translate-x-2 transition-all duration-500">
            <path d="M0 6H44M44 6L38 1M44 6L38 11" stroke-width="0.75"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(140,115,85,0.08)_0%,transparent_75%)] pointer-events-none"></div>
</section>

<style is:global>
  /* Swiper 分页符样式定制 */
  .ts-pagination .swiper-pagination-current {
    color: #8C7355;
    font-weight: bold;
  }
  
  .testimonialSwiper blockquote {
    -webkit-font-smoothing: antialiased;
    word-break: break-word;
    text-rendering: optimizeLegibility;
  }

  /* 入场动画：模糊 -> 清晰 + 位移 */
  .testimonialSwiper .swiper-slide-active blockquote {
    animation: testimonialReveal 2.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes testimonialReveal {
    from {
      filter: blur(10px);
      opacity: 0;
      transform: translateY(15px);
    }
    to {
      filter: blur(0);
      opacity: 0.85;
      transform: translateY(0);
    }
  }

  /* 针对 Swiper Fade 模式的层级修正 */
  .testimonialSwiper .swiper-slide {
    pointer-events: none;
  }
  .testimonialSwiper .swiper-slide-active {
    pointer-events: auto;
  }
</style>

<script>
  import Swiper from 'swiper';
  import { Navigation, Pagination, Autoplay, EffectFade } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/effect-fade';

  function initTestimonials() {
    new Swiper('.testimonialSwiper', {
      modules: [Navigation, Pagination, Autoplay, EffectFade],
      effect: 'fade',
      fadeEffect: { crossFade: true },
      loop: true,
      speed: 1500, // 平滑转场
      autoplay: {
        delay: 8000, // 给用户足够的时间阅读精细的小字
        disableOnInteraction: false,
      },
      navigation: {
        nextEl: '.ts-next',
        prevEl: '.ts-prev',
      },
      pagination: {
        el: '.ts-pagination',
        type: 'fraction',
        formatFractionCurrent: (number) => number.toString().padStart(2, '0'),
        formatFractionTotal: (number) => number.toString().padStart(2, '0'),
      },
    });
  }

  // 确保在 Astro 的不同生命周期中正确初始化
  document.addEventListener('astro:page-load', initTestimonials);
  initTestimonials();
</script>