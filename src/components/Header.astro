      <span class="text-xl md:text-xl font-serif font-bold tracking-tight text-[#F9F2E7]">
        ROSE
      </span>
      <span class="mx-2 text-[9px] tracking-[0.4em] text-[#F9F2E7]/70 font-mono">
        IS
      </span>
      <span class="text-xl md:text-xl font-serif font-light italic text-[#F9F2E7]/95">
        ROSE
      </span>
