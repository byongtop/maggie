        class="hamburger-line w-8 h-[1px] bg-[#F9F2E7] transition-all duration-500"
      ></span>
      <span
        class="hamburger-line w-5 h-[1px] bg-[#F9F2E7] transition-all duration-500"
      ></span>
      <span
        class="hamburger-line w-8 h-[1px] bg-[#F9F2E7] transition-all duration-500"
      ></span>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="fixed inset-0 bg-[#34041A] flex-col pt-32 px-12 overflow-y-auto transition-transform duration-700 ease-[cubic-bezier(0.19,1,0.22,1)] z-[999] lg:hidden"
  >
    <!-- 修复关闭按钮：使用更具体的类名，避免被CSS覆盖 -->
    <button
      id="mobile-menu-close"
      class="fixed top-6 right-6 w-12 h-12 flex items-center justify-center text-[#F9F2E7] hover:text-[#8C7355] transition-colors z-[1001] bg-[#34041A] border border-[#F9F2E7]/20 rounded-full hover:bg-[#F9F2E7] hover:text-[#34041A] group"
      aria-label="Close Menu"
      style="display: flex !important;"
    >
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="transition-transform group-hover:rotate-90 duration-300"
      >
        <path
          d="M18 6L6 18M6 6L18 18"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"></path>
      </svg>
    </button>

    <nav class="flex flex-col space-y-6">
      {
        navLinks.map((link) => (
          <div class="border-b border-[#F9F2E7]/5 py-4">
            <div class="flex items-center justify-between">
              <a
                href={link.href}
                class="text-4xl font-serif tracking-widest text-[#F9F2E7] uppercase font-light italic"
              >
                {link.name}
              </a>
              {link.children && (
                <button class="submenu-trigger text-[#F9F2E7] text-2xl p-2 opacity-40">
                  ＋
                </button>
              )}
            </div>

            {link.children && (
              <div class="mobile-submenu overflow-hidden max-h-0 opacity-0 transition-all duration-700 ease-in-out">
                <div class="flex flex-col space-y-5 mt-8 ml-2 border-l border-[#8C7355]/30 pl-8 pb-4">
                  {link.children.map((child) => (
                    <a
                      href={child.href}
                      class="text-[11px] tracking-[0.4em] uppercase font-bold text-[#F9F2E7]/40"
                    >
                      {child.name}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))
      }
      <a
        href="/booking"
        class="mt-16 bg-[#F9F2E7] text-[#34041A] py-6 text-center text-xs tracking-[0.6em] font-bold uppercase hover:bg-opacity-90 transition-all"
      >
        START YOUR STORY
      </a>
    </nav>
  </div>
</header>

<style>
  /* 滚动后的样式：强制应用深红背景 */
  #main-header.scrolled {
    background-color: #34041a !important;
    border-color: rgba(249, 242, 231, 0.1) !important;
  }

  /* 汉堡菜单动画 */
  #menu-toggle.open .hamburger-line:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
    width: 2rem;
  }
  #menu-toggle.open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  #menu-toggle.open .hamburger-line:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
    width: 2rem;
  }

  /* 移动端菜单 - 完全重写，不使用内联类 */
  #mobile-menu {
    position: fixed !important;
    inset: 0 !important;
    background-color: #34041a !important;
    padding-top: 8rem !important;
    padding-left: 3rem !important;
    padding-right: 3rem !important;
    overflow-y: auto !important;
    z-index: 999 !important;

    /* 隐藏状态 */
    display: none !important;
    transform: none !important;
    transition: none !important;
  }

  /* 移动端显示逻辑 - 只使用 active 类控制显示隐藏 */
  @media (max-width: 1023px) {
    #mobile-menu.active {
      display: flex !important;
    }
  }

  @media (min-width: 1024px) {
    #mobile-menu {
      display: none !important;
    }
    #mobile-menu.active {
      display: none !important;
    }
  }

  /* 子菜单展开 */
  .mobile-submenu.open {
    max-height: 800px;
    opacity: 1;
  }

  /* 关闭按钮样式 */
  #mobile-menu-close {
    /* 确保关闭按钮始终可见 */
    display: flex !important;
    position: fixed !important;
    top: 1.5rem !important;
    right: 1.5rem !important;
    width: 3rem !important;
    height: 3rem !important;
    background-color: #34041a !important;
    border: 1px solid rgba(249, 242, 231, 0.2) !important;
    border-radius: 9999px !important;
    z-index: 1001 !important;
    cursor: pointer !important;
  }

  /* 悬停效果 */
  #mobile-menu-close:hover {
    background-color: #f9f2e7 !important;
    border-color: #f9f2e7 !important;
  }

  #mobile-menu-close:hover svg {
    color: #34041a !important;
  }

  /* 确保移动端菜单激活时关闭按钮显示 */
  #mobile-menu.active #mobile-menu-close {
    display: flex !important;
  }
</style>

<script>
  function initHeader() {
    const header = document.getElementById("main-header");
    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const closeButton = document.getElementById("mobile-menu-close");

    if (!header || !toggle || !menu) {
      console.error("Required header elements not found");
      return;
    }

    console.log("Header initialized", { header, toggle, menu, closeButton });

    const isTransparentConfig =
      header.getAttribute("data-transparent") === "true";

    // 统一的关闭菜单函数
    const closeMenu = () => {
      menu.classList.remove("active");
      toggle.classList.remove("open");
      document.body.style.overflow = "";
      console.log("Menu closed");
    };

    // 统一的打开菜单函数
    const openMenu = () => {
      menu.classList.add("active");
      toggle.classList.add("open");
      document.body.style.overflow = "hidden";
      console.log("Menu opened");
    };

    // 1. 处理滚动逻辑
    const handleScroll = () => {
      if (window.scrollY > 50) {
        header.classList.add("scrolled");
        if (isTransparentConfig) {
          header.classList.remove("bg-transparent", "border-transparent");
          header.classList.add("bg-[#34041A]");
        }
      } else {
        header.classList.remove("scrolled");
        if (isTransparentConfig) {
          header.classList.remove("bg-[#34041A]");
          header.classList.add("bg-transparent", "border-transparent");
        }
      }
    };

    window.addEventListener("scroll", handleScroll);
    handleScroll();

    // 2. 移动端菜单开关（汉堡按钮）
    toggle.onclick = (e) => {
      e.preventDefault();
      e.stopPropagation();

      console.log("Menu toggle clicked!");
      console.log("Before toggle - menu classes:", menu.className);

      const isOpen = menu.classList.contains("active");

      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }

      console.log("After toggle - menu classes:", menu.className);
      console.log("Menu display style:", window.getComputedStyle(menu).display);
    };

    // 3. 关闭按钮事件
    if (closeButton) {
      closeButton.onclick = (e) => {
        e.preventDefault();
        e.stopPropagation();
        console.log("Close button clicked");
        closeMenu();
      };
    }

    // 4. 移动端子菜单折叠
    document.querySelectorAll(".submenu-trigger").forEach((btn) => {
      btn.onclick = (e) => {
        e.preventDefault();
        e.stopPropagation();

        const submenu = btn.parentElement?.nextElementSibling;
        if (submenu) {
          const isOpen = submenu.classList.contains("open");
          if (!isOpen) {
            submenu.classList.add("open");
            btn.textContent = "－";
          } else {
            submenu.classList.remove("open");
            btn.textContent = "＋";
          }
        }
      };
    });

    // 5. 点击链接后自动关闭菜单
    menu.querySelectorAll("a").forEach((link) => {
      link.onclick = (e) => {
        // 不阻止默认行为，让链接正常跳转
        closeMenu();
      };
    });

    // 6. 点击菜单外部关闭
    document.addEventListener("click", (e) => {
      if (window.innerWidth <= 1023) {
        const isClickInside =
          menu.contains(e.target) ||
          toggle.contains(e.target) ||
          (closeButton && closeButton.contains(e.target));
        if (!isClickInside && menu.classList.contains("active")) {
          closeMenu();
        }
      }
    });

    // 7. ESC键关闭
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menu.classList.contains("active")) {
        closeMenu();
      }
    });
  }

  // 生命周期管理
  document.addEventListener("astro:page-load", initHeader);

  // 立即执行一次
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHeader);
  } else {
    initHeader();
  }
</script>
