---
/**
 * Header.astro — SPA Safe Production Version
 */

const pathname = Astro.url.pathname;
//const isHomePage = pathname === '/';
// 精确匹配需要透明背景的页面
const isTransparentPage = pathname === '/' || pathname.startsWith('/services/');

const navLinks = [
  { name: 'PORTFOLIO', href: '/portfolio' },
  { 
    name: 'SERVICES', 
    href: '/services',
    children: [
      { name: 'Sydney Dating Portraits', href: '/services/sydney-dating-photography' },
      { name: 'Dating Styling & Hair Sydney', href: '/services/dating-styling-sydney' },
      { name: 'Dating Wardrobe Consulting Sydney', href: '/services/dating-wardrobe-sydney' },
      { name: 'Dating Bio Writing Sydney', href: '/services/dating-bio-writing-sydney' },
      { name: 'Dating App Strategy Sydney', href: '/services/dating-app-strategy-sydney' }
    ]
  },
  { name: 'ABOUT', href: '/about' },
  { 
    name: 'BLOG', 
    href: '/blog',
    children: [
      { name: 'Photography Tips & Guides', href: '/blog/category/photography-tips-&-guides' },
      { name: 'Success Stories', href: '/blog/category/success-stories' },
      { name: 'Dating Insights', href: '/blog/category/dating-insights' },
      { name: 'Behind the Scenes', href: '/blog/category/behind-the-scenes' }
    ]
  },
  { name: 'CONTACT', href: '/contact' },
];

// 初始背景：首页或服务页面为透明，其他页面为深色
const initialBackground = isTransparentPage
  ? 'bg-transparent border-transparent'
  : 'bg-brand-dark border-brand-muted/20';
---

<header
  id="main-header"
  data-transparent={isTransparentPage}
  class={`fixed top-0 left-0 w-full z-[100] transition-all duration-700 border-b ${initialBackground}`}
>
  <div
    class="max-w-7xl mx-auto px-6 md:px-12 h-16 md:h-20 flex items-center justify-between relative z-[110]"
  >

    <!-- LOGO -->
    <a href="/" class="group flex flex-col items-start no-underline">
      <div class="flex items-baseline">
        <span class="text-2xl md:text-3xl font-serif font-semibold tracking-tight text-brand-on-dark">
          ROSE
        </span>
        <span class="mx-2 text-[10px] tracking-[0.3em] text-brand-on-dark/70">
          IS
        </span>
        <span class="text-2xl md:text-3xl font-serif font-light italic text-brand-on-dark/90">
          ROSE
        </span>
      </div>
      <div class="mt-1 flex items-center space-x-2">
        <span class="h-[0.5px] w-4 bg-brand-muted/60"></span>
        <span class="text-[8px] tracking-[0.5em] uppercase text-brand-on-dark/60">
          Identity & Narrative Portrait
        </span>
      </div>
    </a>

    <!-- DESKTOP NAV -->
    <nav class="hidden md:flex items-center space-x-10 h-full">
      {navLinks.map((link) => (
        <div class="relative h-full flex items-center group">
          <a
            href={link.href}
            class="text-[11px] tracking-[0.3em] font-semibold uppercase text-brand-on-dark hover:text-brand-muted transition"
          >
            {link.name}
            {link.children && <span class="ml-2 text-[7px] opacity-60">▼</span>}
          </a>

          {link.children && (
            <div class="absolute top-full left-1/2 -translate-x-1/2 w-80 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 pt-2">
              <div class="bg-brand-dark border border-brand-muted/20 shadow-xl py-4">
                {link.children.map((child) => (
                  <a
                    href={child.href}
                    class="block px-8 py-3 text-[10px] tracking-[0.2em] uppercase font-bold text-brand-on-dark/70 hover:text-white hover:bg-white/5 transition"
                  >
                    {child.name}
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      ))}

      <a
        href="/booking"
        class="px-8 py-2.5 border border-brand-on-dark/40 text-brand-on-dark text-[10px] tracking-[0.3em] font-bold hover:bg-brand-on-dark hover:text-brand-dark transition"
      >
        BOOKING
      </a>
    </nav>

    <!-- MOBILE TOGGLE -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col justify-center items-end space-y-1.5 p-2 z-[120]"
      aria-label="Toggle Menu"
    >
      <span class="hamburger-line w-6 h-[1.5px] bg-brand-on-dark transition"></span>
      <span class="hamburger-line w-6 h-[1.5px] bg-brand-on-dark transition"></span>
      <span class="hamburger-line w-6 h-[1.5px] bg-brand-on-dark transition"></span>
    </button>

  </div>

  <!-- MOBILE MENU -->
  <div
    id="mobile-menu"
    class="fixed inset-0 bg-brand-dark flex flex-col pt-32 px-10 overflow-y-auto translate-x-full transition-transform duration-500 z-[9999]"
  >
    <nav class="flex flex-col space-y-2">
      {navLinks.map((link) => (
        <div class="border-b border-brand-on-dark/5 py-4">
          <div class="flex items-center justify-between">
            <a href={link.href} class="text-3xl font-serif tracking-widest text-brand-on-dark uppercase font-bold">
              {link.name}
            </a>

            {link.children && (
              <button class="submenu-trigger text-brand-on-dark text-2xl">＋</button>
            )}
          </div>

          {link.children && (
            <div class="mobile-submenu overflow-hidden max-h-0 opacity-0 transition-all duration-500">
              <div class="flex flex-col space-y-4 mt-6 ml-4 border-l border-brand-on-dark/20 pl-6 pb-2">
                {link.children.map((child) => (
                  <a
                    href={child.href}
                    class="text-xs tracking-[0.3em] uppercase font-bold text-brand-on-dark/60"
                  >
                    {child.name}
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      ))}

      <a
        href="/booking"
        class="mt-12 text-sm tracking-[0.5em] bg-brand-on-dark text-brand-dark py-5 text-center font-bold uppercase"
      >
        Book Now
      </a>
    </nav>
  </div>
</header>

<style>
  #main-header.scrolled {
    background-color: var(--color-brand-accent);
    border-color: var(--color-brand-muted);
  }

  #mobile-menu.active {
    transform: translateX(0);
  }

  .hamburger-line.open:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .hamburger-line.open:nth-child(2) {
    opacity: 0;
  }

  .hamburger-line.open:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .mobile-submenu.open {
    max-height: 500px;
    opacity: 1;
    margin-top: 1rem;
  }
</style>

<script>
  if (!window.__HEADER_INITIALIZED__) {
    window.__HEADER_INITIALIZED__ = true;

    function setupHeader() {
      const header = document.getElementById('main-header');
      if (!header) return;

      const isTransparent = header.dataset.transparent === 'true';

      function handleScroll() {
        if (isTransparent) {
          // 透明页面：滚动超过 80px 才添加背景
          if (window.scrollY > 80) {
            header.classList.add('scrolled');
            header.classList.remove('bg-transparent', 'border-transparent');
          } else {
            header.classList.remove('scrolled');
            header.classList.add('bg-transparent', 'border-transparent');
          }
        } else {
          // 非透明页面：始终有背景
          header.classList.add('scrolled');
          header.classList.remove('bg-transparent', 'border-transparent');
        }
      }

      // 初始化
      handleScroll();
      
      // 监听滚动
      window.addEventListener('scroll', handleScroll);

      // 移动端菜单逻辑
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      const lines = document.querySelectorAll('.hamburger-line');
      
      if (toggle && menu) {
        toggle.onclick = () => {
          const active = menu.classList.toggle('active');
          lines.forEach(l => l.classList.toggle('open'));
          document.body.style.overflow = active ? 'hidden' : '';
        };
      }

      // 子菜单逻辑
      document.querySelectorAll('.submenu-trigger').forEach(btn => {
        btn.onclick = () => {
          const submenu = btn.parentElement.nextElementSibling;
          submenu?.classList.toggle('open');
        };
      });
    }

    document.addEventListener('astro:page-load', setupHeader);
    setupHeader();
  }
</script>