---
// Hero.astro
const slides = [
  { img: "/assets/images/hero/01.jpg", title: "SILENCE / 宁静", subtitle: "Captured in 2026, Iceland" },
  { img: "/assets/images/hero/02.jpg", title: "WHISPER / 微风", subtitle: "Captured in 2026, Sahara" },
  { img: "/assets/images/hero/03.jpg", title: "ETERNITY / 永恒", subtitle: "Captured in 2026, Tibet" },
];
---

<section class="relative h-screen w-full bg-brand-bg overflow-hidden">
  <div class="swiper heroSwiper h-full w-full">
    <div class="swiper-wrapper">
      {slides.map((slide) => (
        <div class="swiper-slide relative overflow-hidden">
          <div class="img-container h-full w-full">
            <img 
              src={slide.img} 
              class="h-full w-full object-cover grayscale-[20%] opacity-90" 
              alt={slide.title} 
            />
          </div>
<div class="absolute bottom-20 left-10 md:bottom-32 md:left-32 z-10 flex flex-col items-start">
  
  <div class="absolute -inset-12 bg-[radial-gradient(circle_at_center,rgba(45,41,38,0.2)_0%,transparent_75%)] blur-2xl pointer-events-none"></div>

  <div class="relative backdrop-blur-md bg-brand-bg/30 px-10 py-8 border border-brand-bg/10 slide-content">
    <h2 class="text-3xl md:text-5xl font-light text-brand-contrast tracking-[0.2em] mb-4 uppercase">
      {slide.title}
    </h2>
    
    <div class="flex items-center space-x-4">
      <span class="w-6 h-[1px] bg-brand-accent"></span>
      <p class="text-brand-primary text-[10px] md:text-xs tracking-[0.4em] uppercase font-light">
        {slide.subtitle}
      </p>
    </div>
  </div>
</div>        </div>
      ))}
    </div>
    <div class="swiper-pagination !bottom-10"></div>
  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Pagination, Autoplay, EffectFade } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/effect-fade';
  import 'swiper/css/pagination';

  new Swiper('.heroSwiper', {
    modules: [Pagination, Autoplay, EffectFade],
    effect: 'fade',
    loop: true,
    speed: 2000, // 切换渐变的速度，越慢越优雅
    autoplay: {
      delay: 6000, // 停留时间
      disableOnInteraction: false,
    },
    fadeEffect: {
      crossFade: true // 让图片切换更平滑，不露底色
    },
    pagination: {
      el: '.swiper-pagination',
      clickable: true,
    },
  });
</script>

<style is:global>
  /* 1. 基础图片样式与动画定义 */
  .img-container img {
    transform: scale(1.1); /* 初始略大 */
    transition: transform 7s linear; /* 缩放速度要慢于切换速度 */
  }

  /* 2. 当 Slide 激活时，图片缓慢缩放 */
  /* 这里我们让它从 1.1 缩放到 1.2，产生一种平滑的前行感 */
  .swiper-slide-active .img-container img {
    transform: scale(1.25);
  }

  /* 3. 文字内容入场动画 */
  .swiper-slide-active .slide-content {
    opacity: 1;
    transform: translate-y(0);
  }

  /* 4. 分页器自定义样式（基于你的 brand-accent） */
  .swiper-pagination-bullet {
    background: #8C7355 !important; /* 直接写死色值或确保 Tailwind 变量生效 */
    opacity: 0.3;
    transition: all 0.3s ease;
  }
  .swiper-pagination-bullet-active {
    opacity: 1;
    width: 24px;
    border-radius: 4px;
  }
</style>