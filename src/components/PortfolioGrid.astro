---
// PortfolioGrid.astro
// 模拟作品数据，实际可以从 content collections 读取
const projects = [
  { src: 'https://images.unsplash.com/photo-1542038784456-1ea8e935640e', title: 'Nature Light', size: 'large' },
  { src: 'https://images.unsplash.com/photo-1493863641943-9b68992a8d07', title: 'Pure Soul', size: 'small' },
  { src: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e', title: 'Portrait Study', size: 'small' },
  { src: 'https://images.unsplash.com/photo-1470770841072-f978cf4d019e', title: 'Earth Tones', size: 'medium' },
  { src: 'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f', title: 'Minimalist Fashion', size: 'medium' },
  { src: 'https://images.unsplash.com/photo-1505330622279-bf7d7fc918f4', title: 'Studio Still Life', size: 'small' },
  { src: 'https://images.unsplash.com/photo-1494438639946-1ebd1d20bf85', title: 'Geometric Silence', size: 'medium' },
  { src: 'https://images.unsplash.com/photo-1452421822248-d4c2b47f0c81', title: 'Traveler Memories', size: 'medium' },

];
---

<section class="py-24 bg-brand-bg">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-brand-contrast text-3xl font-serif italic mb-16 text-center">Selected Works</h2>
    
    <div id="gallery" class="columns-1 md:columns-2 lg:columns-3 gap-8 space-y-8">
      {projects.map((project) => (
        <a 
          href={project.src} 
          data-pswp-width="1600" 
          data-pswp-height="1200" 
          target="_blank"
          class="block overflow-hidden rounded-sm group relative cursor-zoom-in"
        >
          <img 
            src={project.src} 
            alt={project.title}
            class="w-full h-auto object-cover grayscale-[0.2] contrast-90 transition-all duration-1000 ease-out group-hover:scale-105 group-hover:grayscale-0 group-hover:contrast-100"
            loading="lazy"
          />
          
          <div class="absolute inset-0 bg-brand-contrast/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
            <p class="text-brand-bg text-sm tracking-widest uppercase font-light translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
              {project.title}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#gallery',
    children: 'a',
    pswpModule: () => import('photoswipe'),
    // 自定义转场动画时间
    showHideAnimationType: 'zoom',
  });
  lightbox.init();
</script>

<style>
  /* 针对 Aether 风格微调 PhotoSwipe 样式 */
  :global(.pswp__bg) {
    background: #2D2926 !important; /* 使用 brand-contrast 做预览背景 */
  }
  :global(.pswp__img) {
    background: #F9F7F2; /* 预加载时的底色 */
  }
</style>