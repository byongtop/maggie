---
/**
 * ContactCTA.astro - 呼吁行动模块
 * 采用大面积留白与强对比文字
 */
---

<section class="py-24 bg-brand-dark overflow-hidden relative">
  <div class="absolute inset-0 flex items-center justify-center opacity-[0.03] select-none pointer-events-none">
    <span class="text-[30vw] font-serif italic text-white whitespace-nowrap">AUTHENTIC</span>
  </div>

  <div class="max-w-7xl mx-auto px-8 relative z-10 text-center">
    <div class="reveal-cta">
      <h2 class="text-4xl md:text-7xl font-serif text-brand-on-dark mb-12 leading-tight">
        READY TO DEFINE YOUR <br />
        <span class="italic font-light opacity-80">VISUAL IDENTITY?</span>
      </h2>
      
      <p class="text-brand-on-dark/60 text-sm md:text-base max-w-xl mx-auto mb-16 font-sans tracking-widest leading-relaxed">
        Limited booking available per month to ensure the highest quality for every client. 
        Secure your session today.
      </p>

      <div class="flex flex-col md:flex-row items-center justify-center gap-8">
        <a href="/booking" class="group relative px-12 py-5 bg-brand-accent text-brand-on-dark overflow-hidden transition-all duration-500">
          <span class="relative z-10 text-xs tracking-[0.5em] font-bold uppercase">Reserve Your Slot</span>
          <div class="absolute inset-0 bg-white translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out"></div>
          <span class="absolute inset-0 z-20 flex items-center justify-center text-brand-dark text-xs tracking-[0.5em] font-bold uppercase translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out">Reserve Your Slot</span>
        </a>
        
        <a href="/contact" class="text-brand-on-dark/80 hover:text-white text-xs tracking-[0.4em] uppercase border-b border-brand-on-dark/20 pb-2 transition-all">
          Inquire for Custom Project
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .reveal-cta {
    opacity: 0;
    transform: translateY(50px);
    transition: all 1.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-cta.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('active');
    });
  }, { threshold: 0.2 });
  
  document.querySelectorAll('.reveal-cta').forEach(el => observer.observe(el));
</script>