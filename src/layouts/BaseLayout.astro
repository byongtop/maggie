---
import { ViewTransitions } from 'astro:transitions';
interface Props {
	title: string;
}
const { title } = Astro.props;

// 挑选了一张具有空间深度的 Unsplash 图片
const bgImage = "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=2073&auto=format&fit=crop";
---

<!doctype html>
<html lang="zh">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<ViewTransitions />
		<style is:global>
			:root { 
				--bg-color: #000; 
				--text-color: #fff; 
				/* 关键修复：初始状态锁定 HTML 溢出，防止出现滚动条 */
				overflow: hidden; 
				height: 100%;
			}

			body { 
				margin: 0; 
				background: var(--bg-color); 
				color: var(--text-color); 
				font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
				/* 关键修复：初始状态 body 也锁定 */
				overflow: hidden;
				height: 100%;
			}

			/* 当 body 获得 .is-active 类时，恢复滚动 */
			body.is-active, html.is-active {
				overflow: auto !important;
				height: auto !important;
			}

			/* 背景图片容器 */
			.bg-container {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				z-index: -1;
				overflow: hidden;
				background: #000;
			}

			/* 基础背景图片 */
			.background-image {
				width: 100%;
				height: 100%;
				object-fit: cover;
				animation: kenburns 40s infinite alternate ease-in-out;
				will-change: transform;
			}

			@keyframes kenburns {
				0% { transform: scale(1); }
				100% { transform: scale(1.2); }
			}

			/* 黑色遮罩层 */
			.bg-overlay {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background: rgba(0, 0, 0, 0.3);
				transition: background 1.2s ease;
				z-index: 1;
			}

			/* 动画类：点击 ENTER 后的状态变化 */
			.content-revealed .background-image {
				filter: blur(5px) brightness(0.6);
				transform: scale(1.1);
				transition: all 2s ease;
			}
		</style>
	</head>
	<body>
		<div class="bg-container">
			<div class="bg-overlay"></div>
			<img 
				class="background-image" 
				src={bgImage} 
				alt="Background"
			/>
		</div>
		
		<slot />

		<script>
			// 使用 Astro 专用的页面加载事件
			document.addEventListener('astro:page-load', () => {
				const enterBtn = document.getElementById('enter-btn');
				
				if (enterBtn) {
					enterBtn.addEventListener('click', () => {
						// 1. 激活滚动
						document.documentElement.classList.add('is-active');
						document.body.classList.add('is-active');
						
						// 2. 标记内容已显现（用于触发背景模糊等 CSS 动画）
						document.body.classList.add('content-revealed');
					});
				}
			});
		</script>
	</body>
</html>