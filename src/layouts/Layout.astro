---
// src/layouts/Layout.astro
import SEO from "../components/SEO.astro";
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  pageType?: "home" | "about" | "service" | "blog" | "contact" | "portfolio";
  schemas?: any[];
  breadcrumbs?: any[];
  service?: any;
  article?: any;
  images?: any[];
}

const {
  title = "Professional Portraits | Sydney Photography",
  description = "High-end image photography for dating and professional profiles in Sydney.",
  //ogImage = "/og-image.jpg",
  ogImage,
  pageType = "website",
  schemas = [],
  breadcrumbs,
  service,
  article,
  images,
} = Astro.props;

const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || "https://roseisrose.com.au"
);

const imageURL = new URL(ogImage, Astro.url);
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <SEO
      {title}
      {description}
      {ogImage}
      {pageType}
      {schemas}
      {breadcrumbs}
      {service}
      {article}
      {images}
    />
    
  </head>

  <body>
    <slot />
  </body>
</html>